  1103 				; ----------------------------------------------------------------------------
  1104 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1105 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1106 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1107 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1108 				;  address, so save/load just walk those tables.
  1109 				; ----------------------------------------------------------------------------
  1110 2644			preset_tick
  1111 2644 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1112 2647 49 01		        eor #$01
  1113 2649 29 01		        and #$01
  1114 264B 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1115 				                                ; which only touches tmp2 — NOT tmpA)
  1116 264E AE 00 06		        ldx cur_param
  1117 2651 E0 0F		        cpx #PRESET_IDX         ; PRESET param selected?
  1118 2653 D0 13		        bne pt_load
  1119 2655 AD 0C 06		        lda tmpA
  1120 2658 F0 0E		        beq pt_load
  1121 265A AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1122 265D D0 09		        bne pt_load
  1123 265F 20 90 26		        jsr preset_save
  1124 2662 AD C5 06		        lda preset_slot         ; keep prev in sync so we don't reload after save
  1125 2665 8D C6 06		        sta prev_preset
  1126 2668			pt_load
  1127 2668 AD 0C 06		        lda tmpA                ; remember fire state for next-frame edge detect
  1128 266B 8D C7 06		        sta preset_fp
  1129 266E AD C5 06		        lda preset_slot         ; selection changed -> load that slot
  1130 2671 CD C6 06		        cmp prev_preset
  1131 2674 F0 06		        beq pt_done
  1132 2676 8D C6 06		        sta prev_preset
  1133 2679 20 C0 26		        jsr preset_load
  1134 267C			pt_done
  1135 267C 60			        rts
  1136
  1137 				; bank offset of the current slot (slot * NSAVE = slot*18) -> tmp2
