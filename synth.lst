  1283 				; ----------------------------------------------------------------------------
  1284 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1285 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1286 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1287 				; ----------------------------------------------------------------------------
  1288 284A			lfo_tick
  1289 284A AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1290 284D D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1291 284F 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1292 2852 8D 65 06		        sta lfo_level_u
  1293 2855 60			        rts
  1294 2856			lt_on
  1295 2856 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1296 2857 8D 69 06		        sta lfo_max
  1297 285A CE 67 06		        dec lfo_count
  1298 285D F0 01		        beq lt_step
  1299 285F 60			        rts
  1300 2860			lt_step
  1301 2860 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1302 2862 38			        sec
  1303 2863 ED 63 06		        sbc lfo_rate
  1304 2866 8D 67 06		        sta lfo_count
  1305 2869 AD 69 06		        lda lfo_max
  1306 286C 0A			        asl
  1307 286D 8D 6A 06		        sta lfo_max2            ; 2*max
  1308 2870 AD 66 06		        lda lfo_dir
  1309 2873 30 19		        bmi lt_down
  1310 2875 EE 65 06		        inc lfo_level_u         ; ramp up
  1311 2878 AD 65 06		        lda lfo_level_u
  1312 287B CD 6A 06		        cmp lfo_max2
  1313 287E 90 1E		        bcc lt_offset
