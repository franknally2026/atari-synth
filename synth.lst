   576 				; Tab: jump the selection to the first param of the next page (0->1->2->0).
   577 				; update_display derives the page from cur_param, so this is all it takes.
   578 228D			page_flip
   579 228D AD 00 06		        lda cur_param
   580 2290 C9 0C		        cmp #PER_PAGE           ; page 0 (0..11) -> page 1
   581 2292 90 0A		        bcc pf_to1
   582 2294 C9 10		        cmp #PG2BASE            ; page 1 (12..15) -> page 2
   583 2296 90 0C		        bcc pf_to2
   584 2298 A9 00		        lda #0                  ; page 2 -> wrap to page 0
   585 229A 8D 00 06		        sta cur_param
   586 229D 60			        rts
   587 229E			pf_to1
   588 229E A9 0C		        lda #PER_PAGE
   589 22A0 8D 00 06		        sta cur_param
   590 22A3 60			        rts
   591 22A4			pf_to2
   592 22A4 A9 10		        lda #PG2BASE
   593 22A6 8D 00 06		        sta cur_param
   594 22A9 60			        rts
