  1011 				; ----------------------------------------------------------------------------
  1012 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
  1013 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
  1014 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
  1015 				;  high channel). drum_tick runs after update_sound and overrides channel 4
  1016 				;  while a hit rings; when it ends, voice 3's normal output resumes.
  1017 				; ----------------------------------------------------------------------------
  1018 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
  1019 25B2			drum_hit
  1020 25B2 AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
  1021 25B5 F0 12		        beq dh_off
  1022 25B7 AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
  1023 25BA C9 02		        cmp #2
  1024 25BC F0 0B		        beq dh_off
  1025 25BE A9 0F		        lda #15
  1026 25C0 8D BE 06		        sta drum_level
  1027 25C3 AD BD 06		        lda drum_dec            ; full level held for one decay interval first
  1028 25C6 8D BF 06		        sta drum_timer
  1029 25C9			dh_off
