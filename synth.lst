   272 				; ----------------------------------------------------------------------------
   273 				        org $2000
   274
   275 				main
   276 FFFF> 2000-39CE> A9 01	        lda #1
   277 2002 8D F0 02		        sta CRSINH
   278 2005 A9 FF		        lda #$FF
   279 2007 8D DB 02		        sta NOCLIK
   280 				        ; ---- known, launcher-independent POKEY state ----------------------
   281 				        ; Don't inherit whatever a cartridge / flash-cart / DOS left in POKEY.
   282 				        ; Silence all four channels and clear AUDCTL up front so there's no stray
   283 				        ; tone or leftover join/clock config before the engine's first frame.
   284 200A A9 00		        lda #0
   285 200C 8D 08 D2		        sta AUDCTL              ; no joins, 64kHz base (update_sound re-sets per mode)
   286 200F A2 07		        ldx #7
   287 2011			clr_pokey
   288 2011 9D 00 D2		        sta AUDF1,x             ; AUDF1/AUDC1 .. AUDF4/AUDC4 ($D200-$D207) = 0
   289 2014 CA			        dex
   290 2015 10 FA		        bpl clr_pokey
   291 2017 A9 03		        lda #$03                ; keyboard scan + debounce; serial OFF
   292 2019 8D 0F D2		        sta SKCTL
   293 				        ; IRQ enables: NONE (verified on real hardware 2026-06-17). The synth POLLS
   294 				        ; KBCODE/SKSTAT/CONSOL every frame; KBCODE is kept current by POKEY's keyboard
   295 				        ; SCAN logic (SKCTL bit1, set above), independent of the keyboard IRQ. Turning
   296 				        ; the keyboard IRQ OFF removes the OS keyboard ISR, whose VBI auto-repeat fired
   297 				        ; the console-speaker key-click on a timer (real-hw bug #3 "sounds on a regular
   298 				        ; interval") and whose debounce desynced with our direct KBCODE poll after a
   299 				        ; few presses (real-hw bug #2 "keyboard stops after changing params"). Both
   300 				        ; bugs are gone on real hardware with IRQEN=0. (Enabling the keyboard IRQ and
   301 				        ; servicing it with our own minimal handler was tried and DEAD the keyboard on
   302 				        ; real hardware — do NOT re-enable it.) IRQEN=0 also covers INHERITING the
   303 				        ; launcher's serial/timer enables: in 16-BIT mode AUDCTL=$78 clocks ch1/ch3 at
   304 				        ; 1.79MHz through POKEY's serial/timer logic, and a stray serial/timer IRQ
   305 				        ; would fire faster than its handler returns and HARD-LOCK the machine.
   306 				        ; NOTE: the headless AltirraSDL test bridge injects cooked keys through POKEY's
   307 				        ; key queue, which only releases a key to KBCODE while the keyboard IRQ is
   308 				        ; enabled (ATPokeyEmulator::CanPushKey tests mIRQST & mIRQEN & $40). So the
   309 				        ; emulator key-injection tests need a build with the IRQ on; see EMU_KBD_IRQ.
   310 				    .if EMU_KBD_IRQ
   311 				        lda #$40                ; EMU TEST BUILD ONLY: keyboard IRQ on so AltirraSDL can
   312 				    .else                       ; inject cooked keys. NEVER ship this — it dead-keys real hw.
   313 201C A9 00		        lda #$00                ; shipping/real-hw: no POKEY IRQs (fixes bugs #2/#3)
   314 				    .endif
   315 201E 85 10		        sta POKMSK
   316 2020 8D 0E D2		        sta IRQEN
   317
   318 2023 20 4A 2A		        jsr gr8_init            ; set up GR.8 + clear
   319
