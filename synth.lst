   699 				; Return mirrors the joystick fire button: save the patch, but only while the
   700 				; PRESET param is selected. Keep prev_preset in sync so preset_tick won't reload.
   701 22F8			nav_save_preset
   702 22F8 AD 00 06		        lda cur_param
   703 22FB C9 0F		        cmp #PRESET_IDX         ; PRESET param index
   704 22FD D0 09		        bne nsp_done
   705 22FF 20 DE 26		        jsr preset_save
   706 2302 AD C5 06		        lda preset_slot
   707 2305 8D C6 06		        sta prev_preset
   708 2308			nsp_done
   709 2308 60			        rts
