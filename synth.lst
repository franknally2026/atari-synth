   149 = 066D			dp_scan     = $066D
   150 				; DETUNE (fat pitch)
   151 = 066E			detune      = $066E     ; 0..15 panel param
   152 = 066F			detune_amt  = $066F     ; detune >> 2 (per-voice AUDF step)
   153 = 0670			prev_disp   = $0670     ; NPARAM bytes ($0670-$067B): last displayed value
   154 = 06C1			dvoff       = $06C1     ; 4 bytes: per-voice detune AUDF offset (moved up: prev_disp
   155 				                        ; grew with NPARAM and reached the old $0680 slot)
   156 				; arpeggiator
   157 = 0684			arp_rate    = $0684     ; 0 = off, 1..15 = step speed
   158 = 0685			arp_step    = $0685     ; pattern position 0..3
   159 = 0686			arp_timer   = $0686     ; frames to next arp step
   160 				; --- new feature work vars (allocated above the sequencer block at $06B5+ so
   161 				;     they stay clear of prev_disp, which grows with NPARAM) ---
   162 = 06B5			arp_mode    = $06B5     ; arpeggiator pattern: 0 UP, 1 DOWN, 2 MINOR, 3 OCTAVE
   163 = 06B6			porta_rate  = $06B6     ; portamento (glide): 0 off, 1..15 = AUDF step every N frames
   164 = 06B7			porta_timer = $06B7     ; frames to next glide step
   165 = 06B8			porta_cur   = $06B8     ; 4: current (gliding) AUDF per voice
   166 = 06BC			porta_step  = $06BC     ; 1 on frames where the glide advances one step
   167 = 06BD			drum_dec    = $06BD     ; DRUM param: 0 off, 1..15 = decay frames per level step
   168 = 06BE			drum_level  = $06BE     ; current drum envelope level (0 = drum channel free)
   169 = 06BF			drum_timer  = $06BF     ; frames to next drum decay step
   170 = 06C0			hpf_cut     = $06C0     ; HP filter: 0 off, 1..15 cutoff (uses ch3 as the clock)
   171 = 06C5			preset_slot = $06C5     ; PRESET param: selected patch slot 0..3
   172 = 06C6			prev_preset = $06C6     ; last slot (detect selection change -> load)
   173 = 06C7			preset_fp   = $06C7     ; previous fire-button state (edge detect for save)
   174 = 06C8			drum_key    = $06C8     ; previous drum-key ('1') state (edge detect for live hit)
   175 = 06C9			drum_beat   = $06C9     ; DRUMBEAT param: 0 off, 1..15 auto drum-machine rate
   176 = 06CA			dbeat_timer = $06CA     ; frames to next tempo beat
   177 = 06CB			dbeat_cnt   = $06CB     ; tempo beats remaining until the next auto drum hit
   178 = 0700			preset_bank = $0700     ; 4 slots x NSAVE bytes of saved params (page 7, free RAM)
   179 = 0687			sustain_ped = $0687     ; 1 while OPTION held -> notes don't release
   180 = 0688			vlimit      = $0688     ; active voice count: 4 (8-bit) or 2 (16-bit)
   181 = 0689			prev_clkm   = $0689     ; previous clock mode (detect change -> reset voices)
   182 = 068A			nlo         = $068A     ; 16-bit divider scratch (low/high)
   183 = 068B			nhi         = $068B
   184 = 068C			tempo       = $068C     ; sequencer tempo (0..15), page-2 param
   185 = 068D			page        = $068D     ; current panel page (cur_param / 12)
   186 = 068E			prev_page   = $068E
   187 = 068F			pg_base     = $068F     ; first param index of current page
   188 = 0690			pg_end      = $0690     ; one past last param index of current page
   189 				; step sequencer
   190 = 0691			seq_notes   = $0691     ; 16 steps: semitone 0..16, or $FF = rest
   191 = 06A1			seq_play    = $06A1     ; 0 stopped / 1 playing
   192 = 06A2			seq_rec     = $06A2     ; 0 / 1 record-armed
   193 = 06A3			seq_pos     = $06A3     ; play head 0..15
   194 = 06A4			seq_wpos    = $06A4     ; record write head 0..15
   195 = 06A5			seq_timer   = $06A5     ; frames to next step
   196 = 06A6			seq_prevn   = $06A6     ; previous note (record onset edge)
   197 = 06A7			prev_spos   = $06A7     ; last drawn play head (display diff)
   198 = 06A8			prev_splay  = $06A8
   199 = 06A9			prev_srec   = $06A9
   200 = 06AA			seq_dirty   = $06AA     ; 1 = step grid needs full redraw
   201 = 06AB			con_now     = $06AB     ; console keys pressed bits (active high)
   202 = 06AC			con_prev    = $06AC
   203 				; per-voice level meters (VU bars at the top, scan 9-13)
   204 = 06AD			prev_vmeter = $06AD     ; 4: last drawn level per voice (incremental redraw)
   205 = 06B1			dm_lo       = $06B1     ; meter draw scratch: lower envelope level
   206 = 06B2			dm_hi       = $06B2     ; meter draw scratch: higher envelope level
   207 = 06B3			seq_len     = $06B3     ; playback loop length = number of recorded steps (1..16)
   208 = 06B4			rec_latch   = $06B4     ; real-time record: note played since last step ($FF=none)
   209 = 06CC			hl_idx      = $06CC     ; DEMO: char index in current label to highlight
   210 = 06CD			dli_idx     = $06CD     ; DEMO: which colour band the next DLI sets (reset each frame)
   211 = 06CE			kbd_dir     = $06CE     ; arrow-key direction bits (mirrors STICK0: U/D/L/R) for update_input
   212 = 06CF			nav_prev    = $06CF     ; last nav-key KBCODE ($FF=none); edge-detect Tab/Return
   213 = 06D0			dp_zoff     = $06D0     ; draw_param: 1 = this param renders value 0 as "OFF"
   214 = 06D1			prev_hint   = $06D1     ; last drawn hint-line id ($FF = force redraw)
   215 = 06D2			pl_inv      = $06D2     ; print_label base inverse: $FF = focused param (inverse video)
   216 = 06D3			hl_shift    = $06D3     ; 1 = the shortcut char is a SHIFT key (drawn opposite video)
   217 = 06D4			saved_flash = $06D4     ; >0 = show "SAVED" over the PRESET name for this many frames
   218 = 06D5			base8       = $06D5     ; 16-bit vibrato/detune scale = note AUDF16 >> 6
   219 = 06D6			acclo       = $06D6     ; add_scaled16 product (low)
   220 = 06D7			acchi       = $06D7     ; add_scaled16 product (high)
   221 = 06D8			scl_sgn     = $06D8     ; add_scaled16 saved signed offset
   222 = 06D9			dct_col     = $06D9     ; draw_clk_toggle: clock-name start column (from p_knobcx)
   223 = 06DA			dct_scan    = $06DA     ; draw_clk_toggle: clock-name scanline (from p_scan)
   224 = 06DB			nav_base    = $06DB     ; read_navkeys: KBCODE with the Shift/Ctrl bits masked off
   225 = 06DC			nav_shift   = $06DC     ; read_navkeys: 1 = a modifier (Shift) is held this frame
   226
