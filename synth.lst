   659 				; ----------------------------------------------------------------------------
   660 				;  Step sequencer: record note onsets into a 16-step pattern; when playing,
   661 				;  step at the TEMPO rate and trigger each step's note via trigger_note.
   662 				; ----------------------------------------------------------------------------
   663 230A			seq_tick
   664 230A AD A2 06		        lda seq_rec             ; --- record: detect a new note onset ---
   665 230D F0 40		        beq sq_norec
   666 230F AD 07 06		        lda note_idx
   667 2312 C9 FF		        cmp #$FF
   668 2314 F0 33		        beq sq_recdone
   669 2316 CD A6 06		        cmp seq_prevn
   670 2319 F0 2E		        beq sq_recdone          ; same held note -> not a new onset
   671 231B AC A1 06		        ldy seq_play
   672 231E D0 23		        bne sq_latch            ; PLAYING+REC = real-time: latch; clock writes it
   673 2320 AE A4 06		        ldx seq_wpos            ; STOPPED+REC = step entry: write here, advance
   674 2323 9D 91 06		        sta seq_notes,x
   675 2326 E8			        inx
   676 2327 EC B3 06		        cpx seq_len             ; grow loop length to the furthest step filled
   677 232A 90 03		        bcc sq_nolen
   678 232C 8E B3 06		        stx seq_len
   679 232F			sq_nolen
   680 232F E0 10		        cpx #16
   681 2331 D0 02		        bne sq_wok
   682 2333 A2 00		        ldx #0
   683 2335			sq_wok
   684 2335 8E A4 06		        stx seq_wpos
   685 2338 A9 01		        lda #1
   686 233A 8D AA 06		        sta seq_dirty
   687 233D AD 07 06		        lda note_idx
   688 2340 4C 49 23		        jmp sq_recdone
   689 2343			sq_latch
   690 2343 8D B4 06		        sta rec_latch           ; real-time: remember the onset for the clock
   691 2346 AD 07 06		        lda note_idx
   692 2349			sq_recdone
   693 2349 8D A6 06		        sta seq_prevn
   694 234C 4C 57 23		        jmp sq_play
   695 234F			sq_norec
   696 234F A9 FF		        lda #$FF
   697 2351 8D A6 06		        sta seq_prevn
   698 2354 8D B4 06		        sta rec_latch           ; not armed -> drop any pending latch
   699 2357			sq_play
   700 2357 AD A1 06		        lda seq_play            ; --- play / real-time clock ---
   701 235A D0 01		        bne sq_playing
   702 235C 60			        rts
   703 235D			sq_playing
   704 235D CE A5 06		        dec seq_timer
   705 2360 F0 01		        beq sq_step
   706 2362 60			        rts
   707 2363			sq_step
   708 2363 A9 10		        lda #16                 ; reload: interval = (16-tempo)*2 + 2 frames
   709 2365 38			        sec
   710 2366 ED 8C 06		        sbc tempo
   711 2369 0A			        asl
   712 236A 18			        clc
   713 236B 69 02		        adc #2
   714 236D 8D A5 06		        sta seq_timer
   715 2370 AE A3 06		        ldx seq_pos             ; play this step's EXISTING note (timing reference)
   716 2373 BD 91 06		        lda seq_notes,x
   717 2376 C9 FE		        cmp #$FE                ; TIE -> a held note continues: do NOT re-strike,
   718 2378 F0 3F		        beq sq_nostep           ; let the sustaining voice ring on (no blips)
   719 237A C9 FD		        cmp #$FD                ; DRUM hit step
   720 237C D0 06		        bne sq_nodrum
   721 237E 20 B2 25		        jsr drum_hit
   722 2381 4C B9 23		        jmp sq_nostep
   723 2384			sq_nodrum
   724 2384 C9 FF		        cmp #$FF
   725 2386 D0 14		        bne sq_playnote
   726 2388 AD A2 06		        lda seq_rec             ; rest step -> silence the gap by releasing the held
   727 238B F0 07		        beq sq_restrel          ; voice. Playback always releases; while recording,
   728 238D AD 07 06		        lda note_idx            ; keep a LIVE-held note (don't cut your own playing)
   729 2390 C9 FF		        cmp #$FF                ; but still release when only monitoring (no key down).
   730 2392 D0 25		        bne sq_nostep
   731 2394			sq_restrel
   732 2394 A9 FF		        lda #$FF
   733 2396 8D 18 06		        sta held_voice
   734 2399 4C B9 23		        jmp sq_nostep
   735 239C			sq_playnote
   736 239C 8D 0C 06		        sta tmpA
   737 239F AD A2 06		        lda seq_rec             ; while RECORDING, don't let the clock re-strike a note
   738 23A2 F0 08		        beq sq_pn_go            ; you're already holding live -> that would double it
   739 23A4 AD 0C 06		        lda tmpA                ; (two unison voices) and re-attack your sustained note
   740 23A7 CD 07 06		        cmp note_idx            ; every loop. note_idx is the live semitone; tmpA is the
   741 23AA F0 0D		        beq sq_nostep           ; step's. Same -> skip the clock trigger, keep monitoring.
   742 23AC			sq_pn_go
   743 23AC AC 03 06		        ldy octave
   744 23AF B9 1C 36		        lda octave_base,y
   745 23B2 18			        clc
   746 23B3 6D 0C 06		        adc tmpA
   747 23B6 20 E9 24		        jsr trigger_note
   748 23B9			sq_nostep
   749 23B9 AD A2 06		        lda seq_rec             ; real-time: capture the live note into this step
   750 23BC F0 2E		        beq sq_adv
   751 23BE AD B4 06		        lda rec_latch           ; a NEW onset latched since the last tick?
   752 23C1 C9 FF		        cmp #$FF
   753 23C3 D0 17		        bne sq_cap              ; yes -> write the struck note (re-attack)
   754 23C5 AD 07 06		        lda note_idx            ; else still holding the same key?
   755 23C8 C9 FF		        cmp #$FF
   756 23CA F0 20		        beq sq_adv              ; nothing held -> leave step (rest)
   757 23CC C9 FD		        cmp #$FD                ; a HELD drum key is a one-shot, not a sustain: don't
   758 23CE F0 1C		        beq sq_adv              ; smear it into ties (leave following steps as rests)
   759 23D0 AE A3 06		        ldx seq_pos             ; held pitch -> extend with a TIE, but ONLY into a
   760 23D3 BD 91 06		        lda seq_notes,x         ; REST. On a later loop this step already holds the
   761 23D6 C9 FF		        cmp #$FF                ; struck note (or its ties); rewriting it as a tie
   762 23D8 D0 12		        bne sq_adv              ; would wipe the attack and play back silent. Leave it.
   763 23DA A9 FE		        lda #$FE                ; held pitch over a rest -> TIE (sustains on playback)
   764 23DC			sq_cap
   765 23DC AE A3 06		        ldx seq_pos
   766 23DF 9D 91 06		        sta seq_notes,x
   767 23E2 A9 01		        lda #1
   768 23E4 8D AA 06		        sta seq_dirty
   769 23E7 A9 FF		        lda #$FF
   770 23E9 8D B4 06		        sta rec_latch           ; consume the latch
   771 23EC			sq_adv
   772 23EC EE A3 06		        inc seq_pos             ; wrap at the recorded length (or 16 if empty)
   773 23EF AE B3 06		        ldx seq_len
   774 23F2 D0 02		        bne sq_lim
   775 23F4 A2 10		        ldx #16
   776 23F6			sq_lim
   777 23F6 EC A3 06		        cpx seq_pos
   778 23F9 D0 05		        bne sq_done
   779 23FB A9 00		        lda #0
   780 23FD 8D A3 06		        sta seq_pos
   781 2400			sq_done
   782 2400 60			        rts
   783
   784 				; Unified directional input: up/down navigate, left/right adjust. ALL FOUR now
   785 				; auto-repeat off one rep_timer (was: U/D edge-only, L/R repeated). Arrow keys are
   786 				; merged in via kbd_dir (read_navkeys) so they drive the exact same path.
   787 2401			update_input
   788 2401 AD 78 02		        lda STICK0
   789 2404 29 0F		        and #$0F
   790 2406 49 0F		        eor #$0F                ; bit0=up bit1=down bit2=left bit3=right (active high)
   791 2408 0D CE 06		        ora kbd_dir             ; merge arrow keys -> identical nav/adjust/repeat
   792 240B 8D 09 06		        sta pressed
   793 240E AD 05 06		        lda prev_pressed
   794 2411 49 FF		        eor #$FF
   795 2413 2D 09 06		        and pressed
   796 2416 8D 0A 06		        sta edge                ; freshly-pressed directions this frame
   797 2419 AD 09 06		        lda pressed
   798 241C 29 0F		        and #$0F
   799 241E D0 08		        bne ui_held
   800 2420 A9 0F		        lda #REPDELAY           ; nothing held -> re-arm the initial delay
   801 2422 8D 06 06		        sta rep_timer
   802 2425 4C 89 24		        jmp ui_done
   803 2428			ui_held
   804 2428 AD 0A 06		        lda edge
   805 242B 29 0F		        and #$0F
   806 242D D0 0D		        bne ui_fresh            ; a fresh press -> act immediately
   807 242F CE 06 06		        dec rep_timer
   808 2432 D0 55		        bne ui_done             ; still counting down -> no action this frame
   809 2434 A9 04		        lda #REPFAST            ; timer expired -> repeat at the fast rate
   810 2436 8D 06 06		        sta rep_timer
   811 2439 4C 41 24		        jmp ui_act
   812 243C			ui_fresh
   813 243C A9 0F		        lda #REPDELAY
   814 243E 8D 06 06		        sta rep_timer
   815 2441			ui_act
   816 2441 AD 09 06		        lda pressed             ; UP -> previous param (wrap)
   817 2444 29 01		        and #$01
   818 2446 F0 0A		        beq ui_a_nodn
   819 2448 CE 00 06		        dec cur_param
   820 244B 10 05		        bpl ui_a_nodn
   821 244D A9 12		        lda #NPARAM-1
   822 244F 8D 00 06		        sta cur_param
   823 2452			ui_a_nodn
   824 2452 AD 09 06		        lda pressed             ; DOWN -> next param (wrap)
   825 2455 29 02		        and #$02
   826 2457 F0 0F		        beq ui_a_nolr
   827 2459 EE 00 06		        inc cur_param
