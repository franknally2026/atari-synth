  2158 				; ----------------------------------------------------------------------------
  2159 				;  Per-voice level meters: 4 horizontal VU bars at scan 9-13, bar width =
  2160 				;  voice envelope level * 3 px. Drawn INCREMENTALLY -- each frame only the
  2161 				;  delta between the old and new level is set/cleared, so meters animating
  2162 				;  with the envelopes cost a few pixels per voice, not a full redraw.
  2163 				; ----------------------------------------------------------------------------
  2164 2EFC			draw_meters
  2165 2EFC A2 00		        ldx #0
  2166 2EFE			dm_loop
  2167 2EFE 8E 46 06		        stx s_kc
  2168 2F01 BD 14 06		        lda voice_level,x
  2169 2F04 DD AD 06		        cmp prev_vmeter,x
  2170 2F07 F0 69		        beq dm_next
  2171 2F09 BC AD 06		        ldy prev_vmeter,x       ; old level
  2172 2F0C 8C 0D 06		        sty tmp2
  2173 2F0F 9D AD 06		        sta prev_vmeter,x       ; store new
  2174 2F12 CD 0D 06		        cmp tmp2                ; new - old
  2175 2F15 B0 14		        bcs dm_rise
  2176 2F17 A9 FF		        lda #$FF                ; level fell -> CLEAR from new to old
  2177 2F19 8D 61 06		        sta pmode
  2178 2F1C AD 0D 06		        lda tmp2
  2179 2F1F 8D B2 06		        sta dm_hi               ; hi = old
  2180 2F22 BD AD 06		        lda prev_vmeter,x
  2181 2F25 8D B1 06		        sta dm_lo               ; lo = new
  2182 2F28 4C 3C 2F		        jmp dm_calc
  2183 2F2B			dm_rise
  2184 2F2B A9 00		        lda #0                  ; level rose -> SET from old to new
  2185 2F2D 8D 61 06		        sta pmode
  2186 2F30 AD 0D 06		        lda tmp2
  2187 2F33 8D B1 06		        sta dm_lo               ; lo = old
  2188 2F36 BD AD 06		        lda prev_vmeter,x
  2189 2F39 8D B2 06		        sta dm_hi               ; hi = new
  2190 2F3C			dm_calc
  2191 2F3C AE 46 06		        ldx s_kc
  2192 2F3F AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2193 2F42 0A			        asl
  2194 2F43 18			        clc
  2195 2F44 6D B1 06		        adc dm_lo
  2196 2F47 18			        clc
  2197 2F48 7D 80 2F		        adc met_x,x
  2198 2F4B 8D 40 06		        sta xlo
  2199 2F4E A9 00		        lda #0
  2200 2F50 8D 41 06		        sta xhi
