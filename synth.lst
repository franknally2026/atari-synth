  1084 				; ----------------------------------------------------------------------------
  1085 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1086 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1087 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1088 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1089 				;  address, so save/load just walk those tables.
  1090 				; ----------------------------------------------------------------------------
  1091 2627			preset_tick
  1092 2627 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1093 262A 49 01		        eor #$01
  1094 262C 29 01		        and #$01
  1095 262E 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1096 				                                ; which only touches tmp2 — NOT tmpA)
  1097 2631 AE 00 06		        ldx cur_param
  1098 2634 E0 11		        cpx #17                 ; PRESET param selected?
  1099 2636 D0 13		        bne pt_load
  1100 2638 AD 0C 06		        lda tmpA
  1101 263B F0 0E		        beq pt_load
  1102 263D AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1103 2640 D0 09		        bne pt_load
  1104 2642 20 6F 26		        jsr preset_save
  1105 2645 AD C5 06		        lda preset_slot         ; keep prev in sync so we don't reload after save
  1106 2648 8D C6 06		        sta prev_preset
  1107 264B			pt_load
  1108 264B AD 0C 06		        lda tmpA                ; remember fire state for next-frame edge detect
  1109 264E 8D C7 06		        sta preset_fp
  1110 2651 AD C5 06		        lda preset_slot         ; selection changed -> load that slot
  1111 2654 CD C6 06		        cmp prev_preset
  1112 2657 F0 06		        beq pt_done
  1113 2659 8D C6 06		        sta prev_preset
  1114 265C 20 9B 26		        jsr preset_load
  1115 265F			pt_done
  1116 265F 60			        rts
  1117
