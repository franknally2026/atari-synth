  1201 				; ----------------------------------------------------------------------------
  1202 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1203 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1204 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1205 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1206 				;  address, so save/load just walk those tables.
  1207 				; ----------------------------------------------------------------------------
  1208 2692			preset_tick
  1209 2692 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1210 2695 49 01		        eor #$01
  1211 2697 29 01		        and #$01
  1212 2699 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1213 				                                ; which only touches tmp2 — NOT tmpA)
  1214 269C AE 00 06		        ldx cur_param
  1215 269F E0 0F		        cpx #PRESET_IDX         ; PRESET param selected?
  1216 26A1 D0 13		        bne pt_load
  1217 26A3 AD 0C 06		        lda tmpA
  1218 26A6 F0 0E		        beq pt_load
  1219 26A8 AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1220 26AB D0 09		        bne pt_load
  1221 26AD 20 DE 26		        jsr preset_save
  1222 26B0 AD C5 06		        lda preset_slot         ; keep prev in sync so we don't reload after save
  1223 26B3 8D C6 06		        sta prev_preset
  1224 26B6			pt_load
