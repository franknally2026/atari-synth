  1113 2654 8D C7 06		        sta preset_fp
  1114 2657 AD C5 06		        lda preset_slot         ; selection changed -> load that slot
  1115 265A CD C6 06		        cmp prev_preset
  1116 265D F0 06		        beq pt_done
  1117 265F 8D C6 06		        sta prev_preset
  1118 2662 20 A1 26		        jsr preset_load
  1119 2665			pt_done
  1120 2665 60			        rts
  1121
