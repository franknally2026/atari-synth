  3393 3CDA 00 00 00 7E 7E 00 +         .byte $00,$00,$00,$7E,$7E,$00,$00,$00   ; 2 TIE   - centred horizontal bar
  3394 3CE2 00 42 24 18 18 24 +         .byte $00,$42,$24,$18,$18,$24,$42,$00   ; 3 DRUM  - X (percussion hit)
