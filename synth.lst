  2452 309D			dm_calc
  2453 309D AE 46 06		        ldx s_kc
  2454 30A0 AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2455 30A3 0A			        asl
  2456 30A4 18			        clc
