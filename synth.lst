   654 				; ----------------------------------------------------------------------------
   655 				;  Step sequencer: record note onsets into a 16-step pattern; when playing,
   656 				;  step at the TEMPO rate and trigger each step's note via trigger_note.
   657 				; ----------------------------------------------------------------------------
   658 230A			seq_tick
   659 230A AD A2 06		        lda seq_rec             ; --- record: detect a new note onset ---
   660 230D F0 40		        beq sq_norec
   661 230F AD 07 06		        lda note_idx
   662 2312 C9 FF		        cmp #$FF
   663 2314 F0 33		        beq sq_recdone
   664 2316 CD A6 06		        cmp seq_prevn
   665 2319 F0 2E		        beq sq_recdone          ; same held note -> not a new onset
   666 231B AC A1 06		        ldy seq_play
   667 231E D0 23		        bne sq_latch            ; PLAYING+REC = real-time: latch; clock writes it
   668 2320 AE A4 06		        ldx seq_wpos            ; STOPPED+REC = step entry: write here, advance
   669 2323 9D 91 06		        sta seq_notes,x
   670 2326 E8			        inx
   671 2327 EC B3 06		        cpx seq_len             ; grow loop length to the furthest step filled
   672 232A 90 03		        bcc sq_nolen
   673 232C 8E B3 06		        stx seq_len
   674 232F			sq_nolen
   675 232F E0 10		        cpx #16
   676 2331 D0 02		        bne sq_wok
   677 2333 A2 00		        ldx #0
   678 2335			sq_wok
   679 2335 8E A4 06		        stx seq_wpos
   680 2338 A9 01		        lda #1
   681 233A 8D AA 06		        sta seq_dirty
   682 233D AD 07 06		        lda note_idx
   683 2340 4C 49 23		        jmp sq_recdone
   684 2343			sq_latch
   685 2343 8D B4 06		        sta rec_latch           ; real-time: remember the onset for the clock
   686 2346 AD 07 06		        lda note_idx
   687 2349			sq_recdone
   688 2349 8D A6 06		        sta seq_prevn
   689 234C 4C 57 23		        jmp sq_play
   690 234F			sq_norec
   691 234F A9 FF		        lda #$FF
   692 2351 8D A6 06		        sta seq_prevn
   693 2354 8D B4 06		        sta rec_latch           ; not armed -> drop any pending latch
   694 2357			sq_play
   695 2357 AD A1 06		        lda seq_play            ; --- play / real-time clock ---
   696 235A D0 01		        bne sq_playing
   697 235C 60			        rts
   698 235D			sq_playing
   699 235D CE A5 06		        dec seq_timer
   700 2360 F0 01		        beq sq_step
   701 2362 60			        rts
   702 2363			sq_step
   703 2363 A9 10		        lda #16                 ; reload: interval = (16-tempo)*2 + 2 frames
   704 2365 38			        sec
   705 2366 ED 8C 06		        sbc tempo
   706 2369 0A			        asl
   707 236A 18			        clc
   708 236B 69 02		        adc #2
   709 236D 8D A5 06		        sta seq_timer
   710 2370 AE A3 06		        ldx seq_pos             ; play this step's EXISTING note (timing reference)
   711 2373 BD 91 06		        lda seq_notes,x
   712 2376 C9 FE		        cmp #$FE                ; TIE -> a held note continues: do NOT re-strike,
   713 2378 F0 2B		        beq sq_nostep           ; let the sustaining voice ring on (no blips)
   714 237A C9 FD		        cmp #$FD                ; DRUM hit step
   715 237C D0 06		        bne sq_nodrum
   716 237E 20 85 25		        jsr drum_hit
   717 2381 4C A5 23		        jmp sq_nostep
   718 2384			sq_nodrum
   719 2384 C9 FF		        cmp #$FF
   720 2386 D0 0D		        bne sq_playnote
   721 2388 AD A2 06		        lda seq_rec             ; rest: during playback, release the held note so
   722 238B D0 18		        bne sq_nostep           ; the rest is silent (don't cut live monitoring)
   723 238D A9 FF		        lda #$FF
   724 238F 8D 18 06		        sta held_voice
   725 2392 4C A5 23		        jmp sq_nostep
   726 2395			sq_playnote
   727 2395 8D 0C 06		        sta tmpA
   728 2398 AC 03 06		        ldy octave
   729 239B B9 81 35		        lda octave_base,y
   730 239E 18			        clc
   731 239F 6D 0C 06		        adc tmpA
   732 23A2 20 CC 24		        jsr trigger_note
   733 23A5			sq_nostep
   734 23A5 AD A2 06		        lda seq_rec             ; real-time: capture the live note into this step
   735 23A8 F0 20		        beq sq_adv
   736 23AA AD B4 06		        lda rec_latch           ; a NEW onset latched since the last tick?
   737 23AD C9 FF		        cmp #$FF
   738 23AF D0 09		        bne sq_cap              ; yes -> write the struck note (re-attack)
   739 23B1 AD 07 06		        lda note_idx            ; else still holding the same note?
   740 23B4 C9 FF		        cmp #$FF
   741 23B6 F0 12		        beq sq_adv              ; nothing held -> leave step (rest)
   742 23B8 A9 FE		        lda #$FE                ; held continuation -> TIE (sustains on playback)
   743 23BA			sq_cap
   744 23BA AE A3 06		        ldx seq_pos
   745 23BD 9D 91 06		        sta seq_notes,x
   746 23C0 A9 01		        lda #1
   747 23C2 8D AA 06		        sta seq_dirty
   748 23C5 A9 FF		        lda #$FF
   749 23C7 8D B4 06		        sta rec_latch           ; consume the latch
   750 23CA			sq_adv
   751 23CA EE A3 06		        inc seq_pos             ; wrap at the recorded length (or 16 if empty)
   752 23CD AE B3 06		        ldx seq_len
   753 23D0 D0 02		        bne sq_lim
   754 23D2 A2 10		        ldx #16
   755 23D4			sq_lim
   756 23D4 EC A3 06		        cpx seq_pos
   757 23D7 D0 05		        bne sq_done
   758 23D9 A9 00		        lda #0
   759 23DB 8D A3 06		        sta seq_pos
   760 23DE			sq_done
   761 23DE 60			        rts
