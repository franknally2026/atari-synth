  1013 25B2 60			        rts                     ; idle -> leave channel 4 to voice 3
  1014 25B3			dt_active
  1015 25B3 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1016 25B6 F0 07		        beq dt_kill
  1017 25B8 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1018 25BB C9 02		        cmp #2
  1019 25BD D0 06		        bne dt_decay
  1020 25BF			dt_kill
  1021 25BF A9 00		        lda #0
  1022 25C1 8D BE 06		        sta drum_level
  1023 25C4 60			        rts
  1024 25C5			dt_decay
  1025 25C5 CE BF 06		        dec drum_timer
  1026 25C8 D0 09		        bne dt_emit
  1027 25CA AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1028 25CD 8D BF 06		        sta drum_timer
