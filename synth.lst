  2327 				; ----------------------------------------------------------------------------
  2328 				;  Per-voice level meters: 4 horizontal VU bars at scan 9-13, bar width =
  2329 				;  voice envelope level * 3 px. Drawn INCREMENTALLY -- each frame only the
  2330 				;  delta between the old and new level is set/cleared, so meters animating
  2331 				;  with the envelopes cost a few pixels per voice, not a full redraw.
  2332 				; ----------------------------------------------------------------------------
  2333 2FD2			draw_meters
  2334 2FD2 A2 00		        ldx #0
  2335 2FD4			dm_loop
  2336 2FD4 8E 46 06		        stx s_kc
  2337 2FD7 BD 14 06		        lda voice_level,x
  2338 2FDA DD AD 06		        cmp prev_vmeter,x
  2339 2FDD F0 69		        beq dm_next
  2340 2FDF BC AD 06		        ldy prev_vmeter,x       ; old level
  2341 2FE2 8C 0D 06		        sty tmp2
  2342 2FE5 9D AD 06		        sta prev_vmeter,x       ; store new
  2343 2FE8 CD 0D 06		        cmp tmp2                ; new - old
  2344 2FEB B0 14		        bcs dm_rise
  2345 2FED A9 FF		        lda #$FF                ; level fell -> CLEAR from new to old
  2346 2FEF 8D 61 06		        sta pmode
  2347 2FF2 AD 0D 06		        lda tmp2
  2348 2FF5 8D B2 06		        sta dm_hi               ; hi = old
  2349 2FF8 BD AD 06		        lda prev_vmeter,x
  2350 2FFB 8D B1 06		        sta dm_lo               ; lo = new
  2351 2FFE 4C 12 30		        jmp dm_calc
  2352 3001			dm_rise
  2353 3001 A9 00		        lda #0                  ; level rose -> SET from old to new
  2354 3003 8D 61 06		        sta pmode
  2355 3006 AD 0D 06		        lda tmp2
  2356 3009 8D B1 06		        sta dm_lo               ; lo = old
  2357 300C BD AD 06		        lda prev_vmeter,x
  2358 300F 8D B2 06		        sta dm_hi               ; hi = new
  2359 3012			dm_calc
  2360 3012 AE 46 06		        ldx s_kc
  2361 3015 AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2362 3018 0A			        asl
  2363 3019 18			        clc
  2364 301A 6D B1 06		        adc dm_lo
  2365 301D 18			        clc
  2366 301E 7D 56 30		        adc met_x,x
  2367 3021 8D 40 06		        sta xlo
  2368 3024 A9 00		        lda #0
  2369 3026 8D 41 06		        sta xhi
  2370 3029 AD B2 06		        lda dm_hi               ; rw = (hi - lo)*3
  2371 302C 38			        sec
