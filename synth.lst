   496 21FB F0 03		        beq rc_nosel
   497 21FD 20 D0 22		        jsr seq_toggle_rec
   498 2200			rc_nosel
   499 2200 AD AB 06		        lda con_now
   500 2203 8D AC 06		        sta con_prev
   501 2206 60			        rts
