   711 2309			seq_toggle_play
   712 2309 AD A1 06		        lda seq_play
   713 230C 49 01		        eor #1
   714 230E 8D A1 06		        sta seq_play
   715 2311 F0 0A		        beq stp_done            ; just stopped
   716 2313 A9 00		        lda #0                  ; just started: from step 0, fire soon
   717 2315 8D A3 06		        sta seq_pos
   718 2318 A9 01		        lda #1
   719 231A 8D A5 06		        sta seq_timer
   720 231D			stp_done
   721 231D 60			        rts
   722
   723 				; SELECT = real-time record: arming clears the pattern and STARTS the clock so
   724 				; you just play in time (the live note is captured on the step under the head).
   725 				; Disarming punches out but keeps the loop playing. To step-enter instead, stop
   726 				; the clock (START) while still armed -> rec + stopped writes one step per key.
   727 231E			seq_toggle_rec
   728 231E AD A2 06		        lda seq_rec
   729 2321 49 01		        eor #1
   730 2323 8D A2 06		        sta seq_rec
   731 2326 F0 2F		        beq str_done            ; just disarmed -> punch out, keep playing
   732 2328 A2 0F		        ldx #15                 ; arm: clear the pattern
   733 232A A9 FF		        lda #$FF
   734 232C			str_clr
   735 232C 9D 91 06		        sta seq_notes,x
   736 232F CA			        dex
   737 2330 10 FA		        bpl str_clr
   738 2332 A9 00		        lda #0
   739 2334 8D A4 06		        sta seq_wpos
   740 2337 8D B3 06		        sta seq_len             ; (step entry grows this; real-time loops 16)
   741 233A 8D A3 06		        sta seq_pos             ; record from step 0
   742 233D A9 FF		        lda #$FF
   743 233F 8D B4 06		        sta rec_latch
   744 2342 A9 01		        lda #1
   745 2344 8D AA 06		        sta seq_dirty
   746 2347 8D A1 06		        sta seq_play            ; run the clock -> real-time record
   747 234A A9 10		        lda #16                 ; one full step of lead-in so step 0 is playable
   748 234C 38			        sec
   749 234D ED 8C 06		        sbc tempo
   750 2350 0A			        asl
   751 2351 18			        clc
   752 2352 69 02		        adc #2
   753 2354 8D A5 06		        sta seq_timer
   754 2357			str_done
   755 2357 60			        rts
