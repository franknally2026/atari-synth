   466 				; Console keys (CONSOL $D01F, active low): OPTION (bit2) = sustain pedal (level),
   467 				; START (bit0) = play/stop, SELECT (bit1) = record arm (edge-triggered).
   468 				; Independent of the scanned key matrix, so they work while a note key is down.
   469 21CD			read_console
   470 21CD AD 1F D0		        lda CONSOL
   471 21D0 49 07		        eor #$07                ; now 1 = pressed
   472 21D2 29 07		        and #$07
   473 21D4 8D AB 06		        sta con_now
   474 21D7 29 04		        and #$04                ; OPTION -> sustain pedal (level)
   475 21D9 F0 04		        beq rc_noopt
   476 21DB A9 01		        lda #1
   477 21DD D0 02		        bne rc_setopt
   478 21DF			rc_noopt
   479 21DF A9 00		        lda #0
   480 21E1			rc_setopt
   481 21E1 8D 87 06		        sta sustain_ped
   482 21E4 AD AC 06		        lda con_prev            ; edges = now & ~prev
   483 21E7 49 FF		        eor #$FF
   484 21E9 2D AB 06		        and con_now
   485 21EC 8D 0C 06		        sta tmpA
   486 21EF 29 01		        and #$01                ; START edge -> toggle play
   487 21F1 F0 03		        beq rc_nostart
   488 21F3 20 BB 22		        jsr seq_toggle_play
   489 21F6			rc_nostart
   490 21F6 AD 0C 06		        lda tmpA
