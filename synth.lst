   612 22BB			seq_toggle_play
   613 22BB AD A1 06		        lda seq_play
   614 22BE 49 01		        eor #1
   615 22C0 8D A1 06		        sta seq_play
   616 22C3 F0 0A		        beq stp_done            ; just stopped
   617 22C5 A9 00		        lda #0                  ; just started: from step 0, fire soon
   618 22C7 8D A3 06		        sta seq_pos
   619 22CA A9 01		        lda #1
   620 22CC 8D A5 06		        sta seq_timer
   621 22CF			stp_done
