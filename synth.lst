mads 2.1.8
synth.asm -o:synth.xex -l:synth.lst 
Source: synth.asm
     1 				; ============================================================================
     2 				;  ATARI POKEY SYNTH  -  GR.8 bitmap UI
     3 				;  Keyboard-playable 4-voice POKEY synth with an ADSR envelope and a drawn
     4 				;  control panel (knobs + switches up top, a piano keyboard along the bottom).
     5 				;
     6 				;  Play:   white keys Q W E R T Y U I O P  (naturals C D E F G A B C D E)
     7 				;          black keys 2 3 5 6 7 9 0         (sharps  C# D# F# G# A# C# D#)
     8 				;  Panel:  joystick UP/DOWN selects a parameter, LEFT/RIGHT adjusts it.
     9 				;
    10 				;  Video:  GR.8 (ANTIC mode $0F), 320x192, 1bpp, custom display list.
    11 				;  Target: PAL Atari XL/XE.  Assemble with MADS.
    12 				; ============================================================================
    13
    14 				; ----- OS / hardware equates ------------------------------------------------
    15 = 0012			RTCLOK  = $12           ; frame counter; +2 ($14) ticks every VBI
    16 = 004D			ATRACT  = $4D           ; attract-mode timer (clear to suppress colour cycling)
    17 = 02F0			CRSINH  = $02F0         ; cursor inhibit
    18 = 02DB			NOCLIK  = $02DB         ; key-click disable
    19 = 0278			STICK0  = $0278         ; OS joystick-0 shadow, active low
    20 = D010			STRIG0  = $D010         ; joystick-0 trigger (fire), 0 = pressed
    21 = 0230			SDLSTL  = $0230         ; OS display-list pointer (shadow)
    22 = 022F			SDMCTL  = $022F         ; OS DMACTL shadow
    23 = 02C5			COLOR1  = $02C5         ; COLPF1 shadow (hi-res foreground luminance)
    24 = 02C6			COLOR2  = $02C6         ; COLPF2 shadow (background)
    25 = 02C8			COLOR4  = $02C8         ; COLBK shadow (border); OS VBI copies it to $D01A each frame
    26
    27 = D01F			CONSOL  = $D01F         ; console keys START/SELECT/OPTION (read, active low)
    28 = D209			KBCODE  = $D209         ; raw keyboard scan code
    29 = D20F			SKSTAT  = $D20F         ; serial/keyboard status (read)
    30 = D20F			SKCTL   = $D20F         ; serial/keyboard control (write)
    31 = D20A			SKRES   = $D20A         ; write (any value) clears SKSTAT serial/keyboard status latches
    32 = D20E			IRQEN   = $D20E         ; POKEY IRQ enable (write); shadow = POKMSK
    33 = 0010			POKMSK  = $0010         ; OS shadow of IRQEN (the OS IRQ handler reads this)
    34 = D200			AUDF1   = $D200         ; channel-1 frequency divisor
    35 = D201			AUDC1   = $D201         ; channel-1 control (distortion | volume)
    36 = D208			AUDCTL  = $D208         ; POKEY global audio control
    37
    38 = E000			ROMFONT = $E000         ; OS ROM character set (8 bytes/glyph, screen-code index)
    39 				; DEMO: DLI colour-band hardware registers
    40 = D40A			WSYNC   = $D40A         ; wait for horizontal sync (write)
    41 = D018			COLPF2  = $D018         ; playfield-2 colour (hi-res: hue of fg + bg)
    42 = D40E			NMIEN   = $D40E         ; NMI enable (bit7 = DLI, bit6 = VBI)
    43 = 0200			VDSLST  = $0200         ; DLI vector
    44 = 4000			FB1     = $4000         ; framebuffer region 1 (scan lines 0..101)
    45 = 5000			FB2     = $5000         ; framebuffer region 2 (scan lines 102..191)
    46 = 6000			linetab_lo = $6000      ; 192 bytes: low byte of each scan line's address
    47 = 60C0			linetab_hi = $60C0      ; 192 bytes: high byte
    48 				                        ; NOTE: kept ABOVE the framebuffers ($4000-$5E0F) and clear
    49 				                        ; of the program/descriptor tables ($2000-$3D59). The old
    50 				                        ; $3000 scratch collided with the param_*/p_* tables once the
    51 				                        ; code grew past $3000 (build_linetab clobbered the label
    52 				                        ; pointers -> draw_page_labels looped forever). Don't move it
    53 				                        ; back into program space.
    54
    55 = 0084			KBTOP   = 132           ; piano keyboard top scan line (shifted down 8 from 124 to
    56 				                        ; open a hint-line row at HINTSCAN; uses the slack below
    57 				                        ; the keyboard, so the keys stay full size)
    58 = 007C			HINTSCAN = 124          ; context-sensitive hint line, just above the keyboard
    59
    60 				; ----- zero-page pointers (free OS scratch $CB-$D1) -------------------------
    61 = 00CB			scrptr  = $CB           ; word: general dest pointer
    62 = 00CD			srcptr  = $CD           ; word: source (font / table / string)
    63 = 00CF			adjptr  = $CF           ; word: blit dest line / apply_adjust target
    64
    65 				; ----- work variables (free RAM, page 6) ------------------------------------
    66 = 0600			cur_param   = $0600     ; selected panel parameter 0..7
    67 = 0601			wave_idx    = $0601     ; 0..3  -> SQUARE/PURE/BUZZ/NOISE
    68 = 0602			volume      = $0602     ; 0..15 (envelope peak)
    69 = 0603			octave      = $0603     ; 0..4  (centre 2 = +0)
    70 = 0604			clock15     = $0604     ; clock/range mode: 0 NORMAL, 1 15KHZ, 2 16-BIT
    71 = 0605			prev_pressed= $0605
    72 = 0606			rep_timer   = $0606
    73 = 0607			note_idx    = $0607     ; current note 0..16, or $FF = none
    74 = 0608			prev_note   = $0608     ; last highlighted note
    75 = 0609			pressed     = $0609
    76 = 060A			edge        = $060A
    77 = 060B			delta       = $060B
    78 = 060C			tmpA        = $060C
    79 = 060D			tmp2        = $060D
    80 = 060E			cnt         = $060E
    81
