   398 				; ============================================================================
   399 				;  ENGINE  (unchanged from the text-mode version)
   400 				; ============================================================================
   401 2192			read_keyboard
   402 2192 AD 0F D2		        lda SKSTAT
   403 2195 29 04		        and #$04
   404 2197 D0 13		        bne rk_none
   405 2199 AD 09 D2		        lda KBCODE
   406 219C 29 3F		        and #$3F
   407 219E A2 10		        ldx #NUMKEYS-1
   408 21A0			rk_search
   409 21A0 DD AD 33		        cmp key_scan,x
   410 21A3 F0 13		        beq rk_found
   411 21A5 CA			        dex
   412 21A6 10 F8		        bpl rk_search
   413 21A8 C9 1F		        cmp #$1F                ; not a pitched key: '1' = the DRUM trigger key
   414 21AA F0 06		        beq rk_drum
