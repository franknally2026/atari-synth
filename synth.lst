   763 				; Unified directional input: up/down navigate, left/right adjust. ALL FOUR now
   764 				; auto-repeat off one rep_timer (was: U/D edge-only, L/R repeated). Arrow keys are
   765 				; merged in via kbd_dir (read_navkeys) so they drive the exact same path.
   766 23DF			update_input
   767 23DF AD 78 02		        lda STICK0
   768 23E2 29 0F		        and #$0F
   769 23E4 49 0F		        eor #$0F                ; bit0=up bit1=down bit2=left bit3=right (active high)
   770 23E6 0D CE 06		        ora kbd_dir             ; merge arrow keys -> identical nav/adjust/repeat
   771 23E9 8D 09 06		        sta pressed
   772 23EC AD 05 06		        lda prev_pressed
   773 23EF 49 FF		        eor #$FF
   774 23F1 2D 09 06		        and pressed
   775 23F4 8D 0A 06		        sta edge                ; freshly-pressed directions this frame
   776 23F7 AD 09 06		        lda pressed
   777 23FA 29 0F		        and #$0F
   778 23FC D0 08		        bne ui_held
   779 23FE A9 0F		        lda #REPDELAY           ; nothing held -> re-arm the initial delay
   780 2400 8D 06 06		        sta rep_timer
   781 2403 4C 67 24		        jmp ui_done
   782 2406			ui_held
   783 2406 AD 0A 06		        lda edge
   784 2409 29 0F		        and #$0F
   785 240B D0 0D		        bne ui_fresh            ; a fresh press -> act immediately
   786 240D CE 06 06		        dec rep_timer
   787 2410 D0 55		        bne ui_done             ; still counting down -> no action this frame
   788 2412 A9 04		        lda #REPFAST            ; timer expired -> repeat at the fast rate
   789 2414 8D 06 06		        sta rep_timer
   790 2417 4C 1F 24		        jmp ui_act
   791 241A			ui_fresh
   792 241A A9 0F		        lda #REPDELAY
   793 241C 8D 06 06		        sta rep_timer
   794 241F			ui_act
   795 241F AD 09 06		        lda pressed             ; UP -> previous param (wrap)
   796 2422 29 01		        and #$01
   797 2424 F0 0A		        beq ui_a_nodn
   798 2426 CE 00 06		        dec cur_param
   799 2429 10 05		        bpl ui_a_nodn
   800 242B A9 12		        lda #NPARAM-1
   801 242D 8D 00 06		        sta cur_param
   802 2430			ui_a_nodn
   803 2430 AD 09 06		        lda pressed             ; DOWN -> next param (wrap)
   804 2433 29 02		        and #$02
   805 2435 F0 0F		        beq ui_a_nolr
   806 2437 EE 00 06		        inc cur_param
   807 243A AD 00 06		        lda cur_param
   808 243D C9 13		        cmp #NPARAM
   809 243F D0 05		        bne ui_a_nolr
   810 2441 A9 00		        lda #0
   811 2443 8D 00 06		        sta cur_param
   812 2446			ui_a_nolr
   813 2446 AD 09 06		        lda pressed             ; LEFT -> value -1
   814 2449 29 04		        and #$04
   815 244B F0 0B		        beq ui_a_tryr
   816 244D A9 FF		        lda #$FF
   817 244F 8D 0B 06		        sta delta
   818 2452 20 6E 24		        jsr apply_adjust
   819 2455 4C 67 24		        jmp ui_done
   820 2458			ui_a_tryr
   821 2458 AD 09 06		        lda pressed             ; RIGHT -> value +1
   822 245B 29 08		        and #$08
   823 245D F0 08		        beq ui_done
   824 245F A9 01		        lda #$01
   825 2461 8D 0B 06		        sta delta
   826 2464 20 6E 24		        jsr apply_adjust
   827 2467			ui_done
   828 2467 AD 09 06		        lda pressed
   829 246A 8D 05 06		        sta prev_pressed
   830 246D 60			        rts
