   769 				; Unified directional input: up/down navigate, left/right adjust. ALL FOUR now
   770 				; auto-repeat off one rep_timer (was: U/D edge-only, L/R repeated). Arrow keys are
   771 				; merged in via kbd_dir (read_navkeys) so they drive the exact same path.
   772 23EA			update_input
   773 23EA AD 78 02		        lda STICK0
   774 23ED 29 0F		        and #$0F
   775 23EF 49 0F		        eor #$0F                ; bit0=up bit1=down bit2=left bit3=right (active high)
   776 23F1 0D CE 06		        ora kbd_dir             ; merge arrow keys -> identical nav/adjust/repeat
   777 23F4 8D 09 06		        sta pressed
   778 23F7 AD 05 06		        lda prev_pressed
   779 23FA 49 FF		        eor #$FF
   780 23FC 2D 09 06		        and pressed
   781 23FF 8D 0A 06		        sta edge                ; freshly-pressed directions this frame
   782 2402 AD 09 06		        lda pressed
   783 2405 29 0F		        and #$0F
   784 2407 D0 08		        bne ui_held
   785 2409 A9 0F		        lda #REPDELAY           ; nothing held -> re-arm the initial delay
   786 240B 8D 06 06		        sta rep_timer
   787 240E 4C 72 24		        jmp ui_done
   788 2411			ui_held
   789 2411 AD 0A 06		        lda edge
   790 2414 29 0F		        and #$0F
   791 2416 D0 0D		        bne ui_fresh            ; a fresh press -> act immediately
   792 2418 CE 06 06		        dec rep_timer
   793 241B D0 55		        bne ui_done             ; still counting down -> no action this frame
   794 241D A9 04		        lda #REPFAST            ; timer expired -> repeat at the fast rate
   795 241F 8D 06 06		        sta rep_timer
   796 2422 4C 2A 24		        jmp ui_act
   797 2425			ui_fresh
   798 2425 A9 0F		        lda #REPDELAY
   799 2427 8D 06 06		        sta rep_timer
   800 242A			ui_act
   801 242A AD 09 06		        lda pressed             ; UP -> previous param (wrap)
   802 242D 29 01		        and #$01
   803 242F F0 0A		        beq ui_a_nodn
   804 2431 CE 00 06		        dec cur_param
   805 2434 10 05		        bpl ui_a_nodn
   806 2436 A9 12		        lda #NPARAM-1
   807 2438 8D 00 06		        sta cur_param
   808 243B			ui_a_nodn
   809 243B AD 09 06		        lda pressed             ; DOWN -> next param (wrap)
   810 243E 29 02		        and #$02
   811 2440 F0 0F		        beq ui_a_nolr
   812 2442 EE 00 06		        inc cur_param
   813 2445 AD 00 06		        lda cur_param
   814 2448 C9 13		        cmp #NPARAM
   815 244A D0 05		        bne ui_a_nolr
   816 244C A9 00		        lda #0
   817 244E 8D 00 06		        sta cur_param
   818 2451			ui_a_nolr
   819 2451 AD 09 06		        lda pressed             ; LEFT -> value -1
   820 2454 29 04		        and #$04
   821 2456 F0 0B		        beq ui_a_tryr
   822 2458 A9 FF		        lda #$FF
   823 245A 8D 0B 06		        sta delta
   824 245D 20 79 24		        jsr apply_adjust
   825 2460 4C 72 24		        jmp ui_done
   826 2463			ui_a_tryr
   827 2463 AD 09 06		        lda pressed             ; RIGHT -> value +1
   828 2466 29 08		        and #$08
   829 2468 F0 08		        beq ui_done
   830 246A A9 01		        lda #$01
   831 246C 8D 0B 06		        sta delta
   832 246F 20 79 24		        jsr apply_adjust
   833 2472			ui_done
   834 2472 AD 09 06		        lda pressed
   835 2475 8D 05 06		        sta prev_pressed
   836 2478 60			        rts
