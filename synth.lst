   990 				; ----------------------------------------------------------------------------
   991 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
   992 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
   993 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
   994 				;  high channel). drum_tick runs after update_sound and overrides channel 4
   995 				;  while a hit rings; when it ends, voice 3's normal output resumes.
   996 				; ----------------------------------------------------------------------------
   997 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
   998 2595			drum_hit
   999 2595 AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
  1000 2598 F0 12		        beq dh_off
  1001 259A AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
  1002 259D C9 02		        cmp #2
  1003 259F F0 0B		        beq dh_off
  1004 25A1 A9 0F		        lda #15
  1005 25A3 8D BE 06		        sta drum_level
  1006 25A6 AD BD 06		        lda drum_dec            ; full level held for one decay interval first
  1007 25A9 8D BF 06		        sta drum_timer
  1008 25AC			dh_off
  1009 25AC 60			        rts
  1010 25AD			drum_tick
  1011 25AD AD BE 06		        lda drum_level
