   608 22BB			seq_toggle_play
   609 22BB AD A1 06		        lda seq_play
   610 22BE 49 01		        eor #1
   611 22C0 8D A1 06		        sta seq_play
   612 22C3 F0 0A		        beq stp_done            ; just stopped
   613 22C5 A9 00		        lda #0                  ; just started: from step 0, fire soon
   614 22C7 8D A3 06		        sta seq_pos
   615 22CA A9 01		        lda #1
   616 22CC 8D A5 06		        sta seq_timer
   617 22CF			stp_done
   618 22CF 60			        rts
   619
   620 				; SELECT = real-time record: arming clears the pattern and STARTS the clock so
   621 				; you just play in time (the live note is captured on the step under the head).
   622 				; Disarming punches out but keeps the loop playing. To step-enter instead, stop
   623 				; the clock (START) while still armed -> rec + stopped writes one step per key.
   624 22D0			seq_toggle_rec
   625 22D0 AD A2 06		        lda seq_rec
   626 22D3 49 01		        eor #1
   627 22D5 8D A2 06		        sta seq_rec
   628 22D8 F0 2F		        beq str_done            ; just disarmed -> punch out, keep playing
   629 22DA A2 0F		        ldx #15                 ; arm: clear the pattern
   630 22DC A9 FF		        lda #$FF
   631 22DE			str_clr
   632 22DE 9D 91 06		        sta seq_notes,x
   633 22E1 CA			        dex
   634 22E2 10 FA		        bpl str_clr
   635 22E4 A9 00		        lda #0
   636 22E6 8D A4 06		        sta seq_wpos
   637 22E9 8D B3 06		        sta seq_len             ; (step entry grows this; real-time loops 16)
   638 22EC 8D A3 06		        sta seq_pos             ; record from step 0
   639 22EF A9 FF		        lda #$FF
   640 22F1 8D B4 06		        sta rec_latch
   641 22F4 A9 01		        lda #1
   642 22F6 8D AA 06		        sta seq_dirty
   643 22F9 8D A1 06		        sta seq_play            ; run the clock -> real-time record
   644 22FC A9 10		        lda #16                 ; one full step of lead-in so step 0 is playable
   645 22FE 38			        sec
   646 22FF ED 8C 06		        sbc tempo
   647 2302 0A			        asl
   648 2303 18			        clc
   649 2304 69 02		        adc #2
   650 2306 8D A5 06		        sta seq_timer
   651 2309			str_done
   652 2309 60			        rts
