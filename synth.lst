   507 21C2			read_keyboard
   508 21C2 AD 0F D2		        lda SKSTAT
   509 21C5 29 04		        and #$04
   510 21C7 D0 17		        bne rk_none
   511 21C9 AD 09 D2		        lda KBCODE
   512 21CC C9 40		        cmp #$40                ; bit6 (Ctrl = arrows) or bit7 (Shift = shortcuts) set
   513 21CE B0 10		        bcs rk_none             ; -> a nav/shortcut key, never a piano note. Without
   514 				                                ; this, masking #$3F collapsed e.g. Shift+W ($AE) onto
   515 				                                ; W's note ($2E) and blipped a note on every shortcut.
   516 21D0 29 3F		        and #$3F
   517 21D2 A2 10		        ldx #NUMKEYS-1
   518 21D4			rk_search
   519 21D4 DD 50 37		        cmp key_scan,x
   520 21D7 F0 13		        beq rk_found
   521 21D9 CA			        dex
   522 21DA 10 F8		        bpl rk_search
   523 21DC C9 1F		        cmp #$1F                ; not a pitched key: '1' = the DRUM trigger key
   524 21DE F0 06		        beq rk_drum
