   504 				; Navigation keys (laptop play, no joystick needed). The Atari arrow keys are
   505 				; Ctrl + the -/=/+/* keys; Ctrl sets KBCODE bit6 ($40), so they read UNMASKED as
   506 				; $4E/$4F/$46/$47 (read_keyboard masks #$3F for the note matrix and ignores
   507 				; these). Arrows set kbd_dir level bits -> update_input gives them the same
   508 				; nav/adjust/auto-repeat as the joystick. Tab/Return are edge-triggered via nav_prev.
   509 				;   Up=$4E Down=$4F Left=$46 Right=$47   Tab=$2C (page flip)   Return=$0C (save)
   510 2207			read_navkeys
   511 2207 A9 00		        lda #0
   512 2209 8D CE 06		        sta kbd_dir
   513 220C AD 0F D2		        lda SKSTAT
   514 220F 29 04		        and #$04
   515 2211 D0 74		        bne rn_none             ; no key down
   516 2213 AD 09 D2		        lda KBCODE
   517 2216 C9 4E		        cmp #$4E                ; UP    (Ctrl+MINUS)
   518 2218 D0 08		        bne rn_n1
   519 221A A9 01		        lda #$01
   520 221C 8D CE 06		        sta kbd_dir
   521 221F 4C 80 22		        jmp rn_seen
   522 2222			rn_n1
   523 2222 C9 4F		        cmp #$4F                ; DOWN  (Ctrl+EQUALS)
   524 2224 D0 08		        bne rn_n2
   525 2226 A9 02		        lda #$02
   526 2228 8D CE 06		        sta kbd_dir
   527 222B 4C 80 22		        jmp rn_seen
   528 222E			rn_n2
   529 222E C9 46		        cmp #$46                ; LEFT  (Ctrl+PLUS)
   530 2230 D0 08		        bne rn_n3
   531 2232 A9 04		        lda #$04
   532 2234 8D CE 06		        sta kbd_dir
   533 2237 4C 80 22		        jmp rn_seen
   534 223A			rn_n3
   535 223A C9 47		        cmp #$47                ; RIGHT (Ctrl+ASTERISK)
   536 223C D0 08		        bne rn_n4
   537 223E A9 08		        lda #$08
   538 2240 8D CE 06		        sta kbd_dir
   539 2243 4C 80 22		        jmp rn_seen
   540 2246			rn_n4
   541 2246 C9 2C		        cmp #$2C                ; Tab -> cycle page (edge only, no repeat)
   542 2248 D0 0D		        bne rn_n5
   543 224A AE CF 06		        ldx nav_prev
   544 224D E0 2C		        cpx #$2C
   545 224F F0 2F		        beq rn_seen
   546 2251 20 8D 22		        jsr page_flip
   547 2254 4C 80 22		        jmp rn_seen
   548 2257			rn_n5
   549 2257 C9 0C		        cmp #$0C                ; Return -> save preset (joystick-fire substitute)
   550 2259 D0 0D		        bne rn_short
   551 225B AE CF 06		        ldx nav_prev
   552 225E E0 0C		        cpx #$0C
   553 2260 F0 1E		        beq rn_seen
   554 2262 20 AA 22		        jsr nav_save_preset
   555 2265 4C 80 22		        jmp rn_seen
   556 2268			rn_short
   557 				        ; letter shortcut: a free letter that's underlined in a param's label jumps
   558 				        ; the selection straight to that param (A still holds raw KBCODE here). Only
   559 				        ; the 6 params whose letter is UNIQUE have an entry (see shortcut_kc).
   560 2268 A2 12		        ldx #NSHORT-1
   561 226A			rn_short_l
   562 226A DD 2A 38		        cmp shortcut_kc,x
   563 226D F0 06		        beq rn_short_hit
   564 226F CA			        dex
   565 2270 10 F8		        bpl rn_short_l
   566 2272 4C 80 22		        jmp rn_seen             ; not a shortcut key
   567 2275			rn_short_hit
   568 2275 CD CF 06		        cmp nav_prev            ; A = this key = shortcut_kc[x]; held -> no re-jump
   569 2278 F0 06		        beq rn_seen
   570 227A BD 3D 38		        lda shortcut_param,x    ; jump (cur_param drives the page too)
   571 227D 8D 00 06		        sta cur_param
   572 2280			rn_seen
   573 2280 AD 09 D2		        lda KBCODE              ; remember this frame's key for next-frame edge detect
   574 2283 8D CF 06		        sta nav_prev
   575 2286 60			        rts
   576 2287			rn_none
   577 2287 A9 FF		        lda #$FF
   578 2289 8D CF 06		        sta nav_prev
   579 228C 60			        rts
