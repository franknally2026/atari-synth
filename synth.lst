   844 24C5 C9 02		        cmp #2
   845 24C7 F0 0B		        beq dh_off
   846 24C9 A9 0F		        lda #15
   847 24CB 8D BE 06		        sta drum_level
   848 24CE AD BD 06		        lda drum_dec            ; full level held for one decay interval first
   849 24D1 8D BF 06		        sta drum_timer
