  2447 308E 8D 61 06		        sta pmode
  2448 3091 AD 0D 06		        lda tmp2
  2449 3094 8D B1 06		        sta dm_lo               ; lo = old
  2450 3097 BD AD 06		        lda prev_vmeter,x
