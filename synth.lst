  1009 				; ----------------------------------------------------------------------------
  1010 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
  1011 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
  1012 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
  1013 				;  high channel). drum_tick runs after update_sound and overrides channel 4
  1014 				;  while a hit rings; when it ends, voice 3's normal output resumes.
  1015 				; ----------------------------------------------------------------------------
  1016 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
  1017 25B2			drum_hit
  1018 25B2 AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
  1019 25B5 F0 12		        beq dh_off
  1020 25B7 AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
  1021 25BA C9 02		        cmp #2
  1022 25BC F0 0B		        beq dh_off
  1023 25BE A9 0F		        lda #15
  1024 25C0 8D BE 06		        sta drum_level
  1025 25C3 AD BD 06		        lda drum_dec            ; full level held for one decay interval first
  1026 25C6 8D BF 06		        sta drum_timer
  1027 25C9			dh_off
  1028 25C9 60			        rts
  1029 25CA			drum_tick
  1030 25CA AD BE 06		        lda drum_level
  1031 25CD D0 01		        bne dt_active
  1032 25CF 60			        rts                     ; idle -> leave channel 4 to voice 3
  1033 25D0			dt_active
  1034 25D0 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1035 25D3 F0 07		        beq dt_kill
  1036 25D5 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1037 25D8 C9 02		        cmp #2
  1038 25DA D0 06		        bne dt_decay
  1039 25DC			dt_kill
  1040 25DC A9 00		        lda #0
  1041 25DE 8D BE 06		        sta drum_level
  1042 25E1 60			        rts
  1043 25E2			dt_decay
  1044 25E2 CE BF 06		        dec drum_timer
  1045 25E5 D0 09		        bne dt_emit
  1046 25E7 AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1047 25EA 8D BF 06		        sta drum_timer
  1048 25ED CE BE 06		        dec drum_level
  1049 25F0			dt_emit
  1050 25F0 A9 1E		        lda #DRUM_AUDF
  1051 25F2 8D 06 D2		        sta AUDF1+6             ; channel 4 frequency
  1052 25F5 AD BE 06		        lda drum_level          ; AUDC = distortion 0 (white-ish noise) | level
  1053 25F8 8D 07 D2		        sta AUDC1+6
  1054 25FB 60			        rts
