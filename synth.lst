   926 				; ----------------------------------------------------------------------------
   927 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
   928 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
   929 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
   930 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
   931 				;  address, so save/load just walk those tables.
   932 				; ----------------------------------------------------------------------------
   933 254F			preset_tick
   934 254F AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
   935 2552 49 01		        eor #$01
   936 2554 29 01		        and #$01
   937 2556 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
   938 				                                ; which only touches tmp2 — NOT tmpA)
   939 2559 AE 00 06		        ldx cur_param
   940 255C E0 11		        cpx #17                 ; PRESET param selected?
   941 255E D0 13		        bne pt_load
   942 2560 AD 0C 06		        lda tmpA
   943 2563 F0 0E		        beq pt_load
   944 2565 AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
   945 2568 D0 09		        bne pt_load
   946 256A 20 97 25		        jsr preset_save
   947 256D AD C5 06		        lda preset_slot         ; keep prev in sync so we don't reload after save
   948 2570 8D C6 06		        sta prev_preset
   949 2573			pt_load
   950 2573 AD 0C 06		        lda tmpA                ; remember fire state for next-frame edge detect
   951 2576 8D C7 06		        sta preset_fp
   952 2579 AD C5 06		        lda preset_slot         ; selection changed -> load that slot
   953 257C CD C6 06		        cmp prev_preset
   954 257F F0 06		        beq pt_done
   955 2581 8D C6 06		        sta prev_preset
   956 2584 20 B9 25		        jsr preset_load
   957 2587			pt_done
   958 2587 60			        rts
   959
   960 				; bank offset of the current slot (slot * NSAVE) -> tmp2
