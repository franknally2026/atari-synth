   380 2164 CA			        dex                     ; for the new vlimit after a mode change)
   381 2165 8E 19 06		        stx last_voice
   382 2168			lp_same
   383 2168 20 92 21		        jsr read_keyboard
   384 216B 20 BC 21		        jsr read_console
   385 216E 20 CF 23		        jsr trigger_voices
   386 2171 20 07 25		        jsr drum_key_tick       ; '1' key -> live drum hit (edge)
   387 2174 20 1A 23		        jsr update_input
   388 2177 20 4F 25		        jsr preset_tick         ; PRESET knob -> load; fire on PRESET -> save
   389 217A 20 4A 28		        jsr lfo_tick
   390 217D 20 50 24		        jsr arp_tick
   391 2180 20 45 22		        jsr seq_tick
   392 2183 20 22 25		        jsr drum_beat_tick      ; DRUMBEAT -> auto drum-machine pulse (tempo-synced)
   393 2186 20 1F 26		        jsr update_sound
   394 2189 20 D5 24		        jsr drum_tick           ; drum overrides channel 4 while a hit rings
   395 218C 20 F9 2C		        jsr update_display
   396 218F 4C 2F 21		        jmp loop
