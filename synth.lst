  1127 266B 8D C7 06		        sta preset_fp
  1128 266E AD C5 06		        lda preset_slot         ; selection changed -> load that slot
  1129 2671 CD C6 06		        cmp prev_preset
  1130 2674 F0 06		        beq pt_done
  1131 2676 8D C6 06		        sta prev_preset
  1132 2679 20 B8 26		        jsr preset_load
  1133 267C			pt_done
  1134 267C 60			        rts
  1135
  1136 				; bank offset of the current slot (slot * NSAVE) -> tmp2
