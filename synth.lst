   230 = 0010			PG2BASE = 16            ; first param index on page 2 (the third page)
   231 = 000C			PER_PAGE = 12
   232 = 0000			K_KNOB = 0              ; 0..15 value -> knob + 2-digit number
   233 = 0001			K_OCT  = 1              ; octave (0..4) -> knob + signed number
   234 = 0002			K_WAVE = 2              ; waveform icon selector
   235 = 0003			K_CLK  = 3              ; NORM|15K toggle
