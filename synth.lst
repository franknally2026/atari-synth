  1437 				; ----------------------------------------------------------------------------
  1438 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1439 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1440 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1441 				; ----------------------------------------------------------------------------
  1442 291C			lfo_tick
  1443 291C AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1444 291F D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1445 2921 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1446 2924 8D 65 06		        sta lfo_level_u
  1447 2927 60			        rts
  1448 2928			lt_on
  1449 2928 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1450 2929 8D 69 06		        sta lfo_max
  1451 292C CE 67 06		        dec lfo_count
  1452 292F F0 01		        beq lt_step
  1453 2931 60			        rts
  1454 2932			lt_step
  1455 2932 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1456 2934 38			        sec
  1457 2935 ED 63 06		        sbc lfo_rate
  1458 2938 8D 67 06		        sta lfo_count
  1459 293B AD 69 06		        lda lfo_max
  1460 293E 0A			        asl
  1461 293F 8D 6A 06		        sta lfo_max2            ; 2*max
  1462 2942 AD 66 06		        lda lfo_dir
  1463 2945 30 19		        bmi lt_down
  1464 2947 EE 65 06		        inc lfo_level_u         ; ramp up
  1465 294A AD 65 06		        lda lfo_level_u
  1466 294D CD 6A 06		        cmp lfo_max2
  1467 2950 90 1E		        bcc lt_offset
  1468 2952 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1469 2955 8D 65 06		        sta lfo_level_u
  1470 2958 A9 FF		        lda #$FF
  1471 295A 8D 66 06		        sta lfo_dir
  1472 295D 4C 70 29		        jmp lt_offset
  1473 2960			lt_down
  1474 2960 AD 65 06		        lda lfo_level_u
  1475 2963 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1476 2965 CE 65 06		        dec lfo_level_u
  1477 2968 4C 70 29		        jmp lt_offset
  1478 296B			lt_rev_up
  1479 296B A9 01		        lda #1
  1480 296D 8D 66 06		        sta lfo_dir
  1481 2970			lt_offset
  1482 2970 AD 65 06		        lda lfo_level_u         ; offset = level - max  (signed)
  1483 2973 38			        sec
  1484 2974 ED 69 06		        sbc lfo_max
  1485 2977 8D 68 06		        sta lfo_offset
  1486 297A 60			        rts
