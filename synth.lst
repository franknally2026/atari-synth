  1518 				; ----------------------------------------------------------------------------
  1519 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1520 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1521 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1522 				; ----------------------------------------------------------------------------
  1523 299D			lfo_tick
  1524 299D AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1525 29A0 D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1526 29A2 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1527 29A5 8D 65 06		        sta lfo_level_u
  1528 29A8 60			        rts
  1529 29A9			lt_on
  1530 29A9 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1531 29AA 8D 69 06		        sta lfo_max
  1532 29AD CE 67 06		        dec lfo_count
  1533 29B0 F0 01		        beq lt_step
  1534 29B2 60			        rts
  1535 29B3			lt_step
  1536 29B3 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1537 29B5 38			        sec
  1538 29B6 ED 63 06		        sbc lfo_rate
  1539 29B9 8D 67 06		        sta lfo_count
  1540 29BC AD 69 06		        lda lfo_max
  1541 29BF 0A			        asl
  1542 29C0 8D 6A 06		        sta lfo_max2            ; 2*max
  1543 29C3 AD 66 06		        lda lfo_dir
  1544 29C6 30 19		        bmi lt_down
  1545 29C8 EE 65 06		        inc lfo_level_u         ; ramp up
  1546 29CB AD 65 06		        lda lfo_level_u
  1547 29CE CD 6A 06		        cmp lfo_max2
  1548 29D1 90 1E		        bcc lt_offset
  1549 29D3 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1550 29D6 8D 65 06		        sta lfo_level_u
  1551 29D9 A9 FF		        lda #$FF
  1552 29DB 8D 66 06		        sta lfo_dir
  1553 29DE 4C F1 29		        jmp lt_offset
  1554 29E1			lt_down
  1555 29E1 AD 65 06		        lda lfo_level_u
  1556 29E4 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1557 29E6 CE 65 06		        dec lfo_level_u
  1558 29E9 4C F1 29		        jmp lt_offset
