  2332 2FCF BC AD 06		        ldy prev_vmeter,x       ; old level
  2333 2FD2 8C 0D 06		        sty tmp2
  2334 2FD5 9D AD 06		        sta prev_vmeter,x       ; store new
  2335 2FD8 CD 0D 06		        cmp tmp2                ; new - old
  2336 2FDB B0 14		        bcs dm_rise
  2337 2FDD A9 FF		        lda #$FF                ; level fell -> CLEAR from new to old
  2338 2FDF 8D 61 06		        sta pmode
  2339 2FE2 AD 0D 06		        lda tmp2
  2340 2FE5 8D B2 06		        sta dm_hi               ; hi = old
  2341 2FE8 BD AD 06		        lda prev_vmeter,x
  2342 2FEB 8D B1 06		        sta dm_lo               ; lo = new
  2343 2FEE 4C 02 30		        jmp dm_calc
  2344 2FF1			dm_rise
  2345 2FF1 A9 00		        lda #0                  ; level rose -> SET from old to new
  2346 2FF3 8D 61 06		        sta pmode
  2347 2FF6 AD 0D 06		        lda tmp2
  2348 2FF9 8D B1 06		        sta dm_lo               ; lo = old
  2349 2FFC BD AD 06		        lda prev_vmeter,x
  2350 2FFF 8D B2 06		        sta dm_hi               ; hi = new
  2351 3002			dm_calc
  2352 3002 AE 46 06		        ldx s_kc
  2353 3005 AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2354 3008 0A			        asl
  2355 3009 18			        clc
  2356 300A 6D B1 06		        adc dm_lo
