  1623 29EE D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1624 29F0 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1625 29F3 8D 65 06		        sta lfo_level_u
  1626 29F6 60			        rts
  1627 29F7			lt_on
  1628 29F7 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1629 29F8 8D 69 06		        sta lfo_max
