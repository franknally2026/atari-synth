mads 2.1.7
Source: synth.asm
     1 				; ============================================================================
     2 				;  ATARI POKEY SYNTH  -  GR.8 bitmap UI
     3 				;  Keyboard-playable 4-voice POKEY synth with an ADSR envelope and a drawn
     4 				;  control panel (knobs + switches up top, a piano keyboard along the bottom).
     5 				;
     6 				;  Play:   white keys Q W E R T Y U I O P  (naturals C D E F G A B C D E)
     7 				;          black keys 2 3 5 6 7 9 0         (sharps  C# D# F# G# A# C# D#)
     8 				;  Panel:  joystick UP/DOWN selects a parameter, LEFT/RIGHT adjusts it.
     9 				;
    10 				;  Video:  GR.8 (ANTIC mode $0F), 320x192, 1bpp, custom display list.
    11 				;  Target: PAL Atari XL/XE.  Assemble with MADS.
    12 				; ============================================================================
    13
    14 				; ----- OS / hardware equates ------------------------------------------------
    15 = 0012			RTCLOK  = $12           ; frame counter; +2 ($14) ticks every VBI
    16 = 004D			ATRACT  = $4D           ; attract-mode timer (clear to suppress colour cycling)
    17 = 02F0			CRSINH  = $02F0         ; cursor inhibit
    18 = 02DB			NOCLIK  = $02DB         ; key-click disable
    19 = 0278			STICK0  = $0278         ; OS joystick-0 shadow, active low
    20 = D010			STRIG0  = $D010         ; joystick-0 trigger (fire), 0 = pressed
    21 = 0230			SDLSTL  = $0230         ; OS display-list pointer (shadow)
    22 = 022F			SDMCTL  = $022F         ; OS DMACTL shadow
    23 = 02C5			COLOR1  = $02C5         ; COLPF1 shadow (hi-res foreground luminance)
    24 = 02C6			COLOR2  = $02C6         ; COLPF2 shadow (background)
    25 = 02C8			COLOR4  = $02C8         ; COLBK shadow (border)
    26
    27 = D01F			CONSOL  = $D01F         ; console keys START/SELECT/OPTION (read, active low)
    28 = D209			KBCODE  = $D209         ; raw keyboard scan code
    29 = D20F			SKSTAT  = $D20F         ; serial/keyboard status (read)
    30 = D20F			SKCTL   = $D20F         ; serial/keyboard control (write)
    31 = D200			AUDF1   = $D200         ; channel-1 frequency divisor
    32 = D201			AUDC1   = $D201         ; channel-1 control (distortion | volume)
    33 = D208			AUDCTL  = $D208         ; POKEY global audio control
    34
    35 = E000			ROMFONT = $E000         ; OS ROM character set (8 bytes/glyph, screen-code index)
    36 = 4000			FB1     = $4000         ; framebuffer region 1 (scan lines 0..101)
    37 = 5000			FB2     = $5000         ; framebuffer region 2 (scan lines 102..191)
    38 = 6000			linetab_lo = $6000      ; 192 bytes: low byte of each scan line's address
    39 = 60C0			linetab_hi = $60C0      ; 192 bytes: high byte
    40 				                        ; NOTE: kept ABOVE the framebuffers ($4000-$5E0F) and clear
    41 				                        ; of the program/descriptor tables ($2000-$3D59). The old
    42 				                        ; $3000 scratch collided with the param_*/p_* tables once the
    43 				                        ; code grew past $3000 (build_linetab clobbered the label
    44 				                        ; pointers -> draw_page_labels looped forever). Don't move it
    45 				                        ; back into program space.
    46
    47 = 007C			KBTOP   = 124           ; piano keyboard top scan line
    48
    49 				; ----- zero-page pointers (free OS scratch $CB-$D1) -------------------------
    50 = 00CB			scrptr  = $CB           ; word: general dest pointer
    51 = 00CD			srcptr  = $CD           ; word: source (font / table / string)
    52 = 00CF			adjptr  = $CF           ; word: blit dest line / apply_adjust target
    53
    54 				; ----- work variables (free RAM, page 6) ------------------------------------
    55 = 0600			cur_param   = $0600     ; selected panel parameter 0..7
    56 = 0601			wave_idx    = $0601     ; 0..3  -> SQUARE/PURE/BUZZ/NOISE
    57 = 0602			volume      = $0602     ; 0..15 (envelope peak)
    58 = 0603			octave      = $0603     ; 0..4  (centre 2 = +0)
    59 = 0604			clock15     = $0604     ; clock/range mode: 0 NORMAL, 1 15KHZ, 2 16-BIT
    60 = 0605			prev_pressed= $0605
    61 = 0606			rep_timer   = $0606
    62 = 0607			note_idx    = $0607     ; current note 0..16, or $FF = none
    63 = 0608			prev_note   = $0608     ; last highlighted note
    64 = 0609			pressed     = $0609
    65 = 060A			edge        = $060A
    66 = 060B			delta       = $060B
    67 = 060C			tmpA        = $060C
    68 = 060D			tmp2        = $060D
    69 = 060E			cnt         = $060E
    70
    71 				; ADSR params (0..15)
    72 = 062C			atk_rate    = $062C
    73 = 062D			dec_rate    = $062D
    74 = 062E			sus_level   = $062E
    75 = 062F			rel_rate    = $062F
    76 = 0630			sus_clamp   = $0630
    77
    78 				; voices (4)
    79 = 0610			voice_note  = $0610     ; 4: absolute chromatic index
    80 = 0614			voice_level = $0614     ; 4: envelope level 0..15
    81 = 0618			held_voice  = $0618
    82 = 0619			last_voice  = $0619
    83 = 061C			vfreq       = $061C
    84 = 061D			vctl        = $061D
    85 = 061E			prev_held   = $061E
    86 = 0620			voice_phase = $0620     ; 4: PH_*
    87 = 0624			voice_count = $0624     ; 4: frames to next step
    88
    89 				; graphics scratch
    90 = 0640			xlo     = $0640
    91 = 0641			xhi     = $0641
    92 = 0642			py      = $0642
    93 = 0643			s0      = $0643
    94 = 0644			s1      = $0644
    95 = 0645			s_dy    = $0645
    96 = 0646			s_kc    = $0646
    97 = 0647			s_pc    = $0647
    98 = 0648			bc_code = $0648
    99 = 0649			bc_col  = $0649
   100 = 064A			bc_scan = $064A
   101 = 064B			bc_inv  = $064B
   102 = 064C			psi     = $064C
   103 = 064D			pcnt    = $064D
   104 = 064E			kcx     = $064E
   105 = 064F			kcy     = $064F
   106 = 0650			kfrm    = $0650
   107 = 0651			rw      = $0651
   108 = 0652			rh      = $0652
   109 = 0653			r_x     = $0653
   110 = 0654			r_xh    = $0654
   111 = 0655			r_y     = $0655
   112 = 0656			wxl     = $0656
   113 = 0657			wxh     = $0657
   114 = 0658			prev_param = $0658
   115 = 0659			prev_wave  = $0659
   116 = 065A			prev_vol   = $065A
   117 = 065B			prev_oct   = $065B
   118 = 065C			prev_atk   = $065C
   119 = 065D			prev_dec   = $065D
   120 = 065E			prev_sus   = $065E
   121 = 065F			prev_rel   = $065F
   122 = 0660			prev_clk   = $0660
   123 = 0661			pmode      = $0661      ; plot mode: 0 = set pixel, $FF = clear pixel
   124 = 0662			bc_mode    = $0662      ; blit mode: 0 = set (white on black), $FF = clear (black on white)
   125
   126 				; LFO (vibrato) state
   127 = 0663			lfo_rate    = $0663     ; 0..15 panel param
   128 = 0664			lfo_depth   = $0664     ; 0..15 panel param
   129 = 0665			lfo_level_u = $0665     ; unsigned 0..2*lfo_max triangle counter
   130 = 0666			lfo_dir     = $0666     ; +1 / $FF
   131 = 0667			lfo_count   = $0667     ; frames to next LFO step
   132 = 0668			lfo_offset  = $0668     ; signed pitch offset added to AUDF
   133 = 0669			lfo_max     = $0669
   134 = 066A			lfo_max2    = $066A
   135 				; draw_param scratch (NOT touched by draw_knob/num2)
   136 = 066B			dp_val      = $066B
   137 = 066C			dp_numcol   = $066C
   138 = 066D			dp_scan     = $066D
   139 				; DETUNE (fat pitch)
   140 = 066E			detune      = $066E     ; 0..15 panel param
   141 = 066F			detune_amt  = $066F     ; detune >> 2 (per-voice AUDF step)
   142 = 0670			prev_disp   = $0670     ; NPARAM bytes ($0670-$067B): last displayed value
   143 = 06C1			dvoff       = $06C1     ; 4 bytes: per-voice detune AUDF offset (moved up: prev_disp
   144 				                        ; grew with NPARAM and reached the old $0680 slot)
   145 				; arpeggiator
   146 = 0684			arp_rate    = $0684     ; 0 = off, 1..15 = step speed
   147 = 0685			arp_step    = $0685     ; pattern position 0..3
   148 = 0686			arp_timer   = $0686     ; frames to next arp step
   149 				; --- new feature work vars (allocated above the sequencer block at $06B5+ so
   150 				;     they stay clear of prev_disp, which grows with NPARAM) ---
   151 = 06B5			arp_mode    = $06B5     ; arpeggiator pattern: 0 UP, 1 DOWN, 2 MINOR, 3 OCTAVE
   152 = 06B6			porta_rate  = $06B6     ; portamento (glide): 0 off, 1..15 = AUDF step every N frames
   153 = 06B7			porta_timer = $06B7     ; frames to next glide step
   154 = 06B8			porta_cur   = $06B8     ; 4: current (gliding) AUDF per voice
   155 = 06BC			porta_step  = $06BC     ; 1 on frames where the glide advances one step
   156 = 06BD			drum_dec    = $06BD     ; DRUM param: 0 off, 1..15 = decay frames per level step
   157 = 06BE			drum_level  = $06BE     ; current drum envelope level (0 = drum channel free)
   158 = 06BF			drum_timer  = $06BF     ; frames to next drum decay step
   159 = 06C0			hpf_cut     = $06C0     ; HP filter: 0 off, 1..15 cutoff (uses ch3 as the clock)
   160 = 06C5			preset_slot = $06C5     ; PRESET param: selected patch slot 0..3
   161 = 06C6			prev_preset = $06C6     ; last slot (detect selection change -> load)
   162 = 06C7			preset_fp   = $06C7     ; previous fire-button state (edge detect for save)
   163 = 06C8			drum_key    = $06C8     ; previous drum-key ('1') state (edge detect for live hit)
   164 = 06C9			drum_beat   = $06C9     ; DRUMBEAT param: 0 off, 1..15 auto drum-machine rate
   165 = 06CA			dbeat_timer = $06CA     ; frames to next tempo beat
   166 = 06CB			dbeat_cnt   = $06CB     ; tempo beats remaining until the next auto drum hit
   167 = 0700			preset_bank = $0700     ; 4 slots x NSAVE bytes of saved params (page 7, free RAM)
   168 = 0687			sustain_ped = $0687     ; 1 while OPTION held -> notes don't release
   169 = 0688			vlimit      = $0688     ; active voice count: 4 (8-bit) or 2 (16-bit)
   170 = 0689			prev_clkm   = $0689     ; previous clock mode (detect change -> reset voices)
   171 = 068A			nlo         = $068A     ; 16-bit divider scratch (low/high)
   172 = 068B			nhi         = $068B
   173 = 068C			tempo       = $068C     ; sequencer tempo (0..15), page-2 param
   174 = 068D			page        = $068D     ; current panel page (cur_param / 12)
   175 = 068E			prev_page   = $068E
   176 = 068F			pg_base     = $068F     ; first param index of current page
   177 = 0690			pg_end      = $0690     ; one past last param index of current page
   178 				; step sequencer
   179 = 0691			seq_notes   = $0691     ; 16 steps: semitone 0..16, or $FF = rest
   180 = 06A1			seq_play    = $06A1     ; 0 stopped / 1 playing
   181 = 06A2			seq_rec     = $06A2     ; 0 / 1 record-armed
   182 = 06A3			seq_pos     = $06A3     ; play head 0..15
   183 = 06A4			seq_wpos    = $06A4     ; record write head 0..15
   184 = 06A5			seq_timer   = $06A5     ; frames to next step
   185 = 06A6			seq_prevn   = $06A6     ; previous note (record onset edge)
   186 = 06A7			prev_spos   = $06A7     ; last drawn play head (display diff)
   187 = 06A8			prev_splay  = $06A8
   188 = 06A9			prev_srec   = $06A9
   189 = 06AA			seq_dirty   = $06AA     ; 1 = step grid needs full redraw
   190 = 06AB			con_now     = $06AB     ; console keys pressed bits (active high)
   191 = 06AC			con_prev    = $06AC
   192 				; per-voice level meters (VU bars at the top, scan 9-13)
   193 = 06AD			prev_vmeter = $06AD     ; 4: last drawn level per voice (incremental redraw)
   194 = 06B1			dm_lo       = $06B1     ; meter draw scratch: lower envelope level
   195 = 06B2			dm_hi       = $06B2     ; meter draw scratch: higher envelope level
   196 = 06B3			seq_len     = $06B3     ; playback loop length = number of recorded steps (1..16)
   197 = 06B4			rec_latch   = $06B4     ; real-time record: note played since last step ($FF=none)
   198
   199 = 0013			NPARAM = 19             ; ...page2 16 HPF, 17 PRESET, 18 DRUMBEAT
   200 = 0011			NSAVE  = 17             ; params 0..16 are saved in a preset (PRESET itself is not)
   201 = 0010			PG2BASE = 16            ; first param index on page 2 (the third page)
   202 = 000C			PER_PAGE = 12
   203 = 0000			K_KNOB = 0              ; 0..15 value -> knob + 2-digit number
   204 = 0001			K_OCT  = 1              ; octave (0..4) -> knob + signed number
   205 = 0002			K_WAVE = 2              ; waveform icon selector
   206 = 0003			K_CLK  = 3              ; NORM|15K toggle
   207
   208 = 0000			PH_IDLE    = 0
   209 = 0001			PH_ATTACK  = 1
   210 = 0002			PH_DECAY   = 2
   211 = 0003			PH_SUSTAIN = 3
   212 = 0004			PH_RELEASE = 4
   213
   214 = 000F			REPDELAY = 15
   215 = 0004			REPFAST  = 4
   216 = 0004			DECAYRATE = 4
   217 = 0011			NUMKEYS  = 17
