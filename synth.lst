  1033 25CD D0 01		        bne dt_active
  1034 25CF 60			        rts                     ; idle -> leave channel 4 to voice 3
  1035 25D0			dt_active
  1036 25D0 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1037 25D3 F0 07		        beq dt_kill
  1038 25D5 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1039 25D8 C9 02		        cmp #2
  1040 25DA D0 06		        bne dt_decay
  1041 25DC			dt_kill
  1042 25DC A9 00		        lda #0
  1043 25DE 8D BE 06		        sta drum_level
  1044 25E1 60			        rts
  1045 25E2			dt_decay
  1046 25E2 CE BF 06		        dec drum_timer
  1047 25E5 D0 09		        bne dt_emit
  1048 25E7 AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1049 25EA 8D BF 06		        sta drum_timer
