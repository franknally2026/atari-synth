   994 				; ----------------------------------------------------------------------------
   995 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
   996 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
   997 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
   998 				;  high channel). drum_tick runs after update_sound and overrides channel 4
   999 				;  while a hit rings; when it ends, voice 3's normal output resumes.
  1000 				; ----------------------------------------------------------------------------
  1001 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
  1002 259B			drum_hit
  1003 259B AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
  1004 259E F0 12		        beq dh_off
  1005 25A0 AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
  1006 25A3 C9 02		        cmp #2
  1007 25A5 F0 0B		        beq dh_off
  1008 25A7 A9 0F		        lda #15
  1009 25A9 8D BE 06		        sta drum_level
  1010 25AC AD BD 06		        lda drum_dec            ; full level held for one decay interval first
  1011 25AF 8D BF 06		        sta drum_timer
  1012 25B2			dh_off
  1013 25B2 60			        rts
  1014 25B3			drum_tick
  1015 25B3 AD BE 06		        lda drum_level
  1016 25B6 D0 01		        bne dt_active
  1017 25B8 60			        rts                     ; idle -> leave channel 4 to voice 3
  1018 25B9			dt_active
  1019 25B9 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1020 25BC F0 07		        beq dt_kill
  1021 25BE AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1022 25C1 C9 02		        cmp #2
  1023 25C3 D0 06		        bne dt_decay
  1024 25C5			dt_kill
  1025 25C5 A9 00		        lda #0
  1026 25C7 8D BE 06		        sta drum_level
  1027 25CA 60			        rts
  1028 25CB			dt_decay
  1029 25CB CE BF 06		        dec drum_timer
  1030 25CE D0 09		        bne dt_emit
  1031 25D0 AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1032 25D3 8D BF 06		        sta drum_timer
  1033 25D6 CE BE 06		        dec drum_level
  1034 25D9			dt_emit
  1035 25D9 A9 1E		        lda #DRUM_AUDF
  1036 25DB 8D 06 D2		        sta AUDF1+6             ; channel 4 frequency
  1037 25DE AD BE 06		        lda drum_level          ; AUDC = distortion 0 (white-ish noise) | level
  1038 25E1 8D 07 D2		        sta AUDC1+6
  1039 25E4 60			        rts
