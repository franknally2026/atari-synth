   499 				; Navigation keys (laptop play, no joystick needed). The Atari arrow keys are
   500 				; Ctrl + the -/=/+/* keys; Ctrl sets KBCODE bit6 ($40), so they read UNMASKED as
   501 				; $4E/$4F/$46/$47 (read_keyboard masks #$3F for the note matrix and ignores
   502 				; these). Arrows set kbd_dir level bits -> update_input gives them the same
   503 				; nav/adjust/auto-repeat as the joystick. Tab/Return are edge-triggered via nav_prev.
   504 				;   Up=$4E Down=$4F Left=$46 Right=$47   Tab=$2C (page flip)   Return=$0C (save)
   505 2207			read_navkeys
   506 2207 A9 00		        lda #0
   507 2209 8D CE 06		        sta kbd_dir
   508 220C AD 0F D2		        lda SKSTAT
   509 220F 29 04		        and #$04
   510 2211 D0 74		        bne rn_none             ; no key down
   511 2213 AD 09 D2		        lda KBCODE
   512 2216 C9 4E		        cmp #$4E                ; UP    (Ctrl+MINUS)
   513 2218 D0 08		        bne rn_n1
   514 221A A9 01		        lda #$01
   515 221C 8D CE 06		        sta kbd_dir
   516 221F 4C 80 22		        jmp rn_seen
   517 2222			rn_n1
   518 2222 C9 4F		        cmp #$4F                ; DOWN  (Ctrl+EQUALS)
   519 2224 D0 08		        bne rn_n2
   520 2226 A9 02		        lda #$02
   521 2228 8D CE 06		        sta kbd_dir
   522 222B 4C 80 22		        jmp rn_seen
   523 222E			rn_n2
   524 222E C9 46		        cmp #$46                ; LEFT  (Ctrl+PLUS)
   525 2230 D0 08		        bne rn_n3
   526 2232 A9 04		        lda #$04
   527 2234 8D CE 06		        sta kbd_dir
   528 2237 4C 80 22		        jmp rn_seen
   529 223A			rn_n3
   530 223A C9 47		        cmp #$47                ; RIGHT (Ctrl+ASTERISK)
   531 223C D0 08		        bne rn_n4
   532 223E A9 08		        lda #$08
   533 2240 8D CE 06		        sta kbd_dir
   534 2243 4C 80 22		        jmp rn_seen
   535 2246			rn_n4
   536 2246 C9 2C		        cmp #$2C                ; Tab -> cycle page (edge only, no repeat)
   537 2248 D0 0D		        bne rn_n5
   538 224A AE CF 06		        ldx nav_prev
   539 224D E0 2C		        cpx #$2C
   540 224F F0 2F		        beq rn_seen
   541 2251 20 8D 22		        jsr page_flip
   542 2254 4C 80 22		        jmp rn_seen
   543 2257			rn_n5
   544 2257 C9 0C		        cmp #$0C                ; Return -> save preset (joystick-fire substitute)
   545 2259 D0 0D		        bne rn_short
   546 225B AE CF 06		        ldx nav_prev
   547 225E E0 0C		        cpx #$0C
   548 2260 F0 1E		        beq rn_seen
   549 2262 20 AA 22		        jsr nav_save_preset
   550 2265 4C 80 22		        jmp rn_seen
   551 2268			rn_short
   552 				        ; letter shortcut: a free letter that's underlined in a param's label jumps
   553 				        ; the selection straight to that param (A still holds raw KBCODE here). Only
   554 				        ; the 6 params whose letter is UNIQUE have an entry (see shortcut_kc).
   555 2268 A2 11		        ldx #NSHORT-1
   556 226A			rn_short_l
   557 226A DD 9F 37		        cmp shortcut_kc,x
   558 226D F0 06		        beq rn_short_hit
   559 226F CA			        dex
   560 2270 10 F8		        bpl rn_short_l
