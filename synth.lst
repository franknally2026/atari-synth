   661 				; ----------------------------------------------------------------------------
   662 				;  Step sequencer: record note onsets into a 16-step pattern; when playing,
   663 				;  step at the TEMPO rate and trigger each step's note via trigger_note.
   664 				; ----------------------------------------------------------------------------
   665 230A			seq_tick
   666 230A AD A2 06		        lda seq_rec             ; --- record: detect a new note onset ---
   667 230D F0 40		        beq sq_norec
   668 230F AD 07 06		        lda note_idx
   669 2312 C9 FF		        cmp #$FF
   670 2314 F0 33		        beq sq_recdone
   671 2316 CD A6 06		        cmp seq_prevn
   672 2319 F0 2E		        beq sq_recdone          ; same held note -> not a new onset
   673 231B AC A1 06		        ldy seq_play
   674 231E D0 23		        bne sq_latch            ; PLAYING+REC = real-time: latch; clock writes it
   675 2320 AE A4 06		        ldx seq_wpos            ; STOPPED+REC = step entry: write here, advance
   676 2323 9D 91 06		        sta seq_notes,x
   677 2326 E8			        inx
   678 2327 EC B3 06		        cpx seq_len             ; grow loop length to the furthest step filled
   679 232A 90 03		        bcc sq_nolen
   680 232C 8E B3 06		        stx seq_len
   681 232F			sq_nolen
   682 232F E0 10		        cpx #16
   683 2331 D0 02		        bne sq_wok
   684 2333 A2 00		        ldx #0
   685 2335			sq_wok
   686 2335 8E A4 06		        stx seq_wpos
   687 2338 A9 01		        lda #1
   688 233A 8D AA 06		        sta seq_dirty
   689 233D AD 07 06		        lda note_idx
   690 2340 4C 49 23		        jmp sq_recdone
   691 2343			sq_latch
   692 2343 8D B4 06		        sta rec_latch           ; real-time: remember the onset for the clock
   693 2346 AD 07 06		        lda note_idx
   694 2349			sq_recdone
   695 2349 8D A6 06		        sta seq_prevn
   696 234C 4C 57 23		        jmp sq_play
   697 234F			sq_norec
   698 234F A9 FF		        lda #$FF
   699 2351 8D A6 06		        sta seq_prevn
   700 2354 8D B4 06		        sta rec_latch           ; not armed -> drop any pending latch
   701 2357			sq_play
   702 2357 AD A1 06		        lda seq_play            ; --- play / real-time clock ---
   703 235A D0 01		        bne sq_playing
   704 235C 60			        rts
   705 235D			sq_playing
   706 235D CE A5 06		        dec seq_timer
   707 2360 F0 01		        beq sq_step
   708 2362 60			        rts
   709 2363			sq_step
   710 2363 A9 10		        lda #16                 ; reload: interval = (16-tempo)*2 + 2 frames
   711 2365 38			        sec
   712 2366 ED 8C 06		        sbc tempo
   713 2369 0A			        asl
   714 236A 18			        clc
   715 236B 69 02		        adc #2
   716 236D 8D A5 06		        sta seq_timer
   717 2370 AE A3 06		        ldx seq_pos             ; play this step's EXISTING note (timing reference)
   718 2373 BD 91 06		        lda seq_notes,x
   719 2376 C9 FE		        cmp #$FE                ; TIE -> a held note continues: do NOT re-strike,
   720 2378 F0 3F		        beq sq_nostep           ; let the sustaining voice ring on (no blips)
   721 237A C9 FD		        cmp #$FD                ; DRUM hit step
   722 237C D0 06		        bne sq_nodrum
   723 237E 20 B2 25		        jsr drum_hit
   724 2381 4C B9 23		        jmp sq_nostep
   725 2384			sq_nodrum
   726 2384 C9 FF		        cmp #$FF
   727 2386 D0 14		        bne sq_playnote
   728 2388 AD A2 06		        lda seq_rec             ; rest step -> silence the gap by releasing the held
   729 238B F0 07		        beq sq_restrel          ; voice. Playback always releases; while recording,
   730 238D AD 07 06		        lda note_idx            ; keep a LIVE-held note (don't cut your own playing)
   731 2390 C9 FF		        cmp #$FF                ; but still release when only monitoring (no key down).
   732 2392 D0 25		        bne sq_nostep
   733 2394			sq_restrel
   734 2394 A9 FF		        lda #$FF
   735 2396 8D 18 06		        sta held_voice
   736 2399 4C B9 23		        jmp sq_nostep
   737 239C			sq_playnote
   738 239C 8D 0C 06		        sta tmpA
   739 239F AD A2 06		        lda seq_rec             ; while RECORDING, don't let the clock re-strike a note
   740 23A2 F0 08		        beq sq_pn_go            ; you're already holding live -> that would double it
   741 23A4 AD 0C 06		        lda tmpA                ; (two unison voices) and re-attack your sustained note
   742 23A7 CD 07 06		        cmp note_idx            ; every loop. note_idx is the live semitone; tmpA is the
   743 23AA F0 0D		        beq sq_nostep           ; step's. Same -> skip the clock trigger, keep monitoring.
   744 23AC			sq_pn_go
   745 23AC AC 03 06		        ldy octave
   746 23AF B9 35 36		        lda octave_base,y
   747 23B2 18			        clc
   748 23B3 6D 0C 06		        adc tmpA
   749 23B6 20 E9 24		        jsr trigger_note
   750 23B9			sq_nostep
   751 23B9 AD A2 06		        lda seq_rec             ; real-time: capture the live note into this step
   752 23BC F0 2E		        beq sq_adv
   753 23BE AD B4 06		        lda rec_latch           ; a NEW onset latched since the last tick?
   754 23C1 C9 FF		        cmp #$FF
   755 23C3 D0 17		        bne sq_cap              ; yes -> write the struck note (re-attack)
   756 23C5 AD 07 06		        lda note_idx            ; else still holding the same key?
   757 23C8 C9 FF		        cmp #$FF
   758 23CA F0 20		        beq sq_adv              ; nothing held -> leave step (rest)
   759 23CC C9 FD		        cmp #$FD                ; a HELD drum key is a one-shot, not a sustain: don't
   760 23CE F0 1C		        beq sq_adv              ; smear it into ties (leave following steps as rests)
   761 23D0 AE A3 06		        ldx seq_pos             ; held pitch -> extend with a TIE, but ONLY into a
   762 23D3 BD 91 06		        lda seq_notes,x         ; REST. On a later loop this step already holds the
   763 23D6 C9 FF		        cmp #$FF                ; struck note (or its ties); rewriting it as a tie
   764 23D8 D0 12		        bne sq_adv              ; would wipe the attack and play back silent. Leave it.
   765 23DA A9 FE		        lda #$FE                ; held pitch over a rest -> TIE (sustains on playback)
   766 23DC			sq_cap
   767 23DC AE A3 06		        ldx seq_pos
   768 23DF 9D 91 06		        sta seq_notes,x
   769 23E2 A9 01		        lda #1
   770 23E4 8D AA 06		        sta seq_dirty
   771 23E7 A9 FF		        lda #$FF
   772 23E9 8D B4 06		        sta rec_latch           ; consume the latch
   773 23EC			sq_adv
   774 23EC EE A3 06		        inc seq_pos             ; wrap at the recorded length (or 16 if empty)
   775 23EF AE B3 06		        ldx seq_len
   776 23F2 D0 02		        bne sq_lim
   777 23F4 A2 10		        ldx #16
   778 23F6			sq_lim
   779 23F6 EC A3 06		        cpx seq_pos
   780 23F9 D0 05		        bne sq_done
   781 23FB A9 00		        lda #0
   782 23FD 8D A3 06		        sta seq_pos
   783 2400			sq_done
   784 2400 60			        rts
   785
   786 				; Unified directional input: up/down navigate, left/right adjust. ALL FOUR now
   787 				; auto-repeat off one rep_timer (was: U/D edge-only, L/R repeated). Arrow keys are
   788 				; merged in via kbd_dir (read_navkeys) so they drive the exact same path.
   789 2401			update_input
   790 2401 AD 78 02		        lda STICK0
   791 2404 29 0F		        and #$0F
   792 2406 49 0F		        eor #$0F                ; bit0=up bit1=down bit2=left bit3=right (active high)
   793 2408 0D CE 06		        ora kbd_dir             ; merge arrow keys -> identical nav/adjust/repeat
   794 240B 8D 09 06		        sta pressed
   795 240E AD 05 06		        lda prev_pressed
   796 2411 49 FF		        eor #$FF
   797 2413 2D 09 06		        and pressed
   798 2416 8D 0A 06		        sta edge                ; freshly-pressed directions this frame
   799 2419 AD 09 06		        lda pressed
   800 241C 29 0F		        and #$0F
   801 241E D0 08		        bne ui_held
   802 2420 A9 0F		        lda #REPDELAY           ; nothing held -> re-arm the initial delay
   803 2422 8D 06 06		        sta rep_timer
   804 2425 4C 89 24		        jmp ui_done
   805 2428			ui_held
   806 2428 AD 0A 06		        lda edge
   807 242B 29 0F		        and #$0F
   808 242D D0 0D		        bne ui_fresh            ; a fresh press -> act immediately
   809 242F CE 06 06		        dec rep_timer
   810 2432 D0 55		        bne ui_done             ; still counting down -> no action this frame
   811 2434 A9 04		        lda #REPFAST            ; timer expired -> repeat at the fast rate
   812 2436 8D 06 06		        sta rep_timer
   813 2439 4C 41 24		        jmp ui_act
   814 243C			ui_fresh
   815 243C A9 0F		        lda #REPDELAY
   816 243E 8D 06 06		        sta rep_timer
   817 2441			ui_act
   818 2441 AD 09 06		        lda pressed             ; UP -> previous param (wrap)
   819 2444 29 01		        and #$01
   820 2446 F0 0A		        beq ui_a_nodn
   821 2448 CE 00 06		        dec cur_param
   822 244B 10 05		        bpl ui_a_nodn
   823 244D A9 12		        lda #NPARAM-1
   824 244F 8D 00 06		        sta cur_param
   825 2452			ui_a_nodn
