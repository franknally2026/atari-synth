   615 22BB			seq_toggle_play
   616 22BB AD A1 06		        lda seq_play
   617 22BE 49 01		        eor #1
   618 22C0 8D A1 06		        sta seq_play
   619 22C3 F0 0A		        beq stp_done            ; just stopped
   620 22C5 A9 00		        lda #0                  ; just started: from step 0, fire soon
   621 22C7 8D A3 06		        sta seq_pos
   622 22CA A9 01		        lda #1
   623 22CC 8D A5 06		        sta seq_timer
   624 22CF			stp_done
