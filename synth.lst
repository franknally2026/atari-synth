   858 24DE F0 07		        beq dt_kill
   859 24E0 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
   860 24E3 C9 02		        cmp #2
   861 24E5 D0 06		        bne dt_decay
   862 24E7			dt_kill
   863 24E7 A9 00		        lda #0
   864 24E9 8D BE 06		        sta drum_level
