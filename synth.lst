   506 				; Navigation keys (laptop play, no joystick needed). The Atari arrow keys are
   507 				; Ctrl + the -/=/+/* keys; Ctrl sets KBCODE bit6 ($40), so they read UNMASKED as
   508 				; $4E/$4F/$46/$47 (read_keyboard masks #$3F for the note matrix and ignores
   509 				; these). Arrows set kbd_dir level bits -> update_input gives them the same
   510 				; nav/adjust/auto-repeat as the joystick. Tab/Return are edge-triggered via nav_prev.
   511 				;   Up=$4E Down=$4F Left=$46 Right=$47   Tab=$2C (page flip)   Return=$0C (save)
   512 2207			read_navkeys
   513 2207 A9 00		        lda #0
   514 2209 8D CE 06		        sta kbd_dir
   515 220C AD 0F D2		        lda SKSTAT
   516 220F 29 04		        and #$04
   517 2211 D0 74		        bne rn_none             ; no key down
   518 2213 AD 09 D2		        lda KBCODE
   519 2216 C9 4E		        cmp #$4E                ; UP    (Ctrl+MINUS)
   520 2218 D0 08		        bne rn_n1
   521 221A A9 01		        lda #$01
   522 221C 8D CE 06		        sta kbd_dir
   523 221F 4C 80 22		        jmp rn_seen
   524 2222			rn_n1
   525 2222 C9 4F		        cmp #$4F                ; DOWN  (Ctrl+EQUALS)
   526 2224 D0 08		        bne rn_n2
   527 2226 A9 02		        lda #$02
   528 2228 8D CE 06		        sta kbd_dir
   529 222B 4C 80 22		        jmp rn_seen
   530 222E			rn_n2
   531 222E C9 46		        cmp #$46                ; LEFT  (Ctrl+PLUS)
   532 2230 D0 08		        bne rn_n3
   533 2232 A9 04		        lda #$04
   534 2234 8D CE 06		        sta kbd_dir
   535 2237 4C 80 22		        jmp rn_seen
   536 223A			rn_n3
   537 223A C9 47		        cmp #$47                ; RIGHT (Ctrl+ASTERISK)
   538 223C D0 08		        bne rn_n4
   539 223E A9 08		        lda #$08
   540 2240 8D CE 06		        sta kbd_dir
   541 2243 4C 80 22		        jmp rn_seen
   542 2246			rn_n4
   543 2246 C9 2C		        cmp #$2C                ; Tab -> cycle page (edge only, no repeat)
   544 2248 D0 0D		        bne rn_n5
   545 224A AE CF 06		        ldx nav_prev
   546 224D E0 2C		        cpx #$2C
   547 224F F0 2F		        beq rn_seen
   548 2251 20 8D 22		        jsr page_flip
   549 2254 4C 80 22		        jmp rn_seen
   550 2257			rn_n5
   551 2257 C9 0C		        cmp #$0C                ; Return -> save preset (joystick-fire substitute)
   552 2259 D0 0D		        bne rn_short
   553 225B AE CF 06		        ldx nav_prev
   554 225E E0 0C		        cpx #$0C
   555 2260 F0 1E		        beq rn_seen
   556 2262 20 AA 22		        jsr nav_save_preset
   557 2265 4C 80 22		        jmp rn_seen
   558 2268			rn_short
   559 				        ; letter shortcut: a free letter that's underlined in a param's label jumps
   560 				        ; the selection straight to that param (A still holds raw KBCODE here). Only
   561 				        ; the 6 params whose letter is UNIQUE have an entry (see shortcut_kc).
   562 2268 A2 12		        ldx #NSHORT-1
   563 226A			rn_short_l
   564 226A DD 43 38		        cmp shortcut_kc,x
   565 226D F0 06		        beq rn_short_hit
   566 226F CA			        dex
   567 2270 10 F8		        bpl rn_short_l
   568 2272 4C 80 22		        jmp rn_seen             ; not a shortcut key
   569 2275			rn_short_hit
   570 2275 CD CF 06		        cmp nav_prev            ; A = this key = shortcut_kc[x]; held -> no re-jump
   571 2278 F0 06		        beq rn_seen
   572 227A BD 56 38		        lda shortcut_param,x    ; jump (cur_param drives the page too)
   573 227D 8D 00 06		        sta cur_param
   574 2280			rn_seen
   575 2280 AD 09 D2		        lda KBCODE              ; remember this frame's key for next-frame edge detect
   576 2283 8D CF 06		        sta nav_prev
   577 2286 60			        rts
   578 2287			rn_none
   579 2287 A9 FF		        lda #$FF
   580 2289 8D CF 06		        sta nav_prev
   581 228C 60			        rts
