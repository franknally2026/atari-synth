  2350 2FF0 8C 0D 06		        sty tmp2
  2351 2FF3 9D AD 06		        sta prev_vmeter,x       ; store new
  2352 2FF6 CD 0D 06		        cmp tmp2                ; new - old
  2353 2FF9 B0 14		        bcs dm_rise
  2354 2FFB A9 FF		        lda #$FF                ; level fell -> CLEAR from new to old
  2355 2FFD 8D 61 06		        sta pmode
  2356 3000 AD 0D 06		        lda tmp2
  2357 3003 8D B2 06		        sta dm_hi               ; hi = old
  2358 3006 BD AD 06		        lda prev_vmeter,x
