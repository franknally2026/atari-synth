   601 				; Return mirrors the joystick fire button: save the patch, but only while the
   602 				; PRESET param is selected. Keep prev_preset in sync so preset_tick won't reload.
   603 22AA			nav_save_preset
   604 22AA AD 00 06		        lda cur_param
