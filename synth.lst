  2319 				; ----------------------------------------------------------------------------
  2320 				;  Per-voice level meters: 4 horizontal VU bars at scan 9-13, bar width =
  2321 				;  voice envelope level * 3 px. Drawn INCREMENTALLY -- each frame only the
  2322 				;  delta between the old and new level is set/cleared, so meters animating
  2323 				;  with the envelopes cost a few pixels per voice, not a full redraw.
  2324 				; ----------------------------------------------------------------------------
  2325 2FC2			draw_meters
  2326 2FC2 A2 00		        ldx #0
  2327 2FC4			dm_loop
  2328 2FC4 8E 46 06		        stx s_kc
  2329 2FC7 BD 14 06		        lda voice_level,x
  2330 2FCA DD AD 06		        cmp prev_vmeter,x
