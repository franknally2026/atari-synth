   623
   624 				; SELECT = real-time record: arming clears the pattern and STARTS the clock so
   625 				; you just play in time (the live note is captured on the step under the head).
   626 				; Disarming punches out but keeps the loop playing. To step-enter instead, stop
   627 				; the clock (START) while still armed -> rec + stopped writes one step per key.
   628 22D0			seq_toggle_rec
   629 22D0 AD A2 06		        lda seq_rec
   630 22D3 49 01		        eor #1
   631 22D5 8D A2 06		        sta seq_rec
   632 22D8 F0 2F		        beq str_done            ; just disarmed -> punch out, keep playing
   633 22DA A2 0F		        ldx #15                 ; arm: clear the pattern
   634 22DC A9 FF		        lda #$FF
   635 22DE			str_clr
   636 22DE 9D 91 06		        sta seq_notes,x
   637 22E1 CA			        dex
   638 22E2 10 FA		        bpl str_clr
   639 22E4 A9 00		        lda #0
   640 22E6 8D A4 06		        sta seq_wpos
   641 22E9 8D B3 06		        sta seq_len             ; (step entry grows this; real-time loops 16)
   642 22EC 8D A3 06		        sta seq_pos             ; record from step 0
   643 22EF A9 FF		        lda #$FF
   644 22F1 8D B4 06		        sta rec_latch
   645 22F4 A9 01		        lda #1
   646 22F6 8D AA 06		        sta seq_dirty
   647 22F9 8D A1 06		        sta seq_play            ; run the clock -> real-time record
   648 22FC A9 10		        lda #16                 ; one full step of lead-in so step 0 is playable
   649 22FE 38			        sec
   650 22FF ED 8C 06		        sbc tempo
   651 2302 0A			        asl
   652 2303 18			        clc
   653 2304 69 02		        adc #2
   654 2306 8D A5 06		        sta seq_timer
   655 2309			str_done
   656 2309 60			        rts
