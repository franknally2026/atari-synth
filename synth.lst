   583 				; Tab: jump the selection to the first param of the next page (0->1->2->0).
   584 				; update_display derives the page from cur_param, so this is all it takes.
   585 228D			page_flip
   586 228D AD 00 06		        lda cur_param
   587 2290 C9 0C		        cmp #PER_PAGE           ; page 0 (0..11) -> page 1
   588 2292 90 0A		        bcc pf_to1
   589 2294 C9 10		        cmp #PG2BASE            ; page 1 (12..15) -> page 2
   590 2296 90 0C		        bcc pf_to2
   591 2298 A9 00		        lda #0                  ; page 2 -> wrap to page 0
   592 229A 8D 00 06		        sta cur_param
   593 229D 60			        rts
   594 229E			pf_to1
   595 229E A9 0C		        lda #PER_PAGE
   596 22A0 8D 00 06		        sta cur_param
   597 22A3 60			        rts
   598 22A4			pf_to2
   599 22A4 A9 10		        lda #PG2BASE
   600 22A6 8D 00 06		        sta cur_param
   601 22A9 60			        rts
