   757 				; ----------------------------------------------------------------------------
   758 				;  Step sequencer: record note onsets into a 16-step pattern; when playing,
   759 				;  step at the TEMPO rate and trigger each step's note via trigger_note.
   760 				; ----------------------------------------------------------------------------
   761 2358			seq_tick
   762 2358 AD A2 06		        lda seq_rec             ; --- record: detect a new note onset ---
   763 235B F0 40		        beq sq_norec
   764 235D AD 07 06		        lda note_idx
   765 2360 C9 FF		        cmp #$FF
   766 2362 F0 33		        beq sq_recdone
   767 2364 CD A6 06		        cmp seq_prevn
   768 2367 F0 2E		        beq sq_recdone          ; same held note -> not a new onset
   769 2369 AC A1 06		        ldy seq_play
   770 236C D0 23		        bne sq_latch            ; PLAYING+REC = real-time: latch; clock writes it
   771 236E AE A4 06		        ldx seq_wpos            ; STOPPED+REC = step entry: write here, advance
   772 2371 9D 91 06		        sta seq_notes,x
   773 2374 E8			        inx
   774 2375 EC B3 06		        cpx seq_len             ; grow loop length to the furthest step filled
   775 2378 90 03		        bcc sq_nolen
   776 237A 8E B3 06		        stx seq_len
   777 237D			sq_nolen
   778 237D E0 10		        cpx #16
   779 237F D0 02		        bne sq_wok
   780 2381 A2 00		        ldx #0
   781 2383			sq_wok
   782 2383 8E A4 06		        stx seq_wpos
   783 2386 A9 01		        lda #1
   784 2388 8D AA 06		        sta seq_dirty
   785 238B AD 07 06		        lda note_idx
   786 238E 4C 97 23		        jmp sq_recdone
   787 2391			sq_latch
   788 2391 8D B4 06		        sta rec_latch           ; real-time: remember the onset for the clock
   789 2394 AD 07 06		        lda note_idx
   790 2397			sq_recdone
   791 2397 8D A6 06		        sta seq_prevn
   792 239A 4C A5 23		        jmp sq_play
   793 239D			sq_norec
   794 239D A9 FF		        lda #$FF
   795 239F 8D A6 06		        sta seq_prevn
   796 23A2 8D B4 06		        sta rec_latch           ; not armed -> drop any pending latch
   797 23A5			sq_play
   798 23A5 AD A1 06		        lda seq_play            ; --- play / real-time clock ---
   799 23A8 D0 01		        bne sq_playing
   800 23AA 60			        rts
   801 23AB			sq_playing
   802 23AB CE A5 06		        dec seq_timer
   803 23AE F0 01		        beq sq_step
   804 23B0 60			        rts
