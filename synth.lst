  1076 				; ----------------------------------------------------------------------------
  1077 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1078 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1079 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1080 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1081 				;  address, so save/load just walk those tables.
  1082 				; ----------------------------------------------------------------------------
  1083 2617			preset_tick
  1084 2617 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1085 261A 49 01		        eor #$01
  1086 261C 29 01		        and #$01
  1087 261E 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1088 				                                ; which only touches tmp2 — NOT tmpA)
  1089 2621 AE 00 06		        ldx cur_param
  1090 2624 E0 11		        cpx #17                 ; PRESET param selected?
  1091 2626 D0 13		        bne pt_load
  1092 2628 AD 0C 06		        lda tmpA
  1093 262B F0 0E		        beq pt_load
  1094 262D AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1095 2630 D0 09		        bne pt_load
