  1449 				; ----------------------------------------------------------------------------
  1450 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1451 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1452 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1453 				; ----------------------------------------------------------------------------
  1454 2932			lfo_tick
  1455 2932 AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1456 2935 D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1457 2937 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1458 293A 8D 65 06		        sta lfo_level_u
  1459 293D 60			        rts
  1460 293E			lt_on
  1461 293E 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1462 293F 8D 69 06		        sta lfo_max
  1463 2942 CE 67 06		        dec lfo_count
  1464 2945 F0 01		        beq lt_step
  1465 2947 60			        rts
  1466 2948			lt_step
  1467 2948 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1468 294A 38			        sec
  1469 294B ED 63 06		        sbc lfo_rate
  1470 294E 8D 67 06		        sta lfo_count
  1471 2951 AD 69 06		        lda lfo_max
  1472 2954 0A			        asl
  1473 2955 8D 6A 06		        sta lfo_max2            ; 2*max
  1474 2958 AD 66 06		        lda lfo_dir
  1475 295B 30 19		        bmi lt_down
  1476 295D EE 65 06		        inc lfo_level_u         ; ramp up
  1477 2960 AD 65 06		        lda lfo_level_u
  1478 2963 CD 6A 06		        cmp lfo_max2
  1479 2966 90 1E		        bcc lt_offset
  1480 2968 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1481 296B 8D 65 06		        sta lfo_level_u
  1482 296E A9 FF		        lda #$FF
  1483 2970 8D 66 06		        sta lfo_dir
  1484 2973 4C 86 29		        jmp lt_offset
  1485 2976			lt_down
  1486 2976 AD 65 06		        lda lfo_level_u
  1487 2979 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1488 297B CE 65 06		        dec lfo_level_u
  1489 297E 4C 86 29		        jmp lt_offset
  1490 2981			lt_rev_up
  1491 2981 A9 01		        lda #1
  1492 2983 8D 66 06		        sta lfo_dir
  1493 2986			lt_offset
  1494 2986 AD 65 06		        lda lfo_level_u         ; offset = level - max  (signed)
  1495 2989 38			        sec
  1496 298A ED 69 06		        sbc lfo_max
  1497 298D 8D 68 06		        sta lfo_offset
  1498 2990 60			        rts
