  2360 300C 4C 20 30		        jmp dm_calc
  2361 300F			dm_rise
  2362 300F A9 00		        lda #0                  ; level rose -> SET from old to new
  2363 3011 8D 61 06		        sta pmode
  2364 3014 AD 0D 06		        lda tmp2
  2365 3017 8D B1 06		        sta dm_lo               ; lo = old
  2366 301A BD AD 06		        lda prev_vmeter,x
  2367 301D 8D B2 06		        sta dm_hi               ; hi = new
  2368 3020			dm_calc
  2369 3020 AE 46 06		        ldx s_kc
  2370 3023 AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2371 3026 0A			        asl
  2372 3027 18			        clc
  2373 3028 6D B1 06		        adc dm_lo
