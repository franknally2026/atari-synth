   603 				; Return mirrors the joystick fire button: save the patch, but only while the
   604 				; PRESET param is selected. Keep prev_preset in sync so preset_tick won't reload.
   605 22AA			nav_save_preset
   606 22AA AD 00 06		        lda cur_param
