   613 22BB			seq_toggle_play
   614 22BB AD A1 06		        lda seq_play
   615 22BE 49 01		        eor #1
   616 22C0 8D A1 06		        sta seq_play
   617 22C3 F0 0A		        beq stp_done            ; just stopped
   618 22C5 A9 00		        lda #0                  ; just started: from step 0, fire soon
   619 22C7 8D A3 06		        sta seq_pos
   620 22CA A9 01		        lda #1
   621 22CC 8D A5 06		        sta seq_timer
   622 22CF			stp_done
   623 22CF 60			        rts
   624
   625 				; SELECT = real-time record: arming clears the pattern and STARTS the clock so
   626 				; you just play in time (the live note is captured on the step under the head).
   627 				; Disarming punches out but keeps the loop playing. To step-enter instead, stop
   628 				; the clock (START) while still armed -> rec + stopped writes one step per key.
   629 22D0			seq_toggle_rec
   630 22D0 AD A2 06		        lda seq_rec
   631 22D3 49 01		        eor #1
   632 22D5 8D A2 06		        sta seq_rec
   633 22D8 F0 2F		        beq str_done            ; just disarmed -> punch out, keep playing
   634 22DA A2 0F		        ldx #15                 ; arm: clear the pattern
   635 22DC A9 FF		        lda #$FF
   636 22DE			str_clr
   637 22DE 9D 91 06		        sta seq_notes,x
   638 22E1 CA			        dex
   639 22E2 10 FA		        bpl str_clr
   640 22E4 A9 00		        lda #0
   641 22E6 8D A4 06		        sta seq_wpos
   642 22E9 8D B3 06		        sta seq_len             ; (step entry grows this; real-time loops 16)
   643 22EC 8D A3 06		        sta seq_pos             ; record from step 0
   644 22EF A9 FF		        lda #$FF
   645 22F1 8D B4 06		        sta rec_latch
   646 22F4 A9 01		        lda #1
   647 22F6 8D AA 06		        sta seq_dirty
   648 22F9 8D A1 06		        sta seq_play            ; run the clock -> real-time record
   649 22FC A9 10		        lda #16                 ; one full step of lead-in so step 0 is playable
   650 22FE 38			        sec
   651 22FF ED 8C 06		        sbc tempo
   652 2302 0A			        asl
   653 2303 18			        clc
   654 2304 69 02		        adc #2
   655 2306 8D A5 06		        sta seq_timer
   656 2309			str_done
   657 2309 60			        rts
