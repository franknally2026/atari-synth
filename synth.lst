  1445 				; ----------------------------------------------------------------------------
  1446 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1447 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1448 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1449 				; ----------------------------------------------------------------------------
  1450 292C			lfo_tick
  1451 292C AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1452 292F D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1453 2931 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1454 2934 8D 65 06		        sta lfo_level_u
  1455 2937 60			        rts
  1456 2938			lt_on
  1457 2938 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1458 2939 8D 69 06		        sta lfo_max
  1459 293C CE 67 06		        dec lfo_count
  1460 293F F0 01		        beq lt_step
  1461 2941 60			        rts
  1462 2942			lt_step
  1463 2942 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1464 2944 38			        sec
  1465 2945 ED 63 06		        sbc lfo_rate
  1466 2948 8D 67 06		        sta lfo_count
  1467 294B AD 69 06		        lda lfo_max
  1468 294E 0A			        asl
  1469 294F 8D 6A 06		        sta lfo_max2            ; 2*max
  1470 2952 AD 66 06		        lda lfo_dir
  1471 2955 30 19		        bmi lt_down
  1472 2957 EE 65 06		        inc lfo_level_u         ; ramp up
  1473 295A AD 65 06		        lda lfo_level_u
  1474 295D CD 6A 06		        cmp lfo_max2
  1475 2960 90 1E		        bcc lt_offset
  1476 2962 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1477 2965 8D 65 06		        sta lfo_level_u
  1478 2968 A9 FF		        lda #$FF
  1479 296A 8D 66 06		        sta lfo_dir
  1480 296D 4C 80 29		        jmp lt_offset
  1481 2970			lt_down
  1482 2970 AD 65 06		        lda lfo_level_u
  1483 2973 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1484 2975 CE 65 06		        dec lfo_level_u
  1485 2978 4C 80 29		        jmp lt_offset
  1486 297B			lt_rev_up
  1487 297B A9 01		        lda #1
  1488 297D 8D 66 06		        sta lfo_dir
  1489 2980			lt_offset
  1490 2980 AD 65 06		        lda lfo_level_u         ; offset = level - max  (signed)
  1491 2983 38			        sec
  1492 2984 ED 69 06		        sbc lfo_max
  1493 2987 8D 68 06		        sta lfo_offset
  1494 298A 60			        rts
