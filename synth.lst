   249 				; --- DEMO: shortcut-letter highlight style (0 = inverse video, 1 = underline)
   250 = 0001			HL_STYLE = 1
   251
   252 				; --- DEMO: DLI colour palette (0 = cool blue/green, 1 = warm orange/gold)
   253 				; EMU_KBD_IRQ: 0 = shipping/real-hardware build (no POKEY IRQs — fixes bugs #2/#3).
   254 				; 1 = test-only build that enables the keyboard IRQ so the headless AltirraSDL bridge
   255 				; can inject cooked keys (its CanPushKey gate needs IRQEN bit6). Build the test binary
   256 				; with `mads -d:EMU_KBD_IRQ=1 ...`. NEVER ship EMU_KBD_IRQ=1 — it dead-keys real hw.
   257 				    .ifndef EMU_KBD_IRQ
   258 				EMU_KBD_IRQ = 0
   259 				    .endif
   260
   261 = 0000			PALETTE = 0
   262 				    .if PALETTE = 0
   263 = 0090			TITLE_COL = $90         ; band A (title row): blue hue, near-black bg + bright text
   264 = 00C0			PANEL_COL = $C0         ; band B (panel): green hue
   265 = 0000			KBD_COL   = $00         ; band C (keyboard): neutral white
   266 				    .else
   267 				TITLE_COL = $30         ; band A: red-orange hue
   268 				PANEL_COL = $F0         ; band B: gold hue
   269 				KBD_COL   = $00         ; band C: neutral white
   270 				    .endif
