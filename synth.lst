   654 				; ----------------------------------------------------------------------------
   655 				;  Step sequencer: record note onsets into a 16-step pattern; when playing,
   656 				;  step at the TEMPO rate and trigger each step's note via trigger_note.
   657 				; ----------------------------------------------------------------------------
   658 230A			seq_tick
   659 230A AD A2 06		        lda seq_rec             ; --- record: detect a new note onset ---
   660 230D F0 40		        beq sq_norec
   661 230F AD 07 06		        lda note_idx
   662 2312 C9 FF		        cmp #$FF
   663 2314 F0 33		        beq sq_recdone
   664 2316 CD A6 06		        cmp seq_prevn
   665 2319 F0 2E		        beq sq_recdone          ; same held note -> not a new onset
   666 231B AC A1 06		        ldy seq_play
   667 231E D0 23		        bne sq_latch            ; PLAYING+REC = real-time: latch; clock writes it
   668 2320 AE A4 06		        ldx seq_wpos            ; STOPPED+REC = step entry: write here, advance
   669 2323 9D 91 06		        sta seq_notes,x
   670 2326 E8			        inx
   671 2327 EC B3 06		        cpx seq_len             ; grow loop length to the furthest step filled
   672 232A 90 03		        bcc sq_nolen
   673 232C 8E B3 06		        stx seq_len
   674 232F			sq_nolen
   675 232F E0 10		        cpx #16
   676 2331 D0 02		        bne sq_wok
   677 2333 A2 00		        ldx #0
   678 2335			sq_wok
   679 2335 8E A4 06		        stx seq_wpos
   680 2338 A9 01		        lda #1
   681 233A 8D AA 06		        sta seq_dirty
   682 233D AD 07 06		        lda note_idx
   683 2340 4C 49 23		        jmp sq_recdone
   684 2343			sq_latch
   685 2343 8D B4 06		        sta rec_latch           ; real-time: remember the onset for the clock
   686 2346 AD 07 06		        lda note_idx
   687 2349			sq_recdone
   688 2349 8D A6 06		        sta seq_prevn
   689 234C 4C 57 23		        jmp sq_play
   690 234F			sq_norec
   691 234F A9 FF		        lda #$FF
   692 2351 8D A6 06		        sta seq_prevn
   693 2354 8D B4 06		        sta rec_latch           ; not armed -> drop any pending latch
   694 2357			sq_play
   695 2357 AD A1 06		        lda seq_play            ; --- play / real-time clock ---
   696 235A D0 01		        bne sq_playing
   697 235C 60			        rts
   698 235D			sq_playing
   699 235D CE A5 06		        dec seq_timer
   700 2360 F0 01		        beq sq_step
   701 2362 60			        rts
   702 2363			sq_step
   703 2363 A9 10		        lda #16                 ; reload: interval = (16-tempo)*2 + 2 frames
   704 2365 38			        sec
   705 2366 ED 8C 06		        sbc tempo
   706 2369 0A			        asl
   707 236A 18			        clc
   708 236B 69 02		        adc #2
   709 236D 8D A5 06		        sta seq_timer
   710 2370 AE A3 06		        ldx seq_pos             ; play this step's EXISTING note (timing reference)
   711 2373 BD 91 06		        lda seq_notes,x
   712 2376 C9 FE		        cmp #$FE                ; TIE -> a held note continues: do NOT re-strike,
   713 2378 F0 3F		        beq sq_nostep           ; let the sustaining voice ring on (no blips)
   714 237A C9 FD		        cmp #$FD                ; DRUM hit step
   715 237C D0 06		        bne sq_nodrum
   716 237E 20 B2 25		        jsr drum_hit
   717 2381 4C B9 23		        jmp sq_nostep
   718 2384			sq_nodrum
   719 2384 C9 FF		        cmp #$FF
   720 2386 D0 14		        bne sq_playnote
   721 2388 AD A2 06		        lda seq_rec             ; rest step -> silence the gap by releasing the held
   722 238B F0 07		        beq sq_restrel          ; voice. Playback always releases; while recording,
   723 238D AD 07 06		        lda note_idx            ; keep a LIVE-held note (don't cut your own playing)
   724 2390 C9 FF		        cmp #$FF                ; but still release when only monitoring (no key down).
   725 2392 D0 25		        bne sq_nostep
   726 2394			sq_restrel
   727 2394 A9 FF		        lda #$FF
   728 2396 8D 18 06		        sta held_voice
   729 2399 4C B9 23		        jmp sq_nostep
   730 239C			sq_playnote
   731 239C 8D 0C 06		        sta tmpA
   732 239F AD A2 06		        lda seq_rec             ; while RECORDING, don't let the clock re-strike a note
   733 23A2 F0 08		        beq sq_pn_go            ; you're already holding live -> that would double it
   734 23A4 AD 0C 06		        lda tmpA                ; (two unison voices) and re-attack your sustained note
   735 23A7 CD 07 06		        cmp note_idx            ; every loop. note_idx is the live semitone; tmpA is the
   736 23AA F0 0D		        beq sq_nostep           ; step's. Same -> skip the clock trigger, keep monitoring.
   737 23AC			sq_pn_go
   738 23AC AC 03 06		        ldy octave
   739 23AF B9 C8 35		        lda octave_base,y
   740 23B2 18			        clc
   741 23B3 6D 0C 06		        adc tmpA
   742 23B6 20 E9 24		        jsr trigger_note
   743 23B9			sq_nostep
   744 23B9 AD A2 06		        lda seq_rec             ; real-time: capture the live note into this step
   745 23BC F0 2E		        beq sq_adv
   746 23BE AD B4 06		        lda rec_latch           ; a NEW onset latched since the last tick?
   747 23C1 C9 FF		        cmp #$FF
   748 23C3 D0 17		        bne sq_cap              ; yes -> write the struck note (re-attack)
   749 23C5 AD 07 06		        lda note_idx            ; else still holding the same key?
   750 23C8 C9 FF		        cmp #$FF
   751 23CA F0 20		        beq sq_adv              ; nothing held -> leave step (rest)
   752 23CC C9 FD		        cmp #$FD                ; a HELD drum key is a one-shot, not a sustain: don't
   753 23CE F0 1C		        beq sq_adv              ; smear it into ties (leave following steps as rests)
   754 23D0 AE A3 06		        ldx seq_pos             ; held pitch -> extend with a TIE, but ONLY into a
   755 23D3 BD 91 06		        lda seq_notes,x         ; REST. On a later loop this step already holds the
   756 23D6 C9 FF		        cmp #$FF                ; struck note (or its ties); rewriting it as a tie
   757 23D8 D0 12		        bne sq_adv              ; would wipe the attack and play back silent. Leave it.
   758 23DA A9 FE		        lda #$FE                ; held pitch over a rest -> TIE (sustains on playback)
   759 23DC			sq_cap
   760 23DC AE A3 06		        ldx seq_pos
   761 23DF 9D 91 06		        sta seq_notes,x
   762 23E2 A9 01		        lda #1
   763 23E4 8D AA 06		        sta seq_dirty
   764 23E7 A9 FF		        lda #$FF
   765 23E9 8D B4 06		        sta rec_latch           ; consume the latch
   766 23EC			sq_adv
   767 23EC EE A3 06		        inc seq_pos             ; wrap at the recorded length (or 16 if empty)
   768 23EF AE B3 06		        ldx seq_len
   769 23F2 D0 02		        bne sq_lim
   770 23F4 A2 10		        ldx #16
   771 23F6			sq_lim
   772 23F6 EC A3 06		        cpx seq_pos
   773 23F9 D0 05		        bne sq_done
   774 23FB A9 00		        lda #0
   775 23FD 8D A3 06		        sta seq_pos
   776 2400			sq_done
   777 2400 60			        rts
