  1026 25CD D0 01		        bne dt_active
  1027 25CF 60			        rts                     ; idle -> leave channel 4 to voice 3
  1028 25D0			dt_active
  1029 25D0 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1030 25D3 F0 07		        beq dt_kill
  1031 25D5 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1032 25D8 C9 02		        cmp #2
  1033 25DA D0 06		        bne dt_decay
  1034 25DC			dt_kill
  1035 25DC A9 00		        lda #0
  1036 25DE 8D BE 06		        sta drum_level
  1037 25E1 60			        rts
  1038 25E2			dt_decay
  1039 25E2 CE BF 06		        dec drum_timer
  1040 25E5 D0 09		        bne dt_emit
  1041 25E7 AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1042 25EA 8D BF 06		        sta drum_timer
  1043 25ED CE BE 06		        dec drum_level
  1044 25F0			dt_emit
  1045 25F0 A9 1E		        lda #DRUM_AUDF
  1046 25F2 8D 06 D2		        sta AUDF1+6             ; channel 4 frequency
  1047 25F5 AD BE 06		        lda drum_level          ; AUDC = distortion 0 (white-ish noise) | level
  1048 25F8 8D 07 D2		        sta AUDC1+6
