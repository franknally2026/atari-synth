  1098 				; ----------------------------------------------------------------------------
  1099 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1100 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1101 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1102 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1103 				;  address, so save/load just walk those tables.
  1104 				; ----------------------------------------------------------------------------
  1105 2644			preset_tick
  1106 2644 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1107 2647 49 01		        eor #$01
  1108 2649 29 01		        and #$01
  1109 264B 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1110 				                                ; which only touches tmp2 — NOT tmpA)
  1111 264E AE 00 06		        ldx cur_param
  1112 2651 E0 11		        cpx #17                 ; PRESET param selected?
  1113 2653 D0 13		        bne pt_load
  1114 2655 AD 0C 06		        lda tmpA
  1115 2658 F0 0E		        beq pt_load
