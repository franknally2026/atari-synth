   355 2132 A9 00		        lda #0
   356 2134 85 4D		        sta ATRACT
   357 				        ; voice count: 16-bit mode (clock 2) uses 2 voices, else 4
   358 2136 A2 04		        ldx #4
   359 2138 AD 04 06		        lda clock15
   360 213B C9 02		        cmp #2
   361 213D D0 02		        bne lp_vl
   362 213F A2 02		        ldx #2
   363 2141			lp_vl
   364 2141 8E 88 06		        stx vlimit
   365 				        ; reset all voices when the clock/range mode changes (avoid stuck notes)
   366 2144 AD 04 06		        lda clock15
   367 2147 CD 89 06		        cmp prev_clkm
   368 214A F0 1C		        beq lp_same
   369 214C 8D 89 06		        sta prev_clkm
   370 214F A2 03		        ldx #3
   371 2151			lp_clr
   372 2151 A9 00		        lda #0
   373 2153 9D 14 06		        sta voice_level,x
   374 2156 9D 20 06		        sta voice_phase,x
   375 2159 CA			        dex
