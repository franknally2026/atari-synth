  1520 				; ----------------------------------------------------------------------------
  1521 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1522 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1523 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1524 				; ----------------------------------------------------------------------------
  1525 299D			lfo_tick
  1526 299D AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1527 29A0 D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1528 29A2 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1529 29A5 8D 65 06		        sta lfo_level_u
  1530 29A8 60			        rts
  1531 29A9			lt_on
  1532 29A9 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1533 29AA 8D 69 06		        sta lfo_max
  1534 29AD CE 67 06		        dec lfo_count
  1535 29B0 F0 01		        beq lt_step
  1536 29B2 60			        rts
  1537 29B3			lt_step
  1538 29B3 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1539 29B5 38			        sec
  1540 29B6 ED 63 06		        sbc lfo_rate
  1541 29B9 8D 67 06		        sta lfo_count
  1542 29BC AD 69 06		        lda lfo_max
  1543 29BF 0A			        asl
  1544 29C0 8D 6A 06		        sta lfo_max2            ; 2*max
  1545 29C3 AD 66 06		        lda lfo_dir
  1546 29C6 30 19		        bmi lt_down
  1547 29C8 EE 65 06		        inc lfo_level_u         ; ramp up
  1548 29CB AD 65 06		        lda lfo_level_u
  1549 29CE CD 6A 06		        cmp lfo_max2
  1550 29D1 90 1E		        bcc lt_offset
  1551 29D3 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1552 29D6 8D 65 06		        sta lfo_level_u
  1553 29D9 A9 FF		        lda #$FF
  1554 29DB 8D 66 06		        sta lfo_dir
  1555 29DE 4C F1 29		        jmp lt_offset
  1556 29E1			lt_down
  1557 29E1 AD 65 06		        lda lfo_level_u
  1558 29E4 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1559 29E6 CE 65 06		        dec lfo_level_u
