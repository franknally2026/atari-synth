  1508 				; ----------------------------------------------------------------------------
  1509 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1510 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1511 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1512 				; ----------------------------------------------------------------------------
  1513 298D			lfo_tick
  1514 298D AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1515 2990 D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1516 2992 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1517 2995 8D 65 06		        sta lfo_level_u
  1518 2998 60			        rts
  1519 2999			lt_on
  1520 2999 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1521 299A 8D 69 06		        sta lfo_max
  1522 299D CE 67 06		        dec lfo_count
  1523 29A0 F0 01		        beq lt_step
  1524 29A2 60			        rts
  1525 29A3			lt_step
  1526 29A3 A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1527 29A5 38			        sec
  1528 29A6 ED 63 06		        sbc lfo_rate
  1529 29A9 8D 67 06		        sta lfo_count
  1530 29AC AD 69 06		        lda lfo_max
  1531 29AF 0A			        asl
  1532 29B0 8D 6A 06		        sta lfo_max2            ; 2*max
  1533 29B3 AD 66 06		        lda lfo_dir
  1534 29B6 30 19		        bmi lt_down
  1535 29B8 EE 65 06		        inc lfo_level_u         ; ramp up
  1536 29BB AD 65 06		        lda lfo_level_u
  1537 29BE CD 6A 06		        cmp lfo_max2
  1538 29C1 90 1E		        bcc lt_offset
  1539 29C3 AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1540 29C6 8D 65 06		        sta lfo_level_u
  1541 29C9 A9 FF		        lda #$FF
  1542 29CB 8D 66 06		        sta lfo_dir
  1543 29CE 4C E1 29		        jmp lt_offset
  1544 29D1			lt_down
  1545 29D1 AD 65 06		        lda lfo_level_u
  1546 29D4 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1547 29D6 CE 65 06		        dec lfo_level_u
  1548 29D9 4C E1 29		        jmp lt_offset
  1549 29DC			lt_rev_up
  1550 29DC A9 01		        lda #1
  1551 29DE 8D 66 06		        sta lfo_dir
  1552 29E1			lt_offset
  1553 29E1 AD 65 06		        lda lfo_level_u         ; offset = level - max  (signed)
  1554 29E4 38			        sec
  1555 29E5 ED 69 06		        sbc lfo_max
  1556 29E8 8D 68 06		        sta lfo_offset
  1557 29EB 60			        rts
