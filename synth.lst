   526 21E0 A9 FF		        lda #$FF
   527 21E2 8D 07 06		        sta note_idx
   528 21E5 60			        rts
   529 21E6			rk_drum
   530 21E6 A9 FD		        lda #$FD                ; $FD = "drum note": flows through live-hit,
   531 21E8 8D 07 06		        sta note_idx            ; sequencer record (drum lane) and playback
   532 21EB 60			        rts
   533 21EC			rk_found
   534 21EC 8E 07 06		        stx note_idx
   535 21EF 60			        rts
