   470 				; Console keys (CONSOL $D01F, active low): OPTION (bit2) = sustain pedal (level),
   471 				; START (bit0) = play/stop, SELECT (bit1) = record arm (edge-triggered).
   472 				; Independent of the scanned key matrix, so they work while a note key is down.
   473 21CD			read_console
   474 21CD AD 1F D0		        lda CONSOL
   475 21D0 49 07		        eor #$07                ; now 1 = pressed
   476 21D2 29 07		        and #$07
   477 21D4 8D AB 06		        sta con_now
   478 21D7 29 04		        and #$04                ; OPTION -> sustain pedal (level)
   479 21D9 F0 04		        beq rc_noopt
   480 21DB A9 01		        lda #1
   481 21DD D0 02		        bne rc_setopt
   482 21DF			rc_noopt
   483 21DF A9 00		        lda #0
   484 21E1			rc_setopt
   485 21E1 8D 87 06		        sta sustain_ped
   486 21E4 AD AC 06		        lda con_prev            ; edges = now & ~prev
   487 21E7 49 FF		        eor #$FF
   488 21E9 2D AB 06		        and con_now
   489 21EC 8D 0C 06		        sta tmpA
   490 21EF 29 01		        and #$01                ; START edge -> toggle play
   491 21F1 F0 03		        beq rc_nostart
   492 21F3 20 BB 22		        jsr seq_toggle_play
   493 21F6			rc_nostart
   494 21F6 AD 0C 06		        lda tmpA
