  2516 				; ----------------------------------------------------------------------------
  2517 				;  Per-voice level meters: 4 horizontal VU bars at scan 9-13, bar width =
  2518 				;  voice envelope level * 3 px. Drawn INCREMENTALLY -- each frame only the
  2519 				;  delta between the old and new level is set/cleared, so meters animating
  2520 				;  with the envelopes cost a few pixels per voice, not a full redraw.
  2521 				; ----------------------------------------------------------------------------
  2522 30AB			draw_meters
  2523 30AB A2 00		        ldx #0
  2524 30AD			dm_loop
  2525 30AD 8E 46 06		        stx s_kc
  2526 30B0 BD 14 06		        lda voice_level,x
  2527 30B3 DD AD 06		        cmp prev_vmeter,x
  2528 30B6 F0 69		        beq dm_next
  2529 30B8 BC AD 06		        ldy prev_vmeter,x       ; old level
  2530 30BB 8C 0D 06		        sty tmp2
  2531 30BE 9D AD 06		        sta prev_vmeter,x       ; store new
  2532 30C1 CD 0D 06		        cmp tmp2                ; new - old
  2533 30C4 B0 14		        bcs dm_rise
  2534 30C6 A9 FF		        lda #$FF                ; level fell -> CLEAR from new to old
  2535 30C8 8D 61 06		        sta pmode
  2536 30CB AD 0D 06		        lda tmp2
  2537 30CE 8D B2 06		        sta dm_hi               ; hi = old
  2538 30D1 BD AD 06		        lda prev_vmeter,x
  2539 30D4 8D B1 06		        sta dm_lo               ; lo = new
  2540 30D7 4C EB 30		        jmp dm_calc
  2541 30DA			dm_rise
  2542 30DA A9 00		        lda #0                  ; level rose -> SET from old to new
  2543 30DC 8D 61 06		        sta pmode
  2544 30DF AD 0D 06		        lda tmp2
  2545 30E2 8D B1 06		        sta dm_lo               ; lo = old
  2546 30E5 BD AD 06		        lda prev_vmeter,x
  2547 30E8 8D B2 06		        sta dm_hi               ; hi = new
  2548 30EB			dm_calc
  2549 30EB AE 46 06		        ldx s_kc
  2550 30EE AD B1 06		        lda dm_lo               ; xlo = met_x[v] + lo*3
  2551 30F1 0A			        asl
  2552 30F2 18			        clc
  2553 30F3 6D B1 06		        adc dm_lo
  2554 30F6 18			        clc
  2555 30F7 7D 2F 31		        adc met_x,x
  2556 30FA 8D 40 06		        sta xlo
  2557 30FD A9 00		        lda #0
  2558 30FF 8D 41 06		        sta xhi
  2559 3102 AD B2 06		        lda dm_hi               ; rw = (hi - lo)*3
  2560 3105 38			        sec
