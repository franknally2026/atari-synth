   137 				; LFO (vibrato) state
   138 = 0663			lfo_rate    = $0663     ; 0..15 panel param
   139 = 0664			lfo_depth   = $0664     ; 0..15 panel param
   140 = 0665			lfo_level_u = $0665     ; unsigned 0..2*lfo_max triangle counter
   141 = 0666			lfo_dir     = $0666     ; +1 / $FF
