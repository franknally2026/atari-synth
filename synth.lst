   482 21E4 AD AC 06		        lda con_prev            ; edges = now & ~prev
   483 21E7 49 FF		        eor #$FF
   484 21E9 2D AB 06		        and con_now
   485 21EC 8D 0C 06		        sta tmpA
   486 21EF 29 01		        and #$01                ; START edge -> toggle play
   487 21F1 F0 03		        beq rc_nostart
   488 21F3 20 BB 22		        jsr seq_toggle_play
   489 21F6			rc_nostart
