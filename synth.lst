   503 				; Navigation keys (laptop play, no joystick needed). The Atari arrow keys are
   504 				; Ctrl + the -/=/+/* keys; Ctrl sets KBCODE bit6 ($40), so they read UNMASKED as
   505 				; $4E/$4F/$46/$47 (read_keyboard masks #$3F for the note matrix and ignores
   506 				; these). Arrows set kbd_dir level bits -> update_input gives them the same
   507 				; nav/adjust/auto-repeat as the joystick. Tab/Return are edge-triggered via nav_prev.
   508 				;   Up=$4E Down=$4F Left=$46 Right=$47   Tab=$2C (page flip)   Return=$0C (save)
   509 2207			read_navkeys
   510 2207 A9 00		        lda #0
   511 2209 8D CE 06		        sta kbd_dir
   512 220C AD 0F D2		        lda SKSTAT
   513 220F 29 04		        and #$04
   514 2211 D0 74		        bne rn_none             ; no key down
   515 2213 AD 09 D2		        lda KBCODE
   516 2216 C9 4E		        cmp #$4E                ; UP    (Ctrl+MINUS)
   517 2218 D0 08		        bne rn_n1
   518 221A A9 01		        lda #$01
   519 221C 8D CE 06		        sta kbd_dir
   520 221F 4C 80 22		        jmp rn_seen
   521 2222			rn_n1
   522 2222 C9 4F		        cmp #$4F                ; DOWN  (Ctrl+EQUALS)
   523 2224 D0 08		        bne rn_n2
   524 2226 A9 02		        lda #$02
   525 2228 8D CE 06		        sta kbd_dir
   526 222B 4C 80 22		        jmp rn_seen
   527 222E			rn_n2
   528 222E C9 46		        cmp #$46                ; LEFT  (Ctrl+PLUS)
   529 2230 D0 08		        bne rn_n3
   530 2232 A9 04		        lda #$04
   531 2234 8D CE 06		        sta kbd_dir
   532 2237 4C 80 22		        jmp rn_seen
   533 223A			rn_n3
   534 223A C9 47		        cmp #$47                ; RIGHT (Ctrl+ASTERISK)
   535 223C D0 08		        bne rn_n4
   536 223E A9 08		        lda #$08
   537 2240 8D CE 06		        sta kbd_dir
   538 2243 4C 80 22		        jmp rn_seen
   539 2246			rn_n4
   540 2246 C9 2C		        cmp #$2C                ; Tab -> cycle page (edge only, no repeat)
   541 2248 D0 0D		        bne rn_n5
   542 224A AE CF 06		        ldx nav_prev
   543 224D E0 2C		        cpx #$2C
   544 224F F0 2F		        beq rn_seen
   545 2251 20 8D 22		        jsr page_flip
   546 2254 4C 80 22		        jmp rn_seen
   547 2257			rn_n5
   548 2257 C9 0C		        cmp #$0C                ; Return -> save preset (joystick-fire substitute)
   549 2259 D0 0D		        bne rn_short
   550 225B AE CF 06		        ldx nav_prev
   551 225E E0 0C		        cpx #$0C
   552 2260 F0 1E		        beq rn_seen
   553 2262 20 AA 22		        jsr nav_save_preset
   554 2265 4C 80 22		        jmp rn_seen
   555 2268			rn_short
   556 				        ; letter shortcut: a free letter that's underlined in a param's label jumps
   557 				        ; the selection straight to that param (A still holds raw KBCODE here). Only
   558 				        ; the 6 params whose letter is UNIQUE have an entry (see shortcut_kc).
   559 2268 A2 11		        ldx #NSHORT-1
   560 226A			rn_short_l
   561 226A DD 1A 38		        cmp shortcut_kc,x
   562 226D F0 06		        beq rn_short_hit
   563 226F CA			        dex
   564 2270 10 F8		        bpl rn_short_l
   565 2272 4C 80 22		        jmp rn_seen             ; not a shortcut key
   566 2275			rn_short_hit
   567 2275 CD CF 06		        cmp nav_prev            ; A = this key = shortcut_kc[x]; held -> no re-jump
   568 2278 F0 06		        beq rn_seen
   569 227A BD 2C 38		        lda shortcut_param,x    ; jump (cur_param drives the page too)
   570 227D 8D 00 06		        sta cur_param
   571 2280			rn_seen
   572 2280 AD 09 D2		        lda KBCODE              ; remember this frame's key for next-frame edge detect
   573 2283 8D CF 06		        sta nav_prev
   574 2286 60			        rts
   575 2287			rn_none
   576 2287 A9 FF		        lda #$FF
   577 2289 8D CF 06		        sta nav_prev
   578 228C 60			        rts
