  1008 				; ----------------------------------------------------------------------------
  1009 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
  1010 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
  1011 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
  1012 				;  high channel). drum_tick runs after update_sound and overrides channel 4
  1013 				;  while a hit rings; when it ends, voice 3's normal output resumes.
  1014 				; ----------------------------------------------------------------------------
  1015 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
  1016 25B2			drum_hit
  1017 25B2 AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
  1018 25B5 F0 12		        beq dh_off
  1019 25B7 AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
  1020 25BA C9 02		        cmp #2
  1021 25BC F0 0B		        beq dh_off
  1022 25BE A9 0F		        lda #15
  1023 25C0 8D BE 06		        sta drum_level
  1024 25C3 AD BD 06		        lda drum_dec            ; full level held for one decay interval first
  1025 25C6 8D BF 06		        sta drum_timer
  1026 25C9			dh_off
  1027 25C9 60			        rts
  1028 25CA			drum_tick
  1029 25CA AD BE 06		        lda drum_level
  1030 25CD D0 01		        bne dt_active
  1031 25CF 60			        rts                     ; idle -> leave channel 4 to voice 3
  1032 25D0			dt_active
  1033 25D0 AD BD 06		        lda drum_dec            ; DRUM turned off -> silence any ringing drum
  1034 25D3 F0 07		        beq dt_kill
  1035 25D5 AD 04 06		        lda clock15             ; 16-bit reclaimed channel 4 -> drop the drum
  1036 25D8 C9 02		        cmp #2
  1037 25DA D0 06		        bne dt_decay
  1038 25DC			dt_kill
  1039 25DC A9 00		        lda #0
  1040 25DE 8D BE 06		        sta drum_level
  1041 25E1 60			        rts
  1042 25E2			dt_decay
  1043 25E2 CE BF 06		        dec drum_timer
  1044 25E5 D0 09		        bne dt_emit
  1045 25E7 AD BD 06		        lda drum_dec            ; reload decay interval (DRUM param)
  1046 25EA 8D BF 06		        sta drum_timer
  1047 25ED CE BE 06		        dec drum_level
  1048 25F0			dt_emit
  1049 25F0 A9 1E		        lda #DRUM_AUDF
  1050 25F2 8D 06 D2		        sta AUDF1+6             ; channel 4 frequency
  1051 25F5 AD BE 06		        lda drum_level          ; AUDC = distortion 0 (white-ish noise) | level
  1052 25F8 8D 07 D2		        sta AUDC1+6
  1053 25FB 60			        rts
