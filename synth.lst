  1459 				; ----------------------------------------------------------------------------
  1460 				;  LFO (vibrato): a triangle that ramps a signed pitch offset between
  1461 				;  -lfo_max and +lfo_max; rate sets step interval, depth sets amplitude.
  1462 				;  No multiply: lfo_level_u counts 0..2*max, offset = level - max.
  1463 				; ----------------------------------------------------------------------------
  1464 2949			lfo_tick
  1465 2949 AD 64 06		        lda lfo_depth           ; depth 0 -> LFO fully off, instantly flat
  1466 294C D0 07		        bne lt_on               ; (don't let the triangle counter decay slowly,
  1467 294E 8D 68 06		        sta lfo_offset          ;  which would leave a residual pitch offset)
  1468 2951 8D 65 06		        sta lfo_level_u
  1469 2954 60			        rts
  1470 2955			lt_on
  1471 2955 4A			        lsr                     ; amplitude = depth/2 (0..7)
  1472 2956 8D 69 06		        sta lfo_max
  1473 2959 CE 67 06		        dec lfo_count
  1474 295C F0 01		        beq lt_step
  1475 295E 60			        rts
  1476 295F			lt_step
  1477 295F A9 10		        lda #16                 ; reload: rate 0 -> slow (16), 15 -> fast (1)
  1478 2961 38			        sec
  1479 2962 ED 63 06		        sbc lfo_rate
  1480 2965 8D 67 06		        sta lfo_count
  1481 2968 AD 69 06		        lda lfo_max
  1482 296B 0A			        asl
  1483 296C 8D 6A 06		        sta lfo_max2            ; 2*max
  1484 296F AD 66 06		        lda lfo_dir
  1485 2972 30 19		        bmi lt_down
  1486 2974 EE 65 06		        inc lfo_level_u         ; ramp up
  1487 2977 AD 65 06		        lda lfo_level_u
  1488 297A CD 6A 06		        cmp lfo_max2
  1489 297D 90 1E		        bcc lt_offset
  1490 297F AD 6A 06		        lda lfo_max2            ; hit top -> clamp, reverse
  1491 2982 8D 65 06		        sta lfo_level_u
  1492 2985 A9 FF		        lda #$FF
  1493 2987 8D 66 06		        sta lfo_dir
  1494 298A 4C 9D 29		        jmp lt_offset
  1495 298D			lt_down
  1496 298D AD 65 06		        lda lfo_level_u
  1497 2990 F0 06		        beq lt_rev_up           ; at 0 -> reverse
  1498 2992 CE 65 06		        dec lfo_level_u
  1499 2995 4C 9D 29		        jmp lt_offset
  1500 2998			lt_rev_up
  1501 2998 A9 01		        lda #1
  1502 299A 8D 66 06		        sta lfo_dir
  1503 299D			lt_offset
  1504 299D AD 65 06		        lda lfo_level_u         ; offset = level - max  (signed)
  1505 29A0 38			        sec
  1506 29A1 ED 69 06		        sbc lfo_max
  1507 29A4 8D 68 06		        sta lfo_offset
  1508 29A7 60			        rts
