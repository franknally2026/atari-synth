   473 				; Console keys (CONSOL $D01F, active low): OPTION (bit2) = sustain pedal (level),
   474 				; START (bit0) = play/stop, SELECT (bit1) = record arm (edge-triggered).
   475 				; Independent of the scanned key matrix, so they work while a note key is down.
   476 21CD			read_console
   477 21CD AD 1F D0		        lda CONSOL
   478 21D0 49 07		        eor #$07                ; now 1 = pressed
   479 21D2 29 07		        and #$07
   480 21D4 8D AB 06		        sta con_now
   481 21D7 29 04		        and #$04                ; OPTION -> sustain pedal (level)
   482 21D9 F0 04		        beq rc_noopt
   483 21DB A9 01		        lda #1
   484 21DD D0 02		        bne rc_setopt
   485 21DF			rc_noopt
   486 21DF A9 00		        lda #0
   487 21E1			rc_setopt
   488 21E1 8D 87 06		        sta sustain_ped
   489 21E4 AD AC 06		        lda con_prev            ; edges = now & ~prev
   490 21E7 49 FF		        eor #$FF
   491 21E9 2D AB 06		        and con_now
   492 21EC 8D 0C 06		        sta tmpA
   493 21EF 29 01		        and #$01                ; START edge -> toggle play
   494 21F1 F0 03		        beq rc_nostart
   495 21F3 20 BB 22		        jsr seq_toggle_play
   496 21F6			rc_nostart
   497 21F6 AD 0C 06		        lda tmpA
   498 21F9 29 02		        and #$02                ; SELECT edge -> toggle record
   499 21FB F0 03		        beq rc_nosel
   500 21FD 20 D0 22		        jsr seq_toggle_rec
   501 2200			rc_nosel
   502 2200 AD AB 06		        lda con_now
   503 2203 8D AC 06		        sta con_prev
   504 2206 60			        rts
