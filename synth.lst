  1088 				; ----------------------------------------------------------------------------
  1089 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1090 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1091 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1092 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1093 				;  address, so save/load just walk those tables.
  1094 				; ----------------------------------------------------------------------------
  1095 262D			preset_tick
  1096 262D AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1097 2630 49 01		        eor #$01
  1098 2632 29 01		        and #$01
  1099 2634 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1100 				                                ; which only touches tmp2 — NOT tmpA)
  1101 2637 AE 00 06		        ldx cur_param
  1102 263A E0 11		        cpx #17                 ; PRESET param selected?
  1103 263C D0 13		        bne pt_load
  1104 263E AD 0C 06		        lda tmpA
  1105 2641 F0 0E		        beq pt_load
  1106 2643 AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1107 2646 D0 09		        bne pt_load
