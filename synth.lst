mads 2.1.8
synth.asm -o:synth.xex -l:synth.lst 
Source: synth.asm
     1 				; ============================================================================
     2 				;  ATARI POKEY SYNTH  -  GR.8 bitmap UI
     3 				;  Keyboard-playable 4-voice POKEY synth with an ADSR envelope and a drawn
     4 				;  control panel (knobs + switches up top, a piano keyboard along the bottom).
     5 				;
     6 				;  Play:   white keys Q W E R T Y U I O P  (naturals C D E F G A B C D E)
     7 				;          black keys 2 3 5 6 7 9 0         (sharps  C# D# F# G# A# C# D#)
     8 				;  Panel:  joystick UP/DOWN selects a parameter, LEFT/RIGHT adjusts it.
     9 				;
    10 				;  Video:  GR.8 (ANTIC mode $0F), 320x192, 1bpp, custom display list.
    11 				;  Target: PAL Atari XL/XE.  Assemble with MADS.
    12 				; ============================================================================
    13
    14 				; ----- OS / hardware equates ------------------------------------------------
    15 = 0012			RTCLOK  = $12           ; frame counter; +2 ($14) ticks every VBI
    16 = 004D			ATRACT  = $4D           ; attract-mode timer (clear to suppress colour cycling)
    17 = 02F0			CRSINH  = $02F0         ; cursor inhibit
    18 = 02DB			NOCLIK  = $02DB         ; key-click disable
    19 = 0278			STICK0  = $0278         ; OS joystick-0 shadow, active low
    20 = D010			STRIG0  = $D010         ; joystick-0 trigger (fire), 0 = pressed
    21 = 0230			SDLSTL  = $0230         ; OS display-list pointer (shadow)
    22 = 022F			SDMCTL  = $022F         ; OS DMACTL shadow
    23 = 02C5			COLOR1  = $02C5         ; COLPF1 shadow (hi-res foreground luminance)
    24 = 02C6			COLOR2  = $02C6         ; COLPF2 shadow (background)
    25 = 02C8			COLOR4  = $02C8         ; COLBK shadow (border)
    26
    27 = D01F			CONSOL  = $D01F         ; console keys START/SELECT/OPTION (read, active low)
    28 = D209			KBCODE  = $D209         ; raw keyboard scan code
    29 = D20F			SKSTAT  = $D20F         ; serial/keyboard status (read)
    30 = D20F			SKCTL   = $D20F         ; serial/keyboard control (write)
    31 = D200			AUDF1   = $D200         ; channel-1 frequency divisor
    32 = D201			AUDC1   = $D201         ; channel-1 control (distortion | volume)
    33 = D208			AUDCTL  = $D208         ; POKEY global audio control
    34
    35 = E000			ROMFONT = $E000         ; OS ROM character set (8 bytes/glyph, screen-code index)
    36 				; DEMO: DLI colour-band hardware registers
    37 = D40A			WSYNC   = $D40A         ; wait for horizontal sync (write)
    38 = D018			COLPF2  = $D018         ; playfield-2 colour (hi-res: hue of fg + bg)
    39 = D40E			NMIEN   = $D40E         ; NMI enable (bit7 = DLI, bit6 = VBI)
    40 = 0200			VDSLST  = $0200         ; DLI vector
    41 = 4000			FB1     = $4000         ; framebuffer region 1 (scan lines 0..101)
    42 = 5000			FB2     = $5000         ; framebuffer region 2 (scan lines 102..191)
    43 = 6000			linetab_lo = $6000      ; 192 bytes: low byte of each scan line's address
    44 = 60C0			linetab_hi = $60C0      ; 192 bytes: high byte
    45 				                        ; NOTE: kept ABOVE the framebuffers ($4000-$5E0F) and clear
    46 				                        ; of the program/descriptor tables ($2000-$3D59). The old
    47 				                        ; $3000 scratch collided with the param_*/p_* tables once the
    48 				                        ; code grew past $3000 (build_linetab clobbered the label
    49 				                        ; pointers -> draw_page_labels looped forever). Don't move it
    50 				                        ; back into program space.
    51
    52 = 0084			KBTOP   = 132           ; piano keyboard top scan line (shifted down 8 from 124 to
    53 				                        ; open a hint-line row at HINTSCAN; uses the slack below
    54 				                        ; the keyboard, so the keys stay full size)
    55 = 007C			HINTSCAN = 124          ; context-sensitive hint line, just above the keyboard
    56
    57 				; ----- zero-page pointers (free OS scratch $CB-$D1) -------------------------
    58 = 00CB			scrptr  = $CB           ; word: general dest pointer
    59 = 00CD			srcptr  = $CD           ; word: source (font / table / string)
    60 = 00CF			adjptr  = $CF           ; word: blit dest line / apply_adjust target
    61
    62 				; ----- work variables (free RAM, page 6) ------------------------------------
    63 = 0600			cur_param   = $0600     ; selected panel parameter 0..7
    64 = 0601			wave_idx    = $0601     ; 0..3  -> SQUARE/PURE/BUZZ/NOISE
    65 = 0602			volume      = $0602     ; 0..15 (envelope peak)
    66 = 0603			octave      = $0603     ; 0..4  (centre 2 = +0)
    67 = 0604			clock15     = $0604     ; clock/range mode: 0 NORMAL, 1 15KHZ, 2 16-BIT
    68 = 0605			prev_pressed= $0605
    69 = 0606			rep_timer   = $0606
    70 = 0607			note_idx    = $0607     ; current note 0..16, or $FF = none
    71 = 0608			prev_note   = $0608     ; last highlighted note
    72 = 0609			pressed     = $0609
    73 = 060A			edge        = $060A
    74 = 060B			delta       = $060B
    75 = 060C			tmpA        = $060C
    76 = 060D			tmp2        = $060D
    77 = 060E			cnt         = $060E
    78
    79 				; ADSR params (0..15)
    80 = 062C			atk_rate    = $062C
    81 = 062D			dec_rate    = $062D
    82 = 062E			sus_level   = $062E
    83 = 062F			rel_rate    = $062F
    84 = 0630			sus_clamp   = $0630
    85
    86 				; voices (4)
    87 = 0610			voice_note  = $0610     ; 4: absolute chromatic index
    88 = 0614			voice_level = $0614     ; 4: envelope level 0..15
    89 = 0618			held_voice  = $0618
    90 = 0619			last_voice  = $0619
    91 = 061C			vfreq       = $061C
    92 = 061D			vctl        = $061D
    93 = 061E			prev_held   = $061E
    94 = 0620			voice_phase = $0620     ; 4: PH_*
    95 = 0624			voice_count = $0624     ; 4: frames to next step
    96
    97 				; graphics scratch
    98 = 0640			xlo     = $0640
    99 = 0641			xhi     = $0641
   100 = 0642			py      = $0642
   101 = 0643			s0      = $0643
   102 = 0644			s1      = $0644
   103 = 0645			s_dy    = $0645
   104 = 0646			s_kc    = $0646
   105 = 0647			s_pc    = $0647
   106 = 0648			bc_code = $0648
   107 = 0649			bc_col  = $0649
   108 = 064A			bc_scan = $064A
   109 = 064B			bc_inv  = $064B
   110 = 064C			psi     = $064C
   111 = 064D			pcnt    = $064D
   112 = 064E			kcx     = $064E
   113 = 064F			kcy     = $064F
   114 = 0650			kfrm    = $0650
   115 = 0651			rw      = $0651
   116 = 0652			rh      = $0652
   117 = 0653			r_x     = $0653
   118 = 0654			r_xh    = $0654
   119 = 0655			r_y     = $0655
   120 = 0656			wxl     = $0656
   121 = 0657			wxh     = $0657
   122 = 0658			prev_param = $0658
   123 = 0659			prev_wave  = $0659
   124 = 065A			prev_vol   = $065A
   125 = 065B			prev_oct   = $065B
   126 = 065C			prev_atk   = $065C
   127 = 065D			prev_dec   = $065D
   128 = 065E			prev_sus   = $065E
   129 = 065F			prev_rel   = $065F
   130 = 0660			prev_clk   = $0660
   131 = 0661			pmode      = $0661      ; plot mode: 0 = set pixel, $FF = clear pixel
   132 = 0662			bc_mode    = $0662      ; blit mode: 0 = set (white on black), $FF = clear (black on white)
   133
   134 				; LFO (vibrato) state
   135 = 0663			lfo_rate    = $0663     ; 0..15 panel param
   136 = 0664			lfo_depth   = $0664     ; 0..15 panel param
   137 = 0665			lfo_level_u = $0665     ; unsigned 0..2*lfo_max triangle counter
   138 = 0666			lfo_dir     = $0666     ; +1 / $FF
   139 = 0667			lfo_count   = $0667     ; frames to next LFO step
   140 = 0668			lfo_offset  = $0668     ; signed pitch offset added to AUDF
   141 = 0669			lfo_max     = $0669
   142 = 066A			lfo_max2    = $066A
   143 				; draw_param scratch (NOT touched by draw_knob/num2)
   144 = 066B			dp_val      = $066B
   145 = 066C			dp_numcol   = $066C
   146 = 066D			dp_scan     = $066D
   147 				; DETUNE (fat pitch)
   148 = 066E			detune      = $066E     ; 0..15 panel param
   149 = 066F			detune_amt  = $066F     ; detune >> 2 (per-voice AUDF step)
   150 = 0670			prev_disp   = $0670     ; NPARAM bytes ($0670-$067B): last displayed value
   151 = 06C1			dvoff       = $06C1     ; 4 bytes: per-voice detune AUDF offset (moved up: prev_disp
   152 				                        ; grew with NPARAM and reached the old $0680 slot)
   153 				; arpeggiator
   154 = 0684			arp_rate    = $0684     ; 0 = off, 1..15 = step speed
   155 = 0685			arp_step    = $0685     ; pattern position 0..3
   156 = 0686			arp_timer   = $0686     ; frames to next arp step
   157 				; --- new feature work vars (allocated above the sequencer block at $06B5+ so
   158 				;     they stay clear of prev_disp, which grows with NPARAM) ---
   159 = 06B5			arp_mode    = $06B5     ; arpeggiator pattern: 0 UP, 1 DOWN, 2 MINOR, 3 OCTAVE
   160 = 06B6			porta_rate  = $06B6     ; portamento (glide): 0 off, 1..15 = AUDF step every N frames
   161 = 06B7			porta_timer = $06B7     ; frames to next glide step
   162 = 06B8			porta_cur   = $06B8     ; 4: current (gliding) AUDF per voice
   163 = 06BC			porta_step  = $06BC     ; 1 on frames where the glide advances one step
   164 = 06BD			drum_dec    = $06BD     ; DRUM param: 0 off, 1..15 = decay frames per level step
   165 = 06BE			drum_level  = $06BE     ; current drum envelope level (0 = drum channel free)
   166 = 06BF			drum_timer  = $06BF     ; frames to next drum decay step
   167 = 06C0			hpf_cut     = $06C0     ; HP filter: 0 off, 1..15 cutoff (uses ch3 as the clock)
   168 = 06C5			preset_slot = $06C5     ; PRESET param: selected patch slot 0..3
   169 = 06C6			prev_preset = $06C6     ; last slot (detect selection change -> load)
   170 = 06C7			preset_fp   = $06C7     ; previous fire-button state (edge detect for save)
   171 = 06C8			drum_key    = $06C8     ; previous drum-key ('1') state (edge detect for live hit)
   172 = 06C9			drum_beat   = $06C9     ; DRUMBEAT param: 0 off, 1..15 auto drum-machine rate
   173 = 06CA			dbeat_timer = $06CA     ; frames to next tempo beat
   174 = 06CB			dbeat_cnt   = $06CB     ; tempo beats remaining until the next auto drum hit
   175 = 0700			preset_bank = $0700     ; 4 slots x NSAVE bytes of saved params (page 7, free RAM)
   176 = 0687			sustain_ped = $0687     ; 1 while OPTION held -> notes don't release
   177 = 0688			vlimit      = $0688     ; active voice count: 4 (8-bit) or 2 (16-bit)
   178 = 0689			prev_clkm   = $0689     ; previous clock mode (detect change -> reset voices)
   179 = 068A			nlo         = $068A     ; 16-bit divider scratch (low/high)
   180 = 068B			nhi         = $068B
   181 = 068C			tempo       = $068C     ; sequencer tempo (0..15), page-2 param
   182 = 068D			page        = $068D     ; current panel page (cur_param / 12)
   183 = 068E			prev_page   = $068E
   184 = 068F			pg_base     = $068F     ; first param index of current page
   185 = 0690			pg_end      = $0690     ; one past last param index of current page
   186 				; step sequencer
   187 = 0691			seq_notes   = $0691     ; 16 steps: semitone 0..16, or $FF = rest
   188 = 06A1			seq_play    = $06A1     ; 0 stopped / 1 playing
   189 = 06A2			seq_rec     = $06A2     ; 0 / 1 record-armed
   190 = 06A3			seq_pos     = $06A3     ; play head 0..15
   191 = 06A4			seq_wpos    = $06A4     ; record write head 0..15
   192 = 06A5			seq_timer   = $06A5     ; frames to next step
   193 = 06A6			seq_prevn   = $06A6     ; previous note (record onset edge)
   194 = 06A7			prev_spos   = $06A7     ; last drawn play head (display diff)
   195 = 06A8			prev_splay  = $06A8
   196 = 06A9			prev_srec   = $06A9
   197 = 06AA			seq_dirty   = $06AA     ; 1 = step grid needs full redraw
   198 = 06AB			con_now     = $06AB     ; console keys pressed bits (active high)
   199 = 06AC			con_prev    = $06AC
   200 				; per-voice level meters (VU bars at the top, scan 9-13)
   201 = 06AD			prev_vmeter = $06AD     ; 4: last drawn level per voice (incremental redraw)
   202 = 06B1			dm_lo       = $06B1     ; meter draw scratch: lower envelope level
   203 = 06B2			dm_hi       = $06B2     ; meter draw scratch: higher envelope level
   204 = 06B3			seq_len     = $06B3     ; playback loop length = number of recorded steps (1..16)
   205 = 06B4			rec_latch   = $06B4     ; real-time record: note played since last step ($FF=none)
   206 = 06CC			hl_idx      = $06CC     ; DEMO: char index in current label to highlight
   207 = 06CD			dli_idx     = $06CD     ; DEMO: which colour band the next DLI sets (reset each frame)
   208 = 06CE			kbd_dir     = $06CE     ; arrow-key direction bits (mirrors STICK0: U/D/L/R) for update_input
   209 = 06CF			nav_prev    = $06CF     ; last nav-key KBCODE ($FF=none); edge-detect Tab/Return
   210 = 06D0			dp_zoff     = $06D0     ; draw_param: 1 = this param renders value 0 as "OFF"
   211 = 06D1			prev_hint   = $06D1     ; last drawn hint-line id ($FF = force redraw)
   212 = 06D2			pl_inv      = $06D2     ; print_label base inverse: $FF = focused param (inverse video)
   213 = 06D3			hl_shift    = $06D3     ; 1 = the shortcut char is a SHIFT key (drawn opposite video)
   214 = 06D4			saved_flash = $06D4     ; >0 = show "SAVED" over the PRESET name for this many frames
   215
   216 = 0013			NPARAM = 19             ; ...page2 16 HPF, 17 PRESET, 18 DRUMBEAT
   217 = 0011			NSAVE  = 17             ; params 0..16 are saved in a preset (PRESET itself is not)
   218 = 0010			PG2BASE = 16            ; first param index on page 2 (the third page)
   219 = 000C			PER_PAGE = 12
   220 = 0000			K_KNOB = 0              ; 0..15 value -> knob + 2-digit number
   221 = 0001			K_OCT  = 1              ; octave (0..4) -> knob + signed number
   222 = 0002			K_WAVE = 2              ; waveform icon selector
   223 = 0003			K_CLK  = 3              ; NORM|15K toggle
   224
   225 = 0000			PH_IDLE    = 0
   226 = 0001			PH_ATTACK  = 1
   227 = 0002			PH_DECAY   = 2
   228 = 0003			PH_SUSTAIN = 3
   229 = 0004			PH_RELEASE = 4
   230
   231 = 000F			REPDELAY = 15
   232 = 0004			REPFAST  = 4
   233 = 0004			DECAYRATE = 4
   234 = 0011			NUMKEYS  = 17
   235 = 0012			NSHORT   = 18           ; 13 plain (page 0 + DRUMBEAT) + 5 Shift (page 1/2)
   236
   237 				; --- DEMO: shortcut-letter highlight style (0 = inverse video, 1 = underline)
   238 = 0001			HL_STYLE = 1
   239
   240 				; --- DEMO: DLI colour palette (0 = cool blue/green, 1 = warm orange/gold)
   241 = 0000			PALETTE = 0
   242 				    .if PALETTE = 0
   243 = 0090			TITLE_COL = $90         ; band A (title row): blue hue, near-black bg + bright text
   244 = 00C0			PANEL_COL = $C0         ; band B (panel): green hue
   245 = 0000			KBD_COL   = $00         ; band C (keyboard): neutral white
   246 				    .else
   247 				TITLE_COL = $30         ; band A: red-orange hue
   248 				PANEL_COL = $F0         ; band B: gold hue
   249 				KBD_COL   = $00         ; band C: neutral white
   250 				    .endif
   251
   252 				; ----------------------------------------------------------------------------
   253 				        org $2000
   254
   255 				main
   256 FFFF> 2000-38FE> A9 01	        lda #1
   257 2002 8D F0 02		        sta CRSINH
   258 2005 A9 FF		        lda #$FF
   259 2007 8D DB 02		        sta NOCLIK
   260 200A A9 03		        lda #$03
   261 200C 8D 0F D2		        sta SKCTL
   262
   263 200F 20 A8 29		        jsr gr8_init            ; set up GR.8 + clear
   264
   265 				        ; parameter defaults
   266 2012 A9 00		        lda #0
   267 2014 8D 00 06		        sta cur_param
   268 2017 8D 01 06		        sta wave_idx
   269 201A 8D 04 06		        sta clock15
   270 201D 8D 05 06		        sta prev_pressed
   271 2020 A9 0A		        lda #10
   272 2022 8D 02 06		        sta volume
   273 2025 A9 02		        lda #2
   274 2027 8D 03 06		        sta octave
   275 202A A9 FF		        lda #$FF
   276 202C 8D 07 06		        sta note_idx
   277 202F 8D 08 06		        sta prev_note
   278 2032 8D 18 06		        sta held_voice
   279 2035 8D 1E 06		        sta prev_held
   280 2038 A9 0F		        lda #REPDELAY
   281 203A 8D 06 06		        sta rep_timer
   282 203D A9 03		        lda #3
   283 203F 8D 19 06		        sta last_voice
   284 2042 A2 03		        ldx #3
   285 2044			init_voice
   286 2044 A9 00		        lda #0
   287 2046 9D 14 06		        sta voice_level,x
   288 2049 9D 20 06		        sta voice_phase,x
   289 204C A9 01		        lda #1
   290 204E 9D 24 06		        sta voice_count,x
   291 2051 CA			        dex
   292 2052 10 F0		        bpl init_voice
   293 2054 A9 00		        lda #0
   294 2056 8D 2C 06		        sta atk_rate
   295 2059 A9 02		        lda #2
   296 205B 8D 2D 06		        sta dec_rate
   297 205E A9 08		        lda #8
   298 2060 8D 2E 06		        sta sus_level
   299 2063 A9 03		        lda #3
   300 2065 8D 2F 06		        sta rel_rate
   301
   302 2068 A9 08		        lda #8                  ; LFO defaults: mid rate, off (depth 0)
   303 206A 8D 63 06		        sta lfo_rate
   304 206D A9 00		        lda #0
   305 206F 8D 64 06		        sta lfo_depth
   306 2072 8D 65 06		        sta lfo_level_u
   307 2075 8D 68 06		        sta lfo_offset
   308 2078 A9 01		        lda #1
   309 207A 8D 66 06		        sta lfo_dir
   310 207D 8D 67 06		        sta lfo_count
   311 2080 A9 00		        lda #0
   312 2082 8D 6E 06		        sta detune
   313 2085 8D 84 06		        sta arp_rate
   314 2088 8D 85 06		        sta arp_step
   315 208B 8D B5 06		        sta arp_mode
   316 208E 8D B6 06		        sta porta_rate          ; portamento off; glide state cleared
   317 2091 8D B8 06		        sta porta_cur
   318 2094 8D B9 06		        sta porta_cur+1
   319 2097 8D BA 06		        sta porta_cur+2
   320 209A 8D BB 06		        sta porta_cur+3
   321 209D 8D BC 06		        sta porta_step
   322 20A0 8D BD 06		        sta drum_dec            ; drum off, idle
   323 20A3 8D BE 06		        sta drum_level
   324 20A6 8D C0 06		        sta hpf_cut             ; high-pass filter off
   325 20A9 8D C5 06		        sta preset_slot         ; preset slot 0, no load/fire pending
   326 20AC 8D C6 06		        sta prev_preset
   327 20AF 8D C7 06		        sta preset_fp
   328 20B2 8D C8 06		        sta drum_key
   329 20B5 8D C9 06		        sta drum_beat           ; auto drum-beat off
   330 20B8 8D 87 06		        sta sustain_ped
   331 20BB 8D 89 06		        sta prev_clkm
   332 20BE 8D 8D 06		        sta page
   333 20C1 8D A1 06		        sta seq_play
   334 20C4 8D A2 06		        sta seq_rec
   335 20C7 8D A3 06		        sta seq_pos
   336 20CA 8D A4 06		        sta seq_wpos
   337 20CD 8D AC 06		        sta con_prev
   338 20D0 A9 08		        lda #8
   339 20D2 8D 8C 06		        sta tempo
   340 20D5 A9 01		        lda #1
   341 20D7 8D B7 06		        sta porta_timer
   342 20DA 8D BF 06		        sta drum_timer
   343 20DD 8D CA 06		        sta dbeat_timer
   344 20E0 8D CB 06		        sta dbeat_cnt
   345 20E3 A9 FF		        lda #$FF
   346 20E5 8D 8E 06		        sta prev_page           ; force first-frame page render
   347 20E8 8D D1 06		        sta prev_hint           ; force first-frame hint-line draw
   348 20EB 8D A6 06		        sta seq_prevn
   349 20EE 8D A7 06		        sta prev_spos
   350 20F1 A2 0F		        ldx #15                 ; clear sequencer pattern
   351 20F3 A9 FF		        lda #$FF
   352 20F5			seq_init
   353 20F5 9D 91 06		        sta seq_notes,x
   354 20F8 CA			        dex
   355 20F9 10 FA		        bpl seq_init
   356 20FB A9 01		        lda #1
   357 20FD 8D 86 06		        sta arp_timer
   358 2100 8D A5 06		        sta seq_timer
   359 2103 A9 10		        lda #16                  ; default loop length (empty pattern = silence)
   360 2105 8D B3 06		        sta seq_len
   361 2108 A9 FF		        lda #$FF
   362 210A 8D B4 06		        sta rec_latch
   363 210D A2 03		        ldx #3                   ; VU meters start empty (match cleared screen)
   364 210F A9 00		        lda #0
   365 2111			vm_init
   366 2111 9D AD 06		        sta prev_vmeter,x
   367 2114 CA			        dex
   368 2115 10 FA		        bpl vm_init
   369
   370 2117 A9 FF		        lda #$FF                 ; force first-frame redraw of every widget
   371 2119 8D 58 06		        sta prev_param
   372 211C A2 12		        ldx #NPARAM-1
   373 211E			init_prev
   374 211E 9D 70 06		        sta prev_disp,x
   375 2121 CA			        dex
   376 2122 10 FA		        bpl init_prev
   377
   378 2124 A2 43		        ldx #4*NSAVE-1           ; copy factory presets into the editable bank
   379 2126			preset_copy
   380 2126 BD DA 26		        lda preset_factory,x
   381 2129 9D 00 07		        sta preset_bank,x
   382 212C CA			        dex
   383 212D 10 F7		        bpl preset_copy
   384
   385 212F 20 0A 2D		        jsr draw_static_gfx     ; panel labels + piano keyboard (once)
   386
   387 2132			loop
   388 2132 20 42 29		        jsr wait_vbl            ; sync, then draw starting at the frame top
   389 2135 A9 00		        lda #0
   390 2137 8D CD 06		        sta dli_idx             ; DEMO: restart colour-band sequence for this frame
   391 213A 85 4D		        sta ATRACT
   392 				        ; voice count: 16-bit mode (clock 2) uses 2 voices, else 4
   393 213C A2 04		        ldx #4
   394 213E AD 04 06		        lda clock15
   395 2141 C9 02		        cmp #2
   396 2143 D0 02		        bne lp_vl
   397 2145 A2 02		        ldx #2
   398 2147			lp_vl
