   779 				; Unified directional input: up/down navigate, left/right adjust. ALL FOUR now
   780 				; auto-repeat off one rep_timer (was: U/D edge-only, L/R repeated). Arrow keys are
   781 				; merged in via kbd_dir (read_navkeys) so they drive the exact same path.
   782 2401			update_input
   783 2401 AD 78 02		        lda STICK0
   784 2404 29 0F		        and #$0F
   785 2406 49 0F		        eor #$0F                ; bit0=up bit1=down bit2=left bit3=right (active high)
   786 2408 0D CE 06		        ora kbd_dir             ; merge arrow keys -> identical nav/adjust/repeat
   787 240B 8D 09 06		        sta pressed
   788 240E AD 05 06		        lda prev_pressed
   789 2411 49 FF		        eor #$FF
   790 2413 2D 09 06		        and pressed
   791 2416 8D 0A 06		        sta edge                ; freshly-pressed directions this frame
   792 2419 AD 09 06		        lda pressed
   793 241C 29 0F		        and #$0F
   794 241E D0 08		        bne ui_held
   795 2420 A9 0F		        lda #REPDELAY           ; nothing held -> re-arm the initial delay
   796 2422 8D 06 06		        sta rep_timer
   797 2425 4C 89 24		        jmp ui_done
   798 2428			ui_held
   799 2428 AD 0A 06		        lda edge
   800 242B 29 0F		        and #$0F
   801 242D D0 0D		        bne ui_fresh            ; a fresh press -> act immediately
   802 242F CE 06 06		        dec rep_timer
   803 2432 D0 55		        bne ui_done             ; still counting down -> no action this frame
   804 2434 A9 04		        lda #REPFAST            ; timer expired -> repeat at the fast rate
   805 2436 8D 06 06		        sta rep_timer
   806 2439 4C 41 24		        jmp ui_act
   807 243C			ui_fresh
   808 243C A9 0F		        lda #REPDELAY
   809 243E 8D 06 06		        sta rep_timer
   810 2441			ui_act
   811 2441 AD 09 06		        lda pressed             ; UP -> previous param (wrap)
   812 2444 29 01		        and #$01
   813 2446 F0 0A		        beq ui_a_nodn
   814 2448 CE 00 06		        dec cur_param
   815 244B 10 05		        bpl ui_a_nodn
   816 244D A9 12		        lda #NPARAM-1
   817 244F 8D 00 06		        sta cur_param
   818 2452			ui_a_nodn
   819 2452 AD 09 06		        lda pressed             ; DOWN -> next param (wrap)
   820 2455 29 02		        and #$02
   821 2457 F0 0F		        beq ui_a_nolr
   822 2459 EE 00 06		        inc cur_param
   823 245C AD 00 06		        lda cur_param
   824 245F C9 13		        cmp #NPARAM
   825 2461 D0 05		        bne ui_a_nolr
   826 2463 A9 00		        lda #0
   827 2465 8D 00 06		        sta cur_param
   828 2468			ui_a_nolr
   829 2468 AD 09 06		        lda pressed             ; LEFT -> value -1
   830 246B 29 04		        and #$04
   831 246D F0 0B		        beq ui_a_tryr
   832 246F A9 FF		        lda #$FF
