  2202 2F56 38			        sec
  2203 2F57 ED B1 06		        sbc dm_lo
  2204 2F5A 8D 0C 06		        sta tmpA
  2205 2F5D 0A			        asl
  2206 2F5E 18			        clc
  2207 2F5F 6D 0C 06		        adc tmpA
