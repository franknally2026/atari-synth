  1102 				; ----------------------------------------------------------------------------
  1103 				;  Presets: 4 slots of the 17 sound params (everything except PRESET itself).
  1104 				;  Selecting a slot with the PRESET knob LOADS it live; pressing FIRE while the
  1105 				;  PRESET param is selected SAVES the current sound into the slot. The bank is
  1106 				;  seeded from preset_factory at boot. param_lo/param_hi give each param's
  1107 				;  address, so save/load just walk those tables.
  1108 				; ----------------------------------------------------------------------------
  1109 2644			preset_tick
  1110 2644 AD 10 D0		        lda STRIG0              ; fire-now: STRIG0 active low (0 = pressed)
  1111 2647 49 01		        eor #$01
  1112 2649 29 01		        and #$01
  1113 264B 8D 0C 06		        sta tmpA                ; tmpA = 1 if pressed (survives jsr preset_save,
  1114 				                                ; which only touches tmp2 — NOT tmpA)
  1115 264E AE 00 06		        ldx cur_param
  1116 2651 E0 11		        cpx #17                 ; PRESET param selected?
  1117 2653 D0 13		        bne pt_load
  1118 2655 AD 0C 06		        lda tmpA
  1119 2658 F0 0E		        beq pt_load
  1120 265A AD C7 06		        lda preset_fp           ; require a fresh press (edge), not a hold
  1121 265D D0 09		        bne pt_load
  1122 265F 20 8C 26		        jsr preset_save
  1123 2662 AD C5 06		        lda preset_slot         ; keep prev in sync so we don't reload after save
  1124 2665 8D C6 06		        sta prev_preset
  1125 2668			pt_load
