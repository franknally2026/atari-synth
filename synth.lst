    84 = 062D			dec_rate    = $062D
    85 = 062E			sus_level   = $062E
    86 = 062F			rel_rate    = $062F
    87 = 0630			sus_clamp   = $0630
    88
    89 				; voices (4)
    90 = 0610			voice_note  = $0610     ; 4: absolute chromatic index
    91 = 0614			voice_level = $0614     ; 4: envelope level 0..15
    92 = 0618			held_voice  = $0618
    93 = 0619			last_voice  = $0619
    94 = 061C			vfreq       = $061C
    95 = 061D			vctl        = $061D
    96 = 061E			prev_held   = $061E
    97 = 0620			voice_phase = $0620     ; 4: PH_*
    98 = 0624			voice_count = $0624     ; 4: frames to next step
