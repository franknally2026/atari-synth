  2433 306A BC AD 06		        ldy prev_vmeter,x       ; old level
  2434 306D 8C 0D 06		        sty tmp2
  2435 3070 9D AD 06		        sta prev_vmeter,x       ; store new
  2436 3073 CD 0D 06		        cmp tmp2                ; new - old
  2437 3076 B0 14		        bcs dm_rise
