   537 				; Console keys (CONSOL $D01F, active low): OPTION (bit2) = sustain pedal (level),
   538 				; START (bit0) = play/stop, SELECT (bit1) = record arm (edge-triggered).
   539 				; Independent of the scanned key matrix, so they work while a note key is down.
   540 21F0			read_console
   541 21F0 AD 1F D0		        lda CONSOL
   542 21F3 49 07		        eor #$07                ; now 1 = pressed
   543 21F5 29 07		        and #$07
   544 21F7 8D AB 06		        sta con_now
   545 21FA 29 04		        and #$04                ; OPTION -> sustain pedal (level)
   546 21FC F0 04		        beq rc_noopt
   547 21FE A9 01		        lda #1
   548 2200 D0 02		        bne rc_setopt
   549 2202			rc_noopt
   550 2202 A9 00		        lda #0
   551 2204			rc_setopt
   552 2204 8D 87 06		        sta sustain_ped
   553 2207 AD AC 06		        lda con_prev            ; edges = now & ~prev
   554 220A 49 FF		        eor #$FF
   555 220C 2D AB 06		        and con_now
   556 220F 8D 0C 06		        sta tmpA
   557 2212 29 01		        and #$01                ; START edge -> toggle play
   558 2214 F0 03		        beq rc_nostart
   559 2216 20 09 23		        jsr seq_toggle_play
   560 2219			rc_nostart
   561 2219 AD 0C 06		        lda tmpA
   562 221C 29 02		        and #$02                ; SELECT edge -> toggle record
   563 221E F0 03		        beq rc_nosel
   564 2220 20 1E 23		        jsr seq_toggle_rec
   565 2223			rc_nosel
   566 2223 AD AB 06		        lda con_now
   567 2226 8D AC 06		        sta con_prev
   568 2229 60			        rts
   569
   570 				; Navigation keys (laptop play, no joystick needed).
   571 				;
   572 				; HARDWARE NOTE (verified on a real Atari, 2026-06-16): KBCODE's modifier bits
   573 				; and the arrow keys do NOT match the atari800/Altirra convention this code was
   574 				; first written against:
   575 				;   * Shift sets KBCODE bit6 ($40)  (the emulator used bit7 $80).
   576 				;   * The arrow keys read BARE -- Up=$0E Down=$0F Left=$06 Right=$07 -- with NO
   577 				;     modifier bit (the emulator delivered Ctrl+arrow as $4E/$4F/$46/$47).
   578 				; So we mask KBCODE to #$3F (base code) and match arrows/Tab/Return/shortcuts on
   579 				; the base, and treat ANY modifier bit (#$C0) as Shift. Masking the base makes
   580 				; the arrows work whether they arrive bare ($06) or Ctrl-modified ($46), and the
   581 				; #$C0 test catches Shift whether it lands on bit6 (hardware) or bit7 (emulator),
   582 				; so the same binary is correct in both places. Shift is matched (not ignored)
   583 				; because plain and Shift letter shortcuts share base codes (e.g. L and ^L).
   584 				; Arrows set kbd_dir level bits -> update_input gives them the same nav/adjust/
   585 				; auto-repeat as the joystick. Tab/Return are edge-triggered via nav_prev.
   586 				;   base: Up=$0E Down=$0F Left=$06 Right=$07   Tab=$2C (page flip)  Return=$0C
   587 222A			read_navkeys
   588 222A A9 00		        lda #0
   589 222C 8D CE 06		        sta kbd_dir
   590 222F AD 0F D2		        lda SKSTAT
   591 2232 29 04		        and #$04
   592 2234 F0 03		        beq rn_haskey           ; (rn_none is out of beq range from here)
   593 2236 4C D5 22		        jmp rn_none
   594 2239			rn_haskey
   595 2239 AD 09 D2		        lda KBCODE
   596 223C 29 3F		        and #$3F                ; base code (drop Shift/Ctrl modifier bits)
   597 223E 8D DB 06		        sta nav_base
   598 2241 AD 09 D2		        lda KBCODE
   599 2244 29 C0		        and #$C0                ; any modifier bit set -> treat as Shift
   600 2246 F0 02		        beq rn_sh0
   601 2248 A9 01		        lda #1
   602 224A			rn_sh0
   603 224A 8D DC 06		        sta nav_shift
   604 224D AD DB 06		        lda nav_base
   605 2250 C9 0E		        cmp #$0E                ; UP    ('-')
   606 2252 D0 08		        bne rn_n1
   607 2254 A9 01		        lda #$01
   608 2256 8D CE 06		        sta kbd_dir
   609 2259 4C CE 22		        jmp rn_seen
   610 225C			rn_n1
   611 225C C9 0F		        cmp #$0F                ; DOWN  ('=')
   612 225E D0 08		        bne rn_n2
   613 2260 A9 02		        lda #$02
   614 2262 8D CE 06		        sta kbd_dir
   615 2265 4C CE 22		        jmp rn_seen
   616 2268			rn_n2
   617 2268 C9 06		        cmp #$06                ; LEFT  ('+')
   618 226A D0 08		        bne rn_n3
   619 226C A9 04		        lda #$04
   620 226E 8D CE 06		        sta kbd_dir
   621 2271 4C CE 22		        jmp rn_seen
   622 2274			rn_n3
   623 2274 C9 07		        cmp #$07                ; RIGHT ('*')
   624 2276 D0 08		        bne rn_n4
   625 2278 A9 08		        lda #$08
   626 227A 8D CE 06		        sta kbd_dir
   627 227D 4C CE 22		        jmp rn_seen
   628 2280			rn_n4
   629 2280 C9 2C		        cmp #$2C                ; Tab -> cycle page (edge only, no repeat)
   630 2282 D0 10		        bne rn_n5
   631 2284 AE CF 06		        ldx nav_prev
   632 2287 E0 2C		        cpx #$2C
   633 2289 D0 03		        bne rn_tab_go           ; (rn_seen is out of beq range from here)
   634 228B 4C CE 22		        jmp rn_seen
   635 228E			rn_tab_go
   636 228E 20 DB 22		        jsr page_flip
   637 2291 4C CE 22		        jmp rn_seen
   638 2294			rn_n5
   639 2294 C9 0C		        cmp #$0C                ; Return -> save preset (joystick-fire substitute)
   640 2296 D0 10		        bne rn_short
   641 2298 AE CF 06		        ldx nav_prev
   642 229B E0 0C		        cpx #$0C
   643 229D D0 03		        bne rn_ret_go
   644 229F 4C CE 22		        jmp rn_seen
   645 22A2			rn_ret_go
   646 22A2 20 F8 22		        jsr nav_save_preset
   647 22A5 4C CE 22		        jmp rn_seen
   648 22A8			rn_short
   649 				        ; letter shortcut: a free letter underlined in a param's label jumps the
   650 				        ; selection straight to that param. Match on the base code AND the Shift
   651 				        ; flag (a plain letter and its Shift twin share a base code).
   652 22A8 A2 12		        ldx #NSHORT-1
   653 22AA			rn_short_l
   654 22AA BD A4 38		        lda shortcut_sh,x
   655 22AD CD DC 06		        cmp nav_shift
   656 22B0 D0 08		        bne rn_short_nx
   657 22B2 AD DB 06		        lda nav_base
   658 22B5 DD 91 38		        cmp shortcut_kc,x
   659 22B8 F0 06		        beq rn_short_hit
   660 22BA			rn_short_nx
   661 22BA CA			        dex
   662 22BB 10 ED		        bpl rn_short_l
   663 22BD 4C CE 22		        jmp rn_seen             ; not a shortcut key
   664 22C0			rn_short_hit
   665 22C0 AD 09 D2		        lda KBCODE              ; held across frames -> no re-jump (edge detect)
   666 22C3 CD CF 06		        cmp nav_prev
   667 22C6 F0 06		        beq rn_seen
   668 22C8 BD B7 38		        lda shortcut_param,x    ; jump (cur_param drives the page too)
   669 22CB 8D 00 06		        sta cur_param
   670 22CE			rn_seen
   671 22CE AD 09 D2		        lda KBCODE              ; remember this frame's key for next-frame edge detect
   672 22D1 8D CF 06		        sta nav_prev
   673 22D4 60			        rts
   674 22D5			rn_none
   675 22D5 A9 FF		        lda #$FF
   676 22D7 8D CF 06		        sta nav_prev
   677 22DA 60			        rts
   678
   679 				; Tab: jump the selection to the first param of the next page (0->1->2->0).
   680 				; update_display derives the page from cur_param, so this is all it takes.
   681 22DB			page_flip
   682 22DB AD 00 06		        lda cur_param
   683 22DE C9 0C		        cmp #PER_PAGE           ; page 0 (0..11) -> page 1
   684 22E0 90 0A		        bcc pf_to1
   685 22E2 C9 10		        cmp #PG2BASE            ; page 1 (12..15) -> page 2
   686 22E4 90 0C		        bcc pf_to2
   687 22E6 A9 00		        lda #0                  ; page 2 -> wrap to page 0
   688 22E8 8D 00 06		        sta cur_param
   689 22EB 60			        rts
   690 22EC			pf_to1
   691 22EC A9 0C		        lda #PER_PAGE
   692 22EE 8D 00 06		        sta cur_param
   693 22F1 60			        rts
   694 22F2			pf_to2
   695 22F2 A9 10		        lda #PG2BASE
   696 22F4 8D 00 06		        sta cur_param
   697 22F7 60			        rts
