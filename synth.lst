   627 				; SELECT = real-time record: arming clears the pattern and STARTS the clock so
   628 				; you just play in time (the live note is captured on the step under the head).
   629 				; Disarming punches out but keeps the loop playing. To step-enter instead, stop
   630 				; the clock (START) while still armed -> rec + stopped writes one step per key.
   631 22D0			seq_toggle_rec
   632 22D0 AD A2 06		        lda seq_rec
   633 22D3 49 01		        eor #1
   634 22D5 8D A2 06		        sta seq_rec
   635 22D8 F0 2F		        beq str_done            ; just disarmed -> punch out, keep playing
   636 22DA A2 0F		        ldx #15                 ; arm: clear the pattern
   637 22DC A9 FF		        lda #$FF
   638 22DE			str_clr
   639 22DE 9D 91 06		        sta seq_notes,x
   640 22E1 CA			        dex
   641 22E2 10 FA		        bpl str_clr
   642 22E4 A9 00		        lda #0
   643 22E6 8D A4 06		        sta seq_wpos
   644 22E9 8D B3 06		        sta seq_len             ; (step entry grows this; real-time loops 16)
   645 22EC 8D A3 06		        sta seq_pos             ; record from step 0
   646 22EF A9 FF		        lda #$FF
   647 22F1 8D B4 06		        sta rec_latch
   648 22F4 A9 01		        lda #1
   649 22F6 8D AA 06		        sta seq_dirty
   650 22F9 8D A1 06		        sta seq_play            ; run the clock -> real-time record
   651 22FC A9 10		        lda #16                 ; one full step of lead-in so step 0 is playable
   652 22FE 38			        sec
   653 22FF ED 8C 06		        sbc tempo
   654 2302 0A			        asl
   655 2303 18			        clc
   656 2304 69 02		        adc #2
   657 2306 8D A5 06		        sta seq_timer
   658 2309			str_done
   659 2309 60			        rts
