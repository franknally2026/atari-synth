   982 				; ----------------------------------------------------------------------------
   983 				;  Drum voice: a noise-percussion hit on channel 4 (its own subsystem, not the
   984 				;  ADSR voice engine). Triggered by a $FD sequencer step. DRUM param = decay
   985 				;  length (0 = off). 8-bit clock modes only (in 16-bit, channel 4 is a joined
   986 				;  high channel). drum_tick runs after update_sound and overrides channel 4
   987 				;  while a hit rings; when it ends, voice 3's normal output resumes.
   988 				; ----------------------------------------------------------------------------
   989 = 001E			DRUM_AUDF = $1E                 ; noise tone of the drum (fixed)
   990 2585			drum_hit
   991 2585 AD BD 06		        lda drum_dec            ; DRUM = 0 -> off
   992 2588 F0 12		        beq dh_off
   993 258A AD 04 06		        lda clock15             ; no drum in 16-bit mode (channel 4 is paired)
   994 258D C9 02		        cmp #2
   995 258F F0 0B		        beq dh_off
   996 2591 A9 0F		        lda #15
   997 2593 8D BE 06		        sta drum_level
   998 2596 AD BD 06		        lda drum_dec            ; full level held for one decay interval first
   999 2599 8D BF 06		        sta drum_timer
