  1030 25D3			dt_emit
  1031 25D3 A9 1E		        lda #DRUM_AUDF
  1032 25D5 8D 06 D2		        sta AUDF1+6             ; channel 4 frequency
  1033 25D8 AD BE 06		        lda drum_level          ; AUDC = distortion 0 (white-ish noise) | level
  1034 25DB 8D 07 D2		        sta AUDC1+6
